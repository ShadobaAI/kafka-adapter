
#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	ИмяМетода = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Параметры, "ИмяМетода");

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Асинх Процедура ИмяМетодаНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ИмяМетода = Элемент.ТекстРедактирования;
	
	Если ПустаяСтрока(ИмяМетода) Тогда
		Возврат;
	КонецЕсли;
	
	ЧастиИмени = СтрРазделить(ИмяМетода, ".");
	
	Текст = Новый Массив;
	Для Каждого Элемент Из СтрРазделить(Элементы.ИмяМетодаРасширеннаяПодсказка.Заголовок, Символы.ПС) Цикл
		Текст.Добавить(СтрШаблон("// %1", Элемент));
	КонецЦикла;
	
	Текст.Добавить(СтрШаблон(НСтр("ru = 'Процедура %1(ТелоСообщения, Свойства, ТекстЖурнала, Отказ) Экспорт'"), ЧастиИмени[ЧастиИмени.ВГраница()]));
	Текст.Добавить("
	|	
	|	// TODO: Вставить содержимое обработчика
	|	
	|");
	Текст.Добавить(НСтр("ru = 'КонецПроцедуры'"));
	
	КодПроцедуры = СтрСоединить(Текст, Символы.ПС);
	
	Ждать СредстваБуфераОбмена.ПоместитьДанныеАсинх(
		Новый ЭлементБуфераОбмена(СтандартныйФорматДанныхБуфераОбмена.Текст, КодПроцедуры));
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОК(Команда)
	
	Закрыть(ИмяМетода);
	
КонецПроцедуры

#КонецОбласти
