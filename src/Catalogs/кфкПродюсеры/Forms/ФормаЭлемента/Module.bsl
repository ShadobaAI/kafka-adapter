КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура УстановитьВидимостьДоступность()
	
	Элементы.ФормаГруппаБлокировка.Доступность = Не Объект.Ссылка.Пустая();
	Элементы.ФормаБлокироватьРегистрацию.Пометка = Объект.БлокироватьРегистрацию;
	Элементы.ФормаБлокироватьСериализацию.Пометка = Объект.БлокироватьСериализацию;
	Элементы.ФормаБлокироватьПубликацию.Пометка = Объект.БлокироватьПубликацию;
	
	Элементы.ДекорацияБлокироватьРегистрацию.Видимость = Объект.БлокироватьРегистрацию;
	Элементы.ДекорацияБлокироватьСериализацию.Видимость = Объект.БлокироватьСериализацию;
	Элементы.ДекорацияБлокироватьПубликацию.Видимость = Объект.БлокироватьПубликацию;
	
КонецПроцедуры

&НаКлиенте
Процедура УстановитьВидимостьСериализации()
	
	// ПроизвольныйОбработчик
	ТипСериализации = ПредопределенноеЗначение("Перечисление.кфкТипыОбработчиков.ПроизвольныйОбработчик");
	Строки = Объект.ОбъектыМетаданных.НайтиСтроки(Новый Структура("ТипСериализации", ТипСериализации));
	Элементы.ОбъектыМетаданныхИмяМетодаСериализации.Видимость = Строки.Количество() > 0;
	
	// КонвертацияДанных
	ТипСериализации = ПредопределенноеЗначение("Перечисление.кфкТипыОбработчиков.КонвертацияДанных");
	Строки = Объект.ОбъектыМетаданных.НайтиСтроки(Новый Структура("ТипСериализации", ТипСериализации));
	Элементы.ОбъектыМетаданныхГруппаСериализацияКД.Видимость = Строки.Количество() > 0;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьПоток(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
		
	ИначеЕсли Результат.Статус = "Ошибка" Тогда
		Если Результат.Свойство("ИнформацияОбОшибке") И Результат.ИнформацияОбОшибке <> Неопределено Тогда
			СтандартныеПодсистемыКлиент.ВывестиИнформациюОбОшибке(Результат.ИнформацияОбОшибке);
			
		ИначеЕсли Не ПустаяСтрока(Результат.ПодробноеПредставлениеОшибки) Тогда // TODO: ИнформацияОбОшибке с БСП 3.1.10
			ОбщегоНазначенияКлиент.СообщитьПользователю(Результат.ПодробноеПредставлениеОшибки);
			
		Иначе
			ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru = 'Не удалось выполнить проверку подключения к брокеру.'"));
		КонецЕсли;
		
		Возврат;
		 
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьВыбораОбъектаМетаданных(РезультатЗакрытия, ДополнительныеПараметры) Экспорт
	
	Если РезультатЗакрытия = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Элементы.ОбъектыМетаданных.ТекущиеДанные;
	
	Строки = Объект.ОбъектыМетаданных.НайтиСтроки(Новый Структура("ТипОбъект", РезультатЗакрытия));
	Для Каждого Строка Из Строки Цикл
		//@skip-check bsl-legacy-check-dynamic-feature-access
		Если ТекущиеДанные.НомерСтроки <> Строка.НомерСтроки Тогда
			Возврат;
		КонецЕсли;
	КонецЦикла;
	
	ТекущиеДанные.ТипОбъект = РезультатЗакрытия;
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Процедура ЗавершитьВводаОбработчика(РезультатЗакрытия, ДополнительныеПараметры) Экспорт
	
	Если РезультатЗакрытия = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущиеДанные = Элементы.ОбъектыМетаданных.ТекущиеДанные;
	ТекущиеДанные.ИмяМетодаСериализации = РезультатЗакрытия;
	
	Модифицированность = Истина;
	
КонецПроцедуры

&НаКлиенте
Функция КлючиПараметровПродюсера()
	
	Результат = Новый Массив;
	Для Каждого ПараметрОтправки Из Объект.ПараметрыПродюсера Цикл
		Результат.Добавить(ПараметрОтправки.Ключ);
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

&НаКлиенте
Процедура ИнициализироватьПравилаОбмена()
	
	ТекущиеДанные = Элементы.ОбъектыМетаданных.ТекущиеДанные;
	Если ТекущиеДанные = Неопределено Или ПустаяСтрока(ТекущиеДанные.ИмяМодуляСериализации) Тогда
		Возврат;
	КонецЕсли;
	
	ОчиститьСообщения();
	
	КлючПравилОбмена = ТекущиеДанные.ИмяМодуляСериализации;
	
	СписокВыбора = Элементы.ОбъектыМетаданныхИмяПОДСериализации.СписокВыбора;
	СписокВыбора.Очистить();
	
	ПОДы = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ПравилаОбработкиДанных, КлючПравилОбмена); // Неопределено, Массив
	Если ПОДы = Неопределено Тогда
		
		ПОДы = ДоступныеПОДы(ТекущиеДанные.ИмяМодуляСериализации); // Неопределено, Массив
		
		Правила = ?(ПравилаОбработкиДанных = Неопределено, Новый Структура, Новый Структура(ПравилаОбработкиДанных));
		Правила.Вставить(КлючПравилОбмена, ПОДы);
		ПравилаОбработкиДанных = Новый ФиксированнаяСтруктура(Правила);
		
	КонецЕсли;
	
	Если ТипЗнч(ПОДы) = Тип("Массив") Тогда
		СписокВыбора.ЗагрузитьЗначения(ПОДы);
		
	ИначеЕсли ТекущиеДанные.ТипСериализации
			= ПредопределенноеЗначение("Перечисление.кфкТипыОбработчиков.КонвертацияДанных") Тогда
		НомерСтроки = ТекущиеДанные.НомерСтроки;
		ТекстОшибки = ОбщегоНазначенияКлиентСервер.ТекстОшибкиЗаполнения("Колонка", "Корректность",
			НСтр("ru = 'Имя модуля'"), НомерСтроки, НСтр("ru = 'Объекты метаданных'"),
			СтрШаблон(НСтр("ru = '''%1'' - не найден'"), ТекущиеДанные.ИмяМодуляСериализации));
		Поле = ОбщегоНазначенияКлиентСервер.ПутьКТабличнойЧасти("ОбъектыМетаданных", НомерСтроки,
			"ИмяМодуляСериализации");
		ОбщегоНазначенияКлиент.СообщитьПользователю(ТекстОшибки, , Поле, "Объект");
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиентеНаСервереБезКонтекста
Функция СтандартныеПараметрыКонсьюмера()
	
//	см. Обработка.кфкИнтеграция.ОтправитьСообщение()
	
	Результат = Новый Соответствие;
	Результат.Вставить("message.timeout.ms", 5000); // с этим параметром поакуратнее	
	
	Возврат Результат;
	
КонецФункции

