// @strict-types
#Если Сервер Или ТолстыйКлиентОбычноеПриложение Или ВнешнееСоединение Тогда

#Область ОбработчикиСобытий

Процедура ОбработкаПолученияФормы(ВидФормы, Параметры, ВыбраннаяФорма, ДополнительнаяИнформация, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	ВыбраннаяФорма = Метаданные.Обработки.кфкПанельАдминистрирования.ОсновнаяФорма;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныйПрограммныйИнтерфейс

Функция ПолучитьПараметры() Экспорт
	
	Результат = Новый Структура;
	
	Результат.Вставить("СрокХраненияНезавершенных", 7);
	
	// ИсходящиеСообщения
	Результат.Вставить("СрокХраненияОшибкиОбработкиИсходящих", 3);
	Результат.Вставить("СрокХраненияОтмененныхИсходящих", 1);
	Результат.Вставить("СрокХраненияОшибкиОтправки", 3);
	Результат.Вставить("СрокХраненияОтправленных", 1);
	
	// ВходящиеСообщения
	Результат.Вставить("СрокХраненияОшибкиОбработкиВходящих", 3);
	Результат.Вставить("СрокХраненияОтмененныхВходящих", 1);
	Результат.Вставить("СрокХраненияОбработанных", 1);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	кфкПараметрыОчисткиХранилища.СрокХраненияНезавершенных КАК СрокХраненияНезавершенных,
	|	кфкПараметрыОчисткиХранилища.СрокХраненияОбработанных КАК СрокХраненияОбработанных,
	|	кфкПараметрыОчисткиХранилища.СрокХраненияОтмененныхВходящих КАК СрокХраненияОтмененныхВходящих,
	|	кфкПараметрыОчисткиХранилища.СрокХраненияОтмененныхИсходящих КАК СрокХраненияОтмененныхИсходящих,
	|	кфкПараметрыОчисткиХранилища.СрокХраненияОтправленных КАК СрокХраненияОтправленных,
	|	кфкПараметрыОчисткиХранилища.СрокХраненияОшибкиОбработкиВходящих КАК СрокХраненияОшибкиОбработкиВходящих,
	|	кфкПараметрыОчисткиХранилища.СрокХраненияОшибкиОбработкиИсходящих КАК СрокХраненияОшибкиОбработкиИсходящих,
	|	кфкПараметрыОчисткиХранилища.СрокХраненияОшибкиОтправки КАК СрокХраненияОшибкиОтправки
	|ИЗ
	|	РегистрСведений.кфкПараметрыОчисткиХранилища КАК кфкПараметрыОчисткиХранилища";
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Результат, Выборка);
		
	ИначеЕсли кфкОбщегоНазначенияСлужебный.ЭтоПолноправныйПользователь() Тогда
		ОбновитьПараметры(Результат);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Процедура ОбновитьПараметры(НовыеПараметры) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	Набор = СоздатьНаборЗаписей();
	ЗаполнитьЗначенияСвойств(Набор.Добавить(), НовыеПараметры);
	Набор.ОбменДанными.Загрузка = Истина;
	Набор.Записать();
		
КонецПроцедуры

#КонецОбласти

#КонецЕсли
