// @strict-types

#Область ОписаниеПеременных

&НаКлиенте
Перем РедакторJSON; // ВнешнийОбъект

#КонецОбласти

#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Не ЗначениеЗаполнено(Параметры.Ключ) Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
		
	ТолькоПросмотр = Истина;
	Элементы.ФормаОбработатьСообщение.Доступность = кфкОбщегоНазначенияСлужебный.ЭтоПолноправныйПользователь();
	
	Элементы.ДлОбработкиМС.ФорматРедактирования = ?(ЗначениеЗаполнено(Запись.ДатаОбработки), "ЧН='<1';", "ЧН=;");
	
	ВерсияРедактораJSON = кфкИнтеграцияСлужебныйПовтИсп.ВерсияРедактораJSON();
	
КонецПроцедуры

&НаСервере
Процедура ПриЧтенииНаСервере(ТекущийОбъект)
	
	// ТелоСообщения
	ТелоСообщения = кфкОбщегоНазначенияСлужебный.ЗначениеИзХранилища(ТекущийОбъект.ТелоСообщения); // Строка
	АдресТелаСообщения = ПоместитьВоВременноеХранилище(ТелоСообщения, УникальныйИдентификатор);
	
	// Заголовки
	Заголовки.Очистить();
	ЗаголовкиИБ = кфкОбщегоНазначенияСлужебный.ЗначениеИзХранилища(ТекущийОбъект.Заголовки); // Неопределено, Соответствие Из Строка
	Если ЗаголовкиИБ <> Неопределено Тогда
		Для Каждого КлючЗначение Из ЗаголовкиИБ Цикл
			ЗаполнитьЗначенияСвойств(Заголовки.Добавить(), КлючЗначение);
		КонецЦикла;
	КонецЕсли;
	Элементы.СтраницаЗаголовки.Доступность = Заголовки.Количество() > 0;
	
	// ТекстЖурнала
	Элементы.СтраницаТекстЖурнала.Доступность = Не ПустаяСтрока(ТекущийОбъект.ТекстЖурнала);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	кфкИнтеграцияСлужебныйКлиент.ИнициализироватьРедакторJSON(ЭтотОбъект);
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

&НаКлиенте
Процедура СтраницаРедактораJSONДокументСформирован(Элемент)
	
	Если РедакторJSON = Неопределено Тогда
		//@skip-check property-return-type
		//@skip-check dynamic-access-method-not-found
		РедакторJSON = Элемент.Документ.defaultView.Init(); // ВнешнийОбъект
		Если РедакторJSON = Неопределено Тогда // Ошибка инициализации
			Возврат;
		КонецЕсли;
	КонецЕсли;
	
	//@skip-check property-return-type
	РедакторJSON.menu.style.backgroundColor = "#d0d0d0";
	//@skip-check dynamic-access-method-not-found
	РедакторJSON.focus();
	
	ТелоСообщения = ПолучитьИзВременногоХранилища(АдресТелаСообщения); // Строка
	//@skip-check dynamic-access-method-not-found
	РедакторJSON.setText(ТелоСообщения);
	
	//@skip-check dynamic-access-method-not-found
	РедакторJSON.setMode("tree");
	
КонецПроцедуры

&НаКлиенте
Процедура РедакторJSONРежимТекстаПриИзменении(Элемент)
	
	Если РедакторJSON = Неопределено Тогда // Редактор не инициализирован
		Возврат;
	КонецЕсли;
	
	//@skip-check dynamic-access-method-not-found
	РедакторJSON.setMode(?(РедакторJSONРежимТекста, "code", "tree"));
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ОбработатьСообщение(Команда)
	
	ОчиститьСообщения();
	
	Если Не ОбработкаДоступна() Тогда
		кфкИнтеграцияСлужебныйКлиент.СообщениеНедоступностиРучнойОбработки();
		Возврат;
	КонецЕсли;
	
	ОбработатьСообщениеНаСервере();
	
	кфкИнтеграцияСлужебныйКлиент.ИнициализироватьРедакторJSON(ЭтотОбъект);
	
	ОповеститьОбИзменении(Запись.ИсходныйКлючЗаписи);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервереБезКонтекста
Функция ОбработкаДоступна()
	Возврат (ПолучитьФункциональнуюОпцию("кфкБлокировкаИнтеграции")
				Или Не кфкФоновыеОперацииСлужебный.РегламентноеЗадание().Использование)
			И кфкФоновыеОперацииСлужебный.ПолучитьПотоки(СостояниеФоновогоЗадания.Активно).Количество() = 0;
КонецФункции

&НаСервере
Процедура ОбработатьСообщениеНаСервере()
	
	кфкФоновыеОперацииСлужебный.ДесериализацияСообщения(Запись.ИсходныйКлючЗаписи);
	
	Прочитать();
	
КонецПроцедуры

#КонецОбласти
