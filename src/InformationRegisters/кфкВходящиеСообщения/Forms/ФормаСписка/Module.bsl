&НаСервереБезКонтекста
Функция КоличествоПоОписаниюЗапроса(ОписаниеЗапроса)
	
	Схема = Новый СхемаЗапроса;
	Схема.УстановитьТекстЗапроса(ОписаниеЗапроса.Текст);
	ЗапросВыборки = Схема.ПакетЗапросов[0].Операторы[0];
	ЗапросВыборки.ВыбираемыеПоля.Очистить();
	ЗапросВыборки.ВыбираемыеПоля.Добавить("Количество(*)");
	
	Запрос = Новый Запрос;
	Запрос.Текст = Схема.ПолучитьТекстЗапроса();
	
	Для Каждого Параметр Из ОписаниеЗапроса.Параметры Цикл
		Запрос.УстановитьПараметр(Параметр.Ключ, Параметр.Значение);
	КонецЦикла;
	Выборка = Запрос.Выполнить().Выбрать();
	Если Не Выборка.Следующий() Тогда
		ВызватьИсключение НСтр("ru = 'Не удалось получить количество записей'");
	КонецЕсли;
	
	Возврат Выборка[0]; // Число
	
КонецФункции

&НаСервере
Процедура ОбработатьСообщениеНаСервере(Сообщение)
	
	кфкФоновыеОперацииСлужебный.ДесериализацияСообщения(Сообщение);
	
	Элементы.Список.Обновить();
	
КонецПроцедуры

&НаСервере
Функция СформироватьОписаниеЗапроса()
	
	Схема = Элементы.Список.ПолучитьИсполняемуюСхемуКомпоновкиДанных();
	НастройкиКД = Элементы.Список.ПолучитьИсполняемыеНастройкиКомпоновкиДанных();
	
	НастройкиКД.Структура.Очистить();
	ГруппировкаКД = НастройкиКД.Структура.Добавить(Тип("ГруппировкаКомпоновкиДанных"));
	Для Каждого Измерение Из Метаданные.РегистрыСведений.кфкВходящиеСообщения.Измерения Цикл
		Поле = ГруппировкаКД.Выбор.Элементы.Добавить(Тип("ВыбранноеПолеКомпоновкиДанных"));
		Поле.Поле = Новый ПолеКомпоновкиДанных(Измерение.Имя);
	КонецЦикла;
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКД = КомпоновщикМакета.Выполнить(Схема, НастройкиКД);
	
	ПараметрыЗапроса = Новый Структура;
	Для Каждого Параметр Из МакетКД.ЗначенияПараметров Цикл
		ПараметрыЗапроса.Вставить(Параметр.Имя, Параметр.Значение);
	КонецЦикла;
	
	Запрос = Новый Структура;
	Запрос.Вставить("Текст", МакетКД.НаборыДанных[0].Запрос);
	Запрос.Вставить("Параметры", ПараметрыЗапроса);
	
	Возврат Запрос;
	
КонецФункции

#КонецОбласти