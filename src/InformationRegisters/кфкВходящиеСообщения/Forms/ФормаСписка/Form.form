        <expression>ВЫБОР КОГДА МеткаИзмененияМС > 0 ТОГДА ДобавитьКДате(ДАТАВРЕМЯ(1, 1, 1), &quot;СЕКУНДА&quot;,  МеткаИзмененияМС / 1000 + СмещениеСтандартногоВремени(ЧасовойПоясСеанса())) ИНАЧЕ ДАТАВРЕМЯ(1, 1, 1) КОНЕЦ</expression>
