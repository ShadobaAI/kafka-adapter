// Отключает регистрацию по объекту.
// 
// Параметры:
//  Источник - СправочникОбъект, ДокументОбъект, ПланВидовХарактеристикОбъект, ПланВидовРасчетаОбъект, ПланСчетовОбъект, БизнесПроцессОбъект, ЗадачаОбъект, ПланОбменаОбъект - Объект, подлежащий выгрузке;
//			 - РегистрСведенийНаборЗаписей, РегистрНакопленияНаборЗаписей, РегистрБухгалтерииНаборЗаписей, РегистрРасчетаНаборЗаписей - Набор записей регистра, подлежащий выгрузке;
Процедура Отключить(Источник) Экспорт
	
	Источник.ДополнительныеСвойства.Вставить("кфкПропуститьРегистрацию", Истина);
	
КонецПроцедуры

// Помещает данные в очередь исходящих сообщений.
// 
// Параметры:
//  Источник - ЛюбаяСсылка - Ссылка на объект, подлежащий выгрузке;
//  		 - СправочникОбъект, ДокументОбъект, ПланВидовХарактеристикОбъект, ПланВидовРасчетаОбъект, ПланСчетовОбъект, БизнесПроцессОбъект, ЗадачаОбъект, ПланОбменаОбъект - Объект, подлежащий выгрузке;
//			 - РегистрСведенийНаборЗаписей, РегистрНакопленияНаборЗаписей, РегистрБухгалтерииНаборЗаписей, РегистрРасчетаНаборЗаписей - Набор записей регистра, подлежащий выгрузке;
//			 - Структура, Соответствие Из Произвольный - произвольное сообщение
//			 - Структура - Описание сообщения, см. ПараметрыСообщения(): 
//			 	* Данные - Строка, ДвоичныеДанные, Структура - Тело сообщения;
//				* Ключ - Строка - Уникальный идентификатор сообщения;
//			 	* Заголовки - Соответствие Из КлючИЗначение - Заголовки сообщения:
//			 		** Ключ - Строка - Имя заголовка;
//			 		** Значение - Строка - Значение заголовка;
//			 - Массив Из ЛюбаяСсылка, СправочникОбъект, ДокументОбъект, Структура - Список объектов или сообщения, подлежащих выгрузке;
//	ТипОбъект - Строка - Тип объект, подлежащий выгрузке;
//	Продюсеры - Неопределено, СправочникСсылка.кфкПродюсеры - Ссылка на продюсер
Процедура ПоместитьВОчередьИсходящих(Источник, ТипОбъект = "", Продюсеры = Неопределено) Экспорт
	
	Если Не ПолучитьФункциональнуюОпцию("кфкИспользоватьИнтеграцию") Тогда
		Возврат;
	КонецЕсли;
		
	ПакетныйРежимЗаписи = ТипЗнч(Источник) = Тип("Массив");
	ПараметрыРегистрации = кфкОбработкаСобытийСлужебный.ПараметрыРегистрации(Продюсеры, ПакетныйРежимЗаписи);
	СобытиеРегистрации = Перечисления.кфкСобытияРегистрации.Программно;
	
	Если ПакетныйРежимЗаписи Тогда
		
		Счетчик = 0;
		МаксРазмерПорции = кфкОбработкаСобытийСлужебный.МаксРазмерПорцииРегистрации();
		
		Для Каждого Элемент Из Источник Цикл
			Счетчик = Счетчик + 1;
			
			кфкОбработкаСобытийСлужебный.ПоместитьВОчередьИсходящих(Элемент, СобытиеРегистрации, ТипОбъект, Ложь, ПараметрыРегистрации);
			
			Если Счетчик >= МаксРазмерПорции Тогда // порционная запись
				Счетчик = 0;
				кфкОбработкаСобытийСлужебный.ЗавершитьРегистрацию(ПараметрыРегистрации, Истина);
			КонецЕсли;
			
		КонецЦикла;
		
		кфкОбработкаСобытийСлужебный.ЗавершитьРегистрацию(ПараметрыРегистрации);
		
	Иначе
		кфкОбработкаСобытийСлужебный.ПоместитьВОчередьИсходящих(Источник, СобытиеРегистрации, ТипОбъект, Ложь, ПараметрыРегистрации);
		
	КонецЕсли;
	
КонецПроцедуры

// Возвращает уникальный ключ объекта, который используется в исходящих сообщениях для идентификации объекта.
// 
// Параметры:
//	Данные - ЛюбаяСсылка, СправочникОбъект, ДокументОбъект, РегистрСведенийКлючЗаписи, РегистрНакопленияКлючЗаписи - Данные для регистрации.
// 
// Возвращаемое значение:
//	Неопределено, Строка - Ключ объекта
//
Функция КлючОбъекта(Данные) Экспорт
	
	Возврат кфкОбработкаСобытийСлужебный.КлючОбъекта(Данные, Истина);
	
КонецФункции

// Возвращает ключи записей исходящих сообщений для данных.
// 
// Параметры:
//  Данные - ЛюбаяСсылка, СправочникОбъект, ДокументОбъект, РегистрСведенийКлючЗаписи - Данные для регистрации.
// 
// Возвращаемое значение:
//  Неопределено, Массив Из Строка - Ключи записей исходящих сообщений
Функция КлючЗаписиИсходящихСообщений(Данные) Экспорт
	
	Возврат кфкОбработкаСобытийСлужебный.КлючЗаписиИсходящихСообщений(Данные);
	
КонецФункции

#Область СобытияРегистрации

// Это регистрация при записи.
// 
// Параметры:
//	Свойства - Структура - Свойства сообщения:
//	 * СобытиеРегистрации - ПеречислениеСсылка.кфкСобытияРегистрации - Событие регистрации
// 
// Возвращаемое значение:
//  Булево - Это регистрация при записи
Функция ЭтоРегистрацияПриЗаписи(Свойства) Экспорт
	
	Событие = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(Свойства, "СобытиеРегистрации");
	Если Событие = Неопределено Тогда
		ВызватьИсключение НСтр("ru = 'Не указано событие регистрации!'");
	КонецЕсли;
	
	Возврат Событие = Перечисления.кфкСобытияРегистрации.ПриЗаписи;
	
КонецФункции

