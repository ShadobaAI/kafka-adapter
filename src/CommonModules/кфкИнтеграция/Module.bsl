#Область Конструкторы

// Конструктор описания сообщения.
// 
// Параметры:
//	Данные - Строка, ДвоичныеДанные, Структура, Массив Из Структура  - Тело сообщения
//	Ключ - Строка - Ключ сообщения
//  
// Возвращаемое значение:
//	Структура - Параметры сообщения:
//	 * Данные - Строка, ДвоичныеДанные, Структура, Массив Из Структура - Тело сообщения
//	 * Ключ - Строка - Уникальный идентификатор сообщения
//	 * Заголовки - Соответствие Из КлючИЗначение - Заголовки сообщения:
//	  ** Ключ - Строка - Имя заголовка
//	  ** Значение - Строка - Значение заголовка
//
Функция ПараметрыСообщения(Данные = "", Ключ = "") Экспорт
	
	Результат = Новый Структура;
	
	// Служебный ключ, признак конструктора сообщения, см. кфкОбработкаСобытийСлужебный.ПоместитьВОчередьИсходящих
	Результат.Вставить(кфкОбработкаСобытийСлужебный.КлючКонструктораСообщения(), Истина);
	
	Результат.Вставить("Данные", Данные);
	Результат.Вставить("Ключ", Ключ);
	Результат.Вставить("Заголовки", Новый Соответствие);
	
	//@skip-check constructor-function-return-section
	Возврат Результат;
	
КонецФункции

// Новый результат интеграции.
// 
// Возвращаемое значение:
//  Структура - Новый результат интеграции:
// * Успешно - Булево - Успешная операция
// * ТекстОшибки - Строка - Текст ошибки операции
Функция РезультатИнтеграции() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Успешно", Ложь);
	Результат.Вставить("ТекстОшибки", "");
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#КонецОбласти
