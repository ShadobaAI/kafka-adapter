#Область ВнешнееЛогирование

// Отправляет логи в сервис по указанному адресу.
//
// Параметры:
//	ПараметрыЛогирования см. ПараметрыЛогирования
//	События - Массив Из Произвольный - события для отправки
//	Сессия - Неопределено, HTTPСоединение - Сессия HTTP-соединения
Процедура ОтправитьЛоги(ПараметрыЛогирования, События, Сессия)
	
	Адрес = ПараметрыЛогирования.АдресСервисаЧасти; // см. ОбщегоНазначенияКлиентСервер.СтруктураURI
	СобытияJSON = кфкОбщегоНазначенияСлужебный.ЗначениеВJSON(События);
	
	Если Сессия = Неопределено Тогда
		ЗащищенноеСоединение = ?(НРег(Адрес.Схема) = "http", Неопределено, Новый ЗащищенноеСоединениеOpenSSL);
		Сессия = Новый HTTPСоединение(Адрес.Хост, Адрес.Порт, , , , , ЗащищенноеСоединение);
	КонецЕсли;
	
	Запрос = Новый HTTPЗапрос(Адрес.ПутьНаСервере);
	Запрос.Заголовки.Вставить("Content-Type", "application/json");
	Запрос.Заголовки.Вставить("Content-encoding", "gzip");
	
	Запрос.УстановитьТелоИзСтроки(СобытияJSON);
	СобытияДД = Запрос.ПолучитьТелоКакДвоичныеДанные();
	СобытияGZip = кфкОбщегоНазначенияСлужебный.ЗаписатьGZip(СобытияДД);
	Запрос.УстановитьТелоИзДвоичныхДанных(СобытияGZip);
	
	//@skip-check bsl-legacy-check-dynamic-feature-access
	Ответ = Сессия.ВызватьHTTPМетод("POST", Запрос);
	Если Не Ответ.КодСостояния = 200 Тогда
		ВызватьИсключение Ответ.КодСостояния;
	КонецЕсли;
	
КонецПроцедуры

#Область НастройкиВнешнегоЛогирования

// Возвращает параметры логирования
// 
// Возвращаемое значение:
//	Структура - Параметры логирования:
//		* Использовать - Булево - Использовать внешнее логирование
//		* АдресСервиса - Строка - Адрес сервиса
//		* АдресСервисаЧасти см. ОбщегоНазначенияКлиентСервер.СтруктураURI
//		* Префикс - Строка - Префикс
//		* ВыгружатьИсходныеДанныеИсходящих - Булево - Признак выгрузки исходных данных исходящих сообщений
//		* ВыгружатьЗаголовкиСообщенияИсходящих - Булево - Признак выгрузки заголовков исходящих сообщений
//		* ВыгружатьТелоСообщенияИсходящих - Булево - Признак выгрузки тела исходящих сообщений
//		* ВыгружатьЗаголовкиСообщенияВходящих - Булево - Признак выгрузки заголовков входящих сообщений
//		* ВыгружатьТелоСообщенияВходящие - Булево - Признак выгрузки тела входящих сообщений
//
Функция ПараметрыЛогирования()
	
	Результат = РегистрыСведений.кфкПараметрыЛогирования.ПолучитьПараметры();
	Результат.Использовать = Результат.Использовать И Не ПустаяСтрока(Результат.АдресСервиса);
	Результат.Вставить("АдресСервисаЧасти", ОбщегоНазначенияКлиентСервер.СтруктураURI(Результат.АдресСервиса));
	
	Возврат Результат;
	
КонецФункции

// Возвращает представления продюсеров и консьюмеров
// 
// Возвращаемое значение:
//	Соответствие Из КлючИЗначение - Представления:
//		* Ключ - СправочникСсылка.кфкПродюсеры, СправочникСсылка.кфкКонсьюмеры - Продюсер или консьюмер
//		* Значение - Строка - Представление
//
Функция ПредставленияПродюсеровИКонсьюмеров()
	
	Результат = Новый Соответствие;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ Справочник.кфкПродюсеры.Ссылка, Наименование ГДЕ ЭтоГруппа = ЛОЖЬ
		|ОБЪЕДИНИТЬ ВСЕ ВЫБРАТЬ Справочник.кфкКонсьюмеры.Ссылка, Наименование ГДЕ ЭтоГруппа = ЛОЖЬ";
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		
		//@skip-check property-return-type
		Результат.Вставить(Выборка.Ссылка, Выборка.Наименование);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращает ограничение указателя перед выгрузкой логов.
// 	Перед выгрузкой логов ждем 1 минуту, чтобы все операции над сообщениями завершились.
// 
// Возвращаемое значение:
//	Число - Ограничение указателя
Функция ОграничениеУказательПередВыгрузкойЛогов()
	Возврат ТекущаяУниверсальнаяДатаВМиллисекундах() - 60000; // 1 минута
КонецФункции

#КонецОбласти

#Область ЛогированияИсходящих

// Выборка исходящих событий.
// 
// Параметры:
//  Количество - Число - Количество записей
//  НачальнаяПозиция - Число - НачальнаяПозиция
// 
// Возвращаемое значение:
//  ВыборкаИзРезультатаЗапроса - Выборка исходящих событий:
//	* КлючЗаписи - Строка - Владелец сообщения
//	* ДатаРегистрацииМС - Число - Дата регистрации (мс)
//	* Статус - ПеречислениеСсылка.кфкСтатусыСообщений - Статус
//	* ИсходныеДанные - ХранилищеЗначения - Исходные данные
//	* ЭтоУдаление - Булево - Это удаление
//	* КлючСообщения - Строка - Ключ сообщения
//	* Заголовки - ХранилищеЗначения - Заголовки
//	* ТелоСообщения - ХранилищеЗначения - Тело сообщения
//	* Продюсер - СправочникСсылка.кфкПродюсеры - Продюсер
//	* ТипОбъект - Строка - Имя объекта метаданных
//	* ТипИсходныхДанных - Строка - Тип исходных данных
//	* КлючОбъекта - Строка - Ключ записи
//	* СобытиеРегистрации - ПеречислениеСсылка.кфкСобытияРегистрации - Событие регистрации
//	* ДатаРегистрации - Дата - Дата регистрация
//	* ДатаОбработки - Дата - Дата обработки
//	* ДатаВыгрузки - Дата - Дата выгрузки
//	* ДлОбработкиМС - Число - Длительность обработки в миллисекундах
//	* ТекстЖурнала - Строка - Текст журнала
//	* КоличествоОбработок - Число - Количество обработок
//	* КоличествоВыгрузок - Число - Количество выгрузок
//	* МеткаИзмененияМС - Число - Метка изменения (мс)
Функция ВыборкаЛоговИсходящихСообщений(Количество, НачальнаяПозиция)
	
	ТекстЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1000
	|	Таблица.КлючЗаписи КАК КлючЗаписи,
	|	Таблица.ДатаРегистрацииМС КАК ДатаРегистрацииМС,
	|	Таблица.Статус КАК Статус,
	|	Таблица.ИсходныеДанные КАК ИсходныеДанные,
	|	Таблица.ЭтоУдаление КАК ЭтоУдаление,
	|	Таблица.КлючСообщения КАК КлючСообщения,
	|	Таблица.Заголовки КАК Заголовки,
	|	Таблица.ТелоСообщения КАК ТелоСообщения,
	|	Таблица.Продюсер КАК Продюсер,
	|	Таблица.ТипОбъект КАК ТипОбъект,
	|	Таблица.ТипИсходныхДанных КАК ТипИсходныхДанных,
	|	Таблица.КлючОбъекта КАК КлючОбъекта,
	|	Таблица.СобытиеРегистрации КАК СобытиеРегистрации,
	|	Таблица.ДатаРегистрации КАК ДатаРегистрации,
	|	Таблица.ДатаОбработки КАК ДатаОбработки,
	|	Таблица.ДатаВыгрузки КАК ДатаВыгрузки,
	|	Таблица.ДлОбработкиМС КАК ДлОбработкиМС,
	|	Таблица.ТекстЖурнала КАК ТекстЖурнала,
	|	Таблица.КоличествоОбработок КАК КоличествоОбработок,
	|	Таблица.КоличествоВыгрузок КАК КоличествоВыгрузок,
	|	Таблица.МеткаИзмененияМС КАК МеткаИзмененияМС
	|ИЗ
	|	РегистрСведений.кфкИсходящиеСообщения КАК Таблица
	|ГДЕ
	|	Таблица.МеткаИзмененияМС > &НачальнаяПозиция
	|	И Таблица.МеткаИзмененияМС < &ОграничениеУказатель
	|
	|УПОРЯДОЧИТЬ ПО
	|	Таблица.МеткаИзмененияМС";
	
	Запрос = Новый Запрос;
	Запрос.Текст = СтрЗаменить(ТекстЗапроса, "1000", XMLСтрока(Количество));
	Запрос.УстановитьПараметр("НачальнаяПозиция", ?(ЗначениеЗаполнено(НачальнаяПозиция), НачальнаяПозиция, 0));
	Запрос.УстановитьПараметр("ОграничениеУказатель", ОграничениеУказательПередВыгрузкойЛогов());
	
	Возврат Запрос.Выполнить().Выбрать();
	
КонецФункции

Процедура ОбработчикВыгрузкиЛоговИсходящихСообщений(Выборка, Представления, ПараметрыЛогирования, Сессия,
		УказательНачалаВыборки)
	
	События = Новый Массив; // Массив Из Соответствие
	
	Префикс = ПараметрыЛогирования.Префикс; // Строка
	ВыгружатьЗаголовкиСообщения = ПараметрыЛогирования.ВыгружатьЗаголовкиСообщенияИсходящих; // Булево
	ВыгружатьТелоСообщения = ПараметрыЛогирования.ВыгружатьТелоСообщенияИсходящих; // Булево
	ВыгружатьИсходныеДанные = ПараметрыЛогирования.ВыгружатьИсходныеДанныеИсходящих; // Булево
	
	// Собираем события
	Пока Выборка.Следующий() Цикл
		
		ИмяРаздела = ИмяРазделаЛогирования(Префикс, Выборка.Продюсер);
		
		Событие = Новый Соответствие; // Соответствие Из Произвольный
		Событие.Вставить("logger", ИмяРаздела);
		Событие.Вставить("id", КлючСобытияЛогирования(Выборка.КлючЗаписи, Выборка.ДатаРегистрацииМС));
		Событие.Вставить("@timestamp", кфкОбщегоНазначенияСлужебный.ДатаМсВСтроку(Выборка.ДатаРегистрацииМС));
		
		Событие.Вставить("producer_id", XMLСтрока(Выборка.Продюсер));
		Событие.Вставить("producer_name", Представления.Получить(Выборка.Продюсер));
		Событие.Вставить("object_type", Выборка.ТипОбъект);
		Событие.Вставить("source_type", Выборка.ТипИсходныхДанных);
		Событие.Вставить("object_key", Выборка.КлючОбъекта);
		Событие.Вставить("record_key", Выборка.КлючЗаписи);
		Событие.Вставить("trigger", XMLСтрока(Выборка.СобытиеРегистрации));
		Событие.Вставить("status", XMLСтрока(Выборка.Статус));
		Событие.Вставить("message_key", Выборка.КлючСообщения);
		
		ДобавитьДатуВЛог(Событие, Выборка.ДатаРегистрации, "registration_date");
		ДобавитьДатуВЛог(Событие, Выборка.ДатаОбработки, "processing_date");
		ДобавитьДатуВЛог(Событие, Выборка.ДатаВыгрузки, "export_date");
		
		Событие.Вставить("log_text", Выборка.ТекстЖурнала);
		Событие.Вставить("change_mark_ms", кфкОбщегоНазначенияСлужебный.ДатаМсВСтроку(Выборка.МеткаИзмененияМС));
		Событие.Вставить("processing_duration_ms", Выборка.ДлОбработкиМС);
		Событие.Вставить("processing_count", Выборка.КоличествоОбработок);
		Событие.Вставить("export_count", Выборка.КоличествоВыгрузок);
		
		Если ВыгружатьИсходныеДанные Тогда
			ИсходныеДанные = Выборка.ИсходныеДанные.Получить(); // Строка
			Если ТипЗнч(ИсходныеДанные) = Тип("Строка") Тогда
				РегулярноеВыражение = "(\s*xmlns(\:\w+)?=""[^""]+"")|((d3p1|xsi)\:)|((?<=\>)\s+(?=\<))";
				Событие.Вставить("source", СтрЗаменитьПоРегулярномуВыражению(ИсходныеДанные, РегулярноеВыражение, "", Истина, Истина));
				Событие.Вставить("is_delete", Выборка.ЭтоУдаление);
			КонецЕсли;
		КонецЕсли;
		ДобавитьЗаголовкиСообщенияВЛог(Событие, Выборка.Заголовки, ВыгружатьЗаголовкиСообщения);
		ДобавитьТелоСообщенияВЛог(Событие, Выборка.ТелоСообщения, ВыгружатьТелоСообщения);
		
		События.Добавить(Событие);
		
		УказательНачалаВыборки = Выборка.МеткаИзмененияМС;
		
	КонецЦикла;
	
	// Отправка событий
	ОтправитьЛоги(ПараметрыЛогирования, События, Сессия);
	
КонецПроцедуры

#КонецОбласти

#Область ЛогированияВходящих

// Выборка прочитанных событий.
// 
// Параметры:
//  Количество - Число - Количество записей
//  НачальнаяПозиция - Число - НачальнаяПозиция
// 
// Возвращаемое значение:
//  ВыборкаИзРезультатаЗапроса - Выборка прочитанных событий:
//  * КлючЗаписи - Строка - Владелец сообщения
//  * ДатаЗагрузкиМС - Число - Дата загрузки (мс)
//  * Статус - ПеречислениеСсылка.кфкСтатусыСообщений - Статус
//  * Заголовки - ХранилищеЗначения - Заголовки
//  * ТелоСообщения - ХранилищеЗначения - Тело сообщения
//	* Консьюмер - СправочникСсылка.кфкКонсьюмеры - Консьюмер
//	* Топик - Строка - Топик
//	* Раздел - Число - Раздел
//	* Смещение - Число - Смещение
//	* КлючСообщения - Строка - Ключ сообщения
//	* ДатаЗаписи - Дата - Дата записи
//	* ДатаЗагрузки - Дата - Дата загрузки
//	* ДатаОбработки - Дата - Дата обработки
//	* ДлОбработкиМС - Число - Длительность обработки (мс)
//	* ТекстЖурнала - Строка - Текст журнала
//	* КоличествоОбработок - Число - Количество обработок
//	* МеткаИзмененияМС - Число - Метка изменения (мс)
Функция ВыборкаЛоговВходящихСообщений(Количество, НачальнаяПозиция)
	
	ТекстЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1000
	|	Таблица.КлючЗаписи КАК КлючЗаписи,
	|	Таблица.ДатаЗагрузкиМС КАК ДатаЗагрузкиМС,
	|	Таблица.Статус КАК Статус,
	|	Таблица.Заголовки КАК Заголовки,
	|	Таблица.ТелоСообщения КАК ТелоСообщения,
	|	Таблица.Консьюмер КАК Консьюмер,
	|	Таблица.Топик КАК Топик,
	|	Таблица.Раздел КАК Раздел,
	|	Таблица.Смещение КАК Смещение,
	|	Таблица.КлючСообщения КАК КлючСообщения,
	|	Таблица.ДатаЗаписи КАК ДатаЗаписи,
	|	Таблица.ДатаЗагрузки КАК ДатаЗагрузки,
	|	Таблица.ДатаОбработки КАК ДатаОбработки,
	|	Таблица.ДлОбработкиМС КАК ДлОбработкиМС,
	|	Таблица.ТекстЖурнала КАК ТекстЖурнала,
	|	Таблица.КоличествоОбработок КАК КоличествоОбработок,
	|	Таблица.МеткаИзмененияМС КАК МеткаИзмененияМС
	|ИЗ
	|	РегистрСведений.кфкВходящиеСообщения КАК Таблица
	|ГДЕ
	|	Таблица.МеткаИзмененияМС > &НачальнаяПозиция
	|	И Таблица.МеткаИзмененияМС < &ОграничениеУказатель
	|
	|УПОРЯДОЧИТЬ ПО
	|	Таблица.МеткаИзмененияМС";
	
	Запрос = Новый Запрос;
	Запрос.Текст = СтрЗаменить(ТекстЗапроса, "1000", XMLСтрока(Количество));
	Запрос.УстановитьПараметр("НачальнаяПозиция", ?(ЗначениеЗаполнено(НачальнаяПозиция), НачальнаяПозиция, 0));
	Запрос.УстановитьПараметр("ОграничениеУказатель", ОграничениеУказательПередВыгрузкойЛогов());
	
	Возврат Запрос.Выполнить().Выбрать();
	
КонецФункции

Процедура ОбработчикВыгрузкиЛоговВходящихСообщений(Выборка, Представления, ПараметрыЛогирования, Сессия,
		УказательНачалаВыборки)
	
	События = Новый Массив; // Массив Из Соответствие
	
	Префикс = ПараметрыЛогирования.Префикс; // Строка
	ВыгружатьЗаголовкиСообщения = ПараметрыЛогирования.ВыгружатьЗаголовкиСообщенияВходящих; // Булево
	ВыгружатьТелоСообщения = ПараметрыЛогирования.ВыгружатьТелоСообщенияВходящие; // Булево
	
	// Собираем события
	Пока Выборка.Следующий() Цикл
		
		ИмяРаздела = ИмяРазделаЛогирования(Префикс, Выборка.Консьюмер);
		
		Событие = Новый Соответствие; // Соответствие Из Произвольный
		Событие.Вставить("logger", ИмяРаздела);
		Событие.Вставить("id", КлючСобытияЛогирования(Выборка.КлючЗаписи, Выборка.ДатаЗагрузкиМС));
		Событие.Вставить("@timestamp", кфкОбщегоНазначенияСлужебный.ДатаМсВСтроку(Выборка.ДатаЗагрузкиМС));
		
		Событие.Вставить("consumer_id", XMLСтрока(Выборка.Консьюмер));
		Событие.Вставить("consumer_name", Представления.Получить(Выборка.Консьюмер));
		Событие.Вставить("topic", Выборка.Топик);
		Событие.Вставить("message_key", Выборка.КлючСообщения);
		Событие.Вставить("record_key", Выборка.КлючЗаписи);
		Событие.Вставить("load_date_ms", Выборка.ДатаЗагрузкиМС);
		Событие.Вставить("partition", Выборка.Раздел);
		Событие.Вставить("offset", Выборка.Смещение);
		Событие.Вставить("status", XMLСтрока(Выборка.Статус));
		
		ДобавитьДатуВЛог(Событие, Выборка.ДатаЗаписи, "write_date");
		ДобавитьДатуВЛог(Событие, Выборка.ДатаЗагрузки, "load_date");
		ДобавитьДатуВЛог(Событие, Выборка.ДатаОбработки, "processing_date");
		
		ДобавитьЗаголовкиСообщенияВЛог(Событие, Выборка.Заголовки, ВыгружатьЗаголовкиСообщения);
		ДобавитьТелоСообщенияВЛог(Событие, Выборка.ТелоСообщения, ВыгружатьТелоСообщения);
		
		Событие.Вставить("log_text", Выборка.ТекстЖурнала);
		Событие.Вставить("change_mark_ms", кфкОбщегоНазначенияСлужебный.ДатаМсВСтроку(Выборка.МеткаИзмененияМС));
		Событие.Вставить("processing_duration_ms", Выборка.ДлОбработкиМС);
		Событие.Вставить("processing_count", Выборка.КоличествоОбработок);
	
		События.Добавить(Событие);
		
		УказательНачалаВыборки = Выборка.МеткаИзмененияМС;
		
	КонецЦикла;
	
	// Отправка событий
	ОтправитьЛоги(ПараметрыЛогирования, События, Сессия);
	
КонецПроцедуры

#КонецОбласти

#Область СериализацияЛога

// Имя раздела логирования.
// 
// Параметры:
//	Префикс - Строка - Префикс логгера
//	Настройка - СправочникСсылка.кфкПродюсеры, СправочникСсылка.кфкКонсьюмеры - Настройка
// 
// Возвращаемое значение:
//	Строка - Имя раздела логирования
Функция ИмяРазделаЛогирования(Префикс, Настройка)
	
	Возврат
		?(ПустаяСтрока(Префикс), "", Префикс + "-")
		+ "kfk-"
		+ ?(ТипЗнч(Настройка) = Тип("СправочникСсылка.кфкПродюсеры"), "producer", "consumer") + "-"
		+ СтрЗаменить(XMLСтрока(Настройка), "-", "");
	
КонецФункции

// Ключ события логирования.
// 
// Параметры:
//  КлючЗаписи - Строка - Ключ записи
//  Период - Число - Период события
// 
// Возвращаемое значение:
//  Строка - Ключ события логирования
Функция КлючСобытияЛогирования(КлючЗаписи, Период)
	Возврат КлючЗаписи + "_" + XMLСтрока(Период);
КонецФункции

// Добавить дату в лог.
// 
// Параметры:
//  Событие - Соответствие Из Произвольный - Событие
//  Значение - Дата - Значение
//  Ключ - Строка - Ключ
Процедура ДобавитьДатуВЛог(Событие, Значение, Ключ)
	
	Если Значение = Дата(1, 1, 1) Тогда
		Возврат;
	КонецЕсли;
	
	Событие.Вставить(Ключ, кфкОбщегоНазначенияСлужебный.ДатаВСтроку(Значение, ВариантЗаписиДатыJSON.ЛокальнаяДатаСоСмещением));
	
КонецПроцедуры

Процедура ДобавитьЗаголовкиСообщенияВЛог(Событие, Значение, УсловиеДобавление)
	
	Если Не УсловиеДобавление Тогда
		Возврат;
	КонецЕсли;
	
	Заголовки = кфкОбщегоНазначенияСлужебный.ЗначениеИзХранилища(Значение); // Неопределено, Соответствие Из Строка
	Если Заголовки = Неопределено Или Заголовки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Результат = "";
	//@skip-check property-return-type
	Для Каждого Элемент Из Заголовки Цикл
		ТЗначение = ТипЗнч(Элемент.Значение); // см. XMLСтрока
		Если Значение = Неопределено Или Значение = Null
			Или ТЗначение = Тип("Булево") Или ТЗначение = Тип("Число") Или ТЗначение = Тип("Строка") Или ТЗначение = Тип("Дата")
			Или ТЗначение = Тип("УникальныйИдентификатор") Или ТЗначение = Тип("ДвоичныеДанные") Или ТЗначение = Тип("ХранилищеЗначения")
			Или ТЗначение = Тип("ВидСчета") Или ТЗначение = Тип("ВидДвиженияБухгалтерии") Или ТЗначение = Тип("ВидДвиженияНакопления")
			Или ТЗначение = Тип("ДопустимыйЗнак") Или ТЗначение = Тип("ДопустимаяДлина") Или ТЗначение = Тип("ЧастиДаты") Тогда
			
			Результат = Результат + ?(ПустаяСтрока(Результат), "", ",")
				+ XMLСтрока(Элемент.Ключ) + "=" + XMLСтрока(Элемент.Значение);
			
		КонецЕсли;
	КонецЦикла;
	
	Если ПустаяСтрока(Результат) Тогда
		Возврат;
	КонецЕсли;
	
	Событие.Вставить("msg_headers", Результат);
	
КонецПроцедуры

Процедура ДобавитьТелоСообщенияВЛог(Событие, Значение, УсловиеДобавление)
	
	Если Не УсловиеДобавление Тогда
		Возврат;
	КонецЕсли;
	
	Результат = кфкОбщегоНазначенияСлужебный.ЗначениеИзХранилища(Значение); // Строка
	Если ПустаяСтрока(Результат) Тогда
		Возврат;
	КонецЕсли;
	
	Событие.Вставить("msg_body", Результат);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область КонтрольИнтеграции

// Оповестить об ошибки.
// 
// Параметры:
//  ПараметрыКонтроля - Структура - Параметры контроля:
//   * ИдентификаторЧатаТГ - Строка - Идентификатор чата ТГ
//   * ТокенБотаТГ - Строка - Токен бота ТГ
//  ТекстСообщения - Строка - Текст сообщения в формате MD
Процедура ОповеститьОбОшибки(ПараметрыКонтроля, ТекстСообщения)
	
	Хост = "api.telegram.org";
	АдресЗапроса = СтрШаблон("/bot%1/sendMessage", ПараметрыКонтроля.ТокенБотаТГ);
	
	Тело = Новый Структура;
	Тело.Вставить("chat_id", ПараметрыКонтроля.ИдентификаторЧатаТГ);
	Тело.Вставить("text", ТекстСообщения);
	Тело.Вставить("parse_mode", "Markdown");
	СтрокаJSON = кфкОбщегоНазначенияСлужебный.ЗначениеВJSON(Тело); // Строка
	
	Соединение = Новый HTTPСоединение(Хост, , , , , , Новый ЗащищенноеСоединениеOpenSSL());
	
	Запрос = Новый HTTPЗапрос(АдресЗапроса);
	Запрос.Заголовки.Вставить("Content-Type", "application/json;charset=utf-8");
	Запрос.УстановитьТелоИзСтроки(СтрокаJSON);
	
	//@skip-check bsl-legacy-check-dynamic-feature-access
	Ответ = Соединение.ВызватьHTTPМетод("POST", Запрос);
	
	Если Не Ответ.КодСостояния = 200 Тогда
		ВызватьИсключение Ответ.ПолучитьТелоКакСтроку();
	КонецЕсли;
	
КонецПроцедуры

// Оповестить об ошибки чтения.
// 
// Параметры:
//  Консьюмер - СправочникСсылка.кфкКонсьюмеры - Консьюмер
//  ТекстОшибки - Строка - Текст ошибки
Процедура ОповеститьОбОшибкиЧтения(Консьюмер, ТекстОшибки)
	
	Если Не ПолучитьФункциональнуюОпцию("кфкИспользоватьКонтрольИнтеграции") Тогда
		Возврат;
	КонецЕсли;
	
	ПараметрыКонтроля = РегистрыСведений.кфкПараметрыКонтроляИнтеграции.ПолучитьПараметры();
	Если ПустаяСтрока(ПараметрыКонтроля.ИдентификаторЧатаТГ) Или ПустаяСтрока(ПараметрыКонтроля.ТокенБотаТГ) Тогда
		Возврат;
	КонецЕсли;
	
	ШаблонСообщения = НСтр("ru = '*📛 Ошибка чтения входящего потока*  
		 |🚨 **Критическая ошибка при чтении сообщений из очереди**  
		 |📍 **Компонент:** `%1`  
		 |💬 **Сообщение об ошибке:**  
		 |`%2`'");
	
	ТекстСообщения = СтрШаблон(ШаблонСообщения, Консьюмер, ТекстОшибки);
	ОповеститьОбОшибки(ПараметрыКонтроля, ТекстСообщения);
	
КонецПроцедуры

Функция КонтроляИнтеграцииПоказатели(Параметры)
	
	Результат = Новый Структура;
	
	Результат.Вставить("НарушенSLAИсходящих", 0);
	Результат.Вставить("НарушенSLAВходящих", 0);
	
	Результат.Вставить("ОшибкиИсходящих", 0);
	Результат.Вставить("ОшибкиВходящих", 0);
	
	Диапазон = ВыборкаКонтроляИнтеграцииДиапазонИзменений();
	РезультатЗапроса = РезультатЗапросаКонтроляИнтеграцииПоказатели(Параметры, Диапазон);
	
//	Обнаружены ошибки
	Выборка = РезультатЗапроса[0].Выбрать();
	Если Выборка.Следующий() Тогда
		Значение = Выборка[0]; // Число
		Результат.ОшибкиИсходящих = Значение;
	КонецЕсли;
	Выборка = РезультатЗапроса[1].Выбрать();
	Если Выборка.Следующий() Тогда
		Значение = Выборка[0]; // Число
		Результат.ОшибкиВходящих = Значение;
	КонецЕсли;
	
	// Нарушен SLA
	Выборка = РезультатЗапроса[2].Выбрать();
	Если Выборка.Следующий() Тогда
		Значение = Выборка[0]; // Число
		Результат.НарушенSLAИсходящих = Значение;
	КонецЕсли;
	Выборка = РезультатЗапроса[3].Выбрать();
	Если Выборка.Следующий() Тогда
		Значение = Выборка[0]; // Число
		Результат.НарушенSLAВходящих = Значение;
	КонецЕсли;
	
	ОбновитьПозицию(ИДОперации_КонтрольИнтеграцииИсходящих(), Диапазон.ИсхДо);
	ОбновитьПозицию(ИДОперации_КонтрольИнтеграцииВходящих(), Диапазон.ВхДо);
	
	Возврат Результат;
	
КонецФункции

// Выборка контроля интеграции диапазон изменений.
// 
// Возвращаемое значение:
//	Структура - Диапазон изменений:
//	 * ВхОт - Число - ВхОт
//	 * ВхДо - Число - ВхДо
//	 * ИсхОт - Число - ИсхОт
//	 * ИсхДо - Число - ИсхДо
Функция ВыборкаКонтроляИнтеграцииДиапазонИзменений()
	
	Результат = Новый Структура;
	Результат.Вставить("ИсхОт", 0);
	Результат.Вставить("ИсхДо", 0);
	
	Результат.Вставить("ВхОт", 0);
	Результат.Вставить("ВхДо", 0);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	МАКСИМУМ(ПозицииОпераций.ВременнаяМеткаВходящих) КАК ВхОт,
	|	МАКСИМУМ(ПозицииОпераций.ВременнаяМеткаИсходящих) КАК ИсхОт
	|ИЗ
	|	(ВЫБРАТЬ
	|		ПозицииОпераций.ВременнаяМетка КАК ВременнаяМеткаИсходящих,
	|		0 КАК ВременнаяМеткаВходящих
	|	ИЗ
	|		РегистрСведений.кфкПозицииОпераций КАК ПозицииОпераций
	|	ГДЕ
	|		ПозицииОпераций.Идентификатор = &ИдентификаторИсх
	|
	|	ОБЪЕДИНИТЬ
	|
	|	ВЫБРАТЬ
	|		0,
	|		ПозицииОпераций.ВременнаяМетка
	|	ИЗ
	|		РегистрСведений.кфкПозицииОпераций КАК ПозицииОпераций
	|	ГДЕ
	|		ПозицииОпераций.Идентификатор = &ИдентификаторВх) КАК ПозицииОпераций
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(ИсходящиеСообщения.МеткаИзмененияМС) КАК ИсхДо
	|ИЗ
	|	РегистрСведений.кфкИсходящиеСообщения КАК ИсходящиеСообщения
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	МАКСИМУМ(ВходящиеСообщения.МеткаИзмененияМС) КАК ВхДо
	|ИЗ
	|	РегистрСведений.кфкВходящиеСообщения КАК ВходящиеСообщения";
	Запрос.УстановитьПараметр("ИдентификаторИсх", ИДОперации_КонтрольИнтеграцииИсходящих());
	Запрос.УстановитьПараметр("ИдентификаторВх", ИДОперации_КонтрольИнтеграцииВходящих());
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	
	Выборка = РезультатЗапроса[0].Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Результат, Выборка, "ВхОт,ИсхОт");
	КонецЕсли;
	
	Выборка = РезультатЗапроса[1].Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Результат, Выборка, "ИсхДо");
	КонецЕсли;
	
	Выборка = РезультатЗапроса[2].Выбрать();
	Если Выборка.Следующий() Тогда
		ЗаполнитьЗначенияСвойств(Результат, Выборка, "ВхДо");
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Результат запроса контроля интеграции показатели.
// 
// Параметры:
//  Параметры - Структура - Параметры
//  Диапазон - Структура - Диапазон
// 
// Возвращаемое значение:
//  Массив Из РезультатЗапроса - Результат запроса контроля интеграции показатели
Функция РезультатЗапросаКонтроляИнтеграцииПоказатели(Параметры, Диапазон)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	КОЛИЧЕСТВО(*) КАК Количество
	|ИЗ
	|	РегистрСведений.кфкИсходящиеСообщения КАК ИсходящиеСообщения
	|ГДЕ
	|	ИсходящиеСообщения.МеткаИзмененияМС > &МеткаИзмененияОтИсх
	|	И ИсходящиеСообщения.МеткаИзмененияМС <= &МеткаИзмененияДоИсх
	|	И ИсходящиеСообщения.Статус В (ЗНАЧЕНИЕ(Перечисление.кфкСтатусыСообщений.ОшибкаОбработки),
	|		ЗНАЧЕНИЕ(Перечисление.кфкСтатусыСообщений.ОшибкаВыгрузки))
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	КОЛИЧЕСТВО(*) КАК Количество
	|ИЗ
	|	РегистрСведений.кфкВходящиеСообщения КАК ВходящиеСообщения
	|ГДЕ
	|	ВходящиеСообщения.МеткаИзмененияМС > &МеткаИзмененияОтВх
	|	И ВходящиеСообщения.МеткаИзмененияМС <= &МеткаИзмененияДоВх
	|	И ВходящиеСообщения.Статус = ЗНАЧЕНИЕ(Перечисление.кфкСтатусыСообщений.ОшибкаОбработки)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(Запрос.Количество) КАК Количество
	|ИЗ
	|	(ВЫБРАТЬ
	|		КОЛИЧЕСТВО(*) КАК Количество
	|	ИЗ
	|		РегистрСведений.кфкИсходящиеСообщения КАК ИсходящиеСообщения
	|	ГДЕ
	|		ИсходящиеСообщения.МеткаИзмененияМС > &МеткаИзмененияОтИсх
	|		И ИсходящиеСообщения.МеткаИзмененияМС <= &МеткаИзмененияДоИсх
	|		И ИсходящиеСообщения.ДатаРегистрацииМС < &ВремяSLAИсхМС
	|		И ИсходящиеСообщения.Статус В (ЗНАЧЕНИЕ(Перечисление.кфкСтатусыСообщений.Новое),
	|			ЗНАЧЕНИЕ(Перечисление.кфкСтатусыСообщений.Обработано))
	|
	|	ОБЪЕДИНИТЬ ВСЕ
	|
	|	ВЫБРАТЬ
	|		КОЛИЧЕСТВО(*)
	|	ИЗ
	|		РегистрСведений.кфкИсходящиеСообщения КАК ИсходящиеСообщения
	|	ГДЕ
	|		ИсходящиеСообщения.МеткаИзмененияМС > &МеткаИзмененияОтИсх
	|		И ИсходящиеСообщения.МеткаИзмененияМС <= &МеткаИзмененияДоИсх
	|		И РАЗНОСТЬДАТ(ИсходящиеСообщения.ДатаРегистрации, ИсходящиеСообщения.ДатаВыгрузки, МИНУТА) > &ВремяSLAИсх
	|		И ИсходящиеСообщения.Статус = ЗНАЧЕНИЕ(Перечисление.кфкСтатусыСообщений.Выгружено)) КАК Запрос
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	СУММА(Запрос.Количество) КАК Количество
	|ИЗ
	|	(ВЫБРАТЬ
	|		КОЛИЧЕСТВО(*) КАК Количество
	|	ИЗ
	|		РегистрСведений.кфкВходящиеСообщения КАК ВходящиеСообщения
	|	ГДЕ
	|		ВходящиеСообщения.МеткаИзмененияМС > &МеткаИзмененияОтВх
	|		И ВходящиеСообщения.МеткаИзмененияМС <= &МеткаИзмененияДоВх
	|		И ВходящиеСообщения.ДатаЗагрузкиМС < &ВремяSLAВхМС
	|		И ВходящиеСообщения.Статус = ЗНАЧЕНИЕ(Перечисление.кфкСтатусыСообщений.Новое)
	|
	|	ОБЪЕДИНИТЬ ВСЕ
	|
	|	ВЫБРАТЬ
	|		КОЛИЧЕСТВО(*)
	|	ИЗ
	|		РегистрСведений.кфкВходящиеСообщения КАК ВходящиеСообщения
	|	ГДЕ
	|		ВходящиеСообщения.МеткаИзмененияМС > &МеткаИзмененияОтВх
	|		И ВходящиеСообщения.МеткаИзмененияМС <= &МеткаИзмененияДоИсх
	|		И РАЗНОСТЬДАТ(ВходящиеСообщения.ДатаЗагрузки, ВходящиеСообщения.ДатаОбработки, МИНУТА) > &ВремяSLAВх
	|		И ВходящиеСообщения.Статус = ЗНАЧЕНИЕ(Перечисление.кфкСтатусыСообщений.Обработано)) КАК Запрос";
	
	Запрос.УстановитьПараметр("ВремяSLAВх", Параметры.ВремяSLAВходящих);
	Запрос.УстановитьПараметр("ВремяSLAВхМС", Параметры.ВремяSLAВходящих * 60000);
	Запрос.УстановитьПараметр("ВремяSLAИсх", Параметры.ВремяSLAИсходящих);
	Запрос.УстановитьПараметр("ВремяSLAИсхМС", Параметры.ВремяSLAИсходящих * 60000);
	
	Запрос.УстановитьПараметр("МеткаИзмененияОтВх", Диапазон.ВхОт);
	Запрос.УстановитьПараметр("МеткаИзмененияДоВх", Диапазон.ВхДо);
	
	
	Запрос.УстановитьПараметр("МеткаИзмененияОтИсх", Диапазон.ИсхОт);
	Запрос.УстановитьПараметр("МеткаИзмененияДоИсх", Диапазон.ИсхДо);
	
	Возврат Запрос.ВыполнитьПакет();
	
КонецФункции

#КонецОбласти

#Область Прочее

// Добавляет сообщение в журнал.
// 
// Параметры:
//  ТекстЖурнала - Строка - Текст журнала
//  ТекстСообщения - Строка - Новый текст сообщения
// 
// Возвращаемое значение:
//  Строка - Дополнить текст журнала
Функция ДополнитьТекстЖурнала(ТекстЖурнала, ТекстСообщения)
	
	Если ПустаяСтрока(ТекстЖурнала) Тогда
		Возврат ТекстСообщения;
		
	ИначеЕсли ПустаяСтрока(ТекстСообщения) Тогда
		Возврат ТекстЖурнала;
		
	Иначе
		Возврат СокрЛП(ТекстСообщения) + "
		|--------------------------------------------------
		|" + СокрЛП(ТекстЖурнала);
		
	КонецЕсли;
	
КонецФункции

// Очереди исходящих.
// 
// Возвращаемое значение:
//  Структура - Очереди исходящих:
// * Очередь - РегистрСведенийНаборЗаписей.кфкИсходящиеСообщения - Исходящие сообщения
// * ОчередьПотока - РегистрСведенийНаборЗаписей.кфкОчередьПотоков - Очередь потоков
Функция ОчередиИсходящих()
	
	Результат = Новый Структура;
	Результат.Вставить("Очередь", кфкОбщегоНазначенияСлужебный.СоздатьНаборЗаписей(РегистрыСведений.кфкИсходящиеСообщения));
	Результат.Вставить("ОчередьПотока", кфкОбщегоНазначенияСлужебный.СоздатьНаборЗаписей(РегистрыСведений.кфкОчередьПотоков));
	
	//@skip-check constructor-function-return-section
	Возврат Результат;
	
КонецФункции

// Очереди входящих.
// 
// Возвращаемое значение:
//  Структура - Очереди исходящих:
// * Очередь - РегистрСведенийНаборЗаписей.кфкВходящиеСообщения - Входящие сообщения
// * ОчередьПотока - РегистрСведенийНаборЗаписей.кфкОчередьПотоков - Очередь потоков
Функция ОчередиВходящих()
	
	Результат = Новый Структура;
	Результат.Вставить("Очередь", кфкОбщегоНазначенияСлужебный.СоздатьНаборЗаписей(РегистрыСведений.кфкВходящиеСообщения));
	Результат.Вставить("ОчередьПотока", кфкОбщегоНазначенияСлужебный.СоздатьНаборЗаписей(РегистрыСведений.кфкОчередьПотоков));
	
	//@skip-check constructor-function-return-section
	Возврат Результат;
	
КонецФункции

// Новая очередь.
// 
// Параметры:
//	Очереди - Структура - Очереди, см. ОчередиИсходящих, ОчередиВходящих 
// 
// Возвращаемое значение:
//  РегистрСведенийНаборЗаписей.кфкИсходящиеСообщения, РегистрСведенийНаборЗаписей.кфкВходящиеСообщения - Новая очередь
Функция НоваяОчередь(Очереди)
	
	Результат = Очереди.Очередь; // РегистрСведенийНаборЗаписей.кфкИсходящиеСообщения, РегистрСведенийНаборЗаписей.кфкВходящиеСообщения
	Результат.Отбор.Сбросить();
	Результат.Очистить();
	
	Возврат Результат;
	
КонецФункции

// Новая очередь потока.
// 
// Параметры:
//  Очереди - Структура - Очереди, см. ОчередиИсходящих, ОчередиВходящих
// 
// Возвращаемое значение:
//  РегистрСведенийНаборЗаписей.кфкОчередьПотоков - Новая очередь потока
Функция НоваяОчередьПотока(Очереди)
	
	Результат = Очереди.ОчередьПотока; // РегистрСведенийНаборЗаписей.кфкОчередьПотоков
	Результат.Отбор.Сбросить();
	Результат.Очистить();
	
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#КонецОбласти
