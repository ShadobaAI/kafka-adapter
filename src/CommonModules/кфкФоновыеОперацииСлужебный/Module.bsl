// 
// Возвращаемое значение:
//  Строка - Ключ зфонового задания
Функция КлючЗадания(КлючПотока, ДиспетчерЗадач = Неопределено)
	
	Результат = "кфк" + КлючПотока;
	 
	Если ДиспетчерЗадач = Неопределено Тогда
		Возврат Результат;
		
	ИначеЕсли ТипЗнч(ДиспетчерЗадач) = Тип("Строка") Тогда
		Возврат Результат + "_" + ДиспетчерЗадач;
		
	Иначе
		Возврат Результат + "_" + Лев(XMLСтрока(ДиспетчерЗадач), 8);
		
	КонецЕсли;
	
