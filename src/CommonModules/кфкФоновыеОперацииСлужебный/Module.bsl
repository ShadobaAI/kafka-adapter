// Возвращает представления идентификаторов операций.
// 
// Возвращаемое значение:
//	СписокЗначений Из УникальныйИдентификатор - Представления идентификатора операций
Функция ПредставленияИдентификатораОпераций() Экспорт

	// Шаблон - 00000000-XXXX-0000-NNNN-NNNNNNNNNNNN
	//  Доступные символы - [a-f0-9]
	//	XXXX - ИД раздела
	//	NNNN-NNNNNNNNNNNN - Сквозной ИД операции
	
	Результат = Новый СписокЗначений; // СписокЗначений Из УникальныйИдентификатор
	
	// ОтправкаЛогов, ИД - 1
	Результат.Добавить(ИДОперации_ВыгрузкаЛоговИсходящихСообщений(), НСтр("ru = 'Выгрузка логов исходящих сообщений'"));
	Результат.Добавить(ИДОперации_ВыгрузкаЛоговВходящихСообщений(), НСтр("ru = 'Выгрузка логов входящих сообщений'"));
	
	// КонтрольИнтеграции, ИД - 2
	Результат.Добавить(ИДОперации_КонтрольИнтеграцииИсходящих(), НСтр("ru = 'Контроль интеграции исходящих сообщений'"));
	Результат.Добавить(ИДОперации_КонтрольИнтеграцииВходящих(), НСтр("ru = 'Контроль интеграции входящих сообщений'"));
	
	// УказательНачалаВыборки, ИД - 3
	Результат.Добавить(ИДОперации_УказательСериализацииСообщений(), НСтр("ru = 'Сериализация сообщений'"));
	Результат.Добавить(ИДОперации_УказательОтправкиИсходящихСообщений(), НСтр("ru = 'Публикация сообщений'"));
	Результат.Добавить(ИДОперации_УказательУдаленияДублейОчереди(), НСтр("ru = 'Удаление дублей очереди'"));
	Результат.Добавить(ИДОперации_ВозвратВОчередь(), НСтр("ru = 'Возврат в очередь'"));
	Результат.Добавить(ИДОперации_УказательДесериализацииСообщений(), НСтр("ru = 'Десериализация сообщений'"));
	
	Возврат Результат;

КонецФункции

// Возвращает ключи служебных операций
// 
// Возвращаемое значение:
//	ФиксированныйМассив Из Строка - Ключи служебных операций
Функция КлючиСлужебныхОпераций() Экспорт
	
	Результат = Новый Массив; // Массив Из Строка
	
	Для Каждого Элемент Из СписокСлужебныхОпераций(Неопределено, Истина) Цикл
		Результат.Добавить(КлючЗадания(Элемент.Значение));
	КонецЦикла;
	
	Возврат Новый ФиксированныйМассив(Результат);
	
КонецФункции

