// Новое описание правил обмена.
// 
// Возвращаемое значение:
//	Структура - описание обмена:
//	 * Тип - ПеречислениеСсылка.кфкТипыОбработчиков - Тип обработчика
//	 * ИмяМетода - Строка - Метод произвольного обработчика
//	 * ИмяМодуля - Строка - Менеджер обмена
//	 * ИмяПОД - Строка - Имя ПОД
//	 * Формат - Строка - Формат обмена
//	 * КомпонентыОбмена - Неопределено, Структура - Компоненты обмена. см. кфкОбменДаннымиXDTOСервер.ИнициализироватьКомпонентыОбмена
Функция НовоеОписаниеПравилОбмена() Экспорт
	
	Результат = Новый Структура;
	Результат.Вставить("Тип", Перечисления.кфкТипыОбработчиков.ПустаяСсылка());
	Результат.Вставить("ИмяМетода", "");
	Результат.Вставить("ИмяМодуля", "");
	Результат.Вставить("ИмяПОД", "");
	Результат.Вставить("Формат", "");
	
	Результат.Вставить("КомпонентыОбмена", Неопределено);
	
	Возврат Результат;
		
КонецФункции

#КонецОбласти

