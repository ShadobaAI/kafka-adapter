// @strict-types
#Область СлужебныйПрограммныйИнтерфейс

#Область УправлениеФЗ

// Запустить интеграцию kafka.
Процедура ЗапуститьРегламентноеЗадание() Экспорт
	
	ОбщегоНазначения.ПриНачалеВыполненияРегламентногоЗадания(Метаданные.РегламентныеЗадания.кфкЗапускИнтеграции);
	
	ЗапуститьПотоки = ПолучитьФункциональнуюОпцию("кфкИспользоватьИнтеграцию")
		И Не ПолучитьФункциональнуюОпцию("кфкБлокировкаИнтеграции");
	
	Если ЗапуститьПотоки Тогда
		ЗапуститьПотоки();
	КонецЕсли;
	
КонецПроцедуры

// Получить потоки.
// 
// Параметры:
//  Состояние - Неопределено, СостояниеФоновогоЗадания - Состояние
// 
// Возвращаемое значение:
//  Массив Из ФоновоеЗадание - Потоки
Функция ПолучитьПотоки(Состояние = Неопределено) Экспорт
	
	Результат = Новый Массив;
	
	Отбор = Новый Структура;
	Отбор.Вставить("ИмяМетода", "");
	Если Состояние <> Неопределено Тогда
		Отбор.Вставить("Состояние", Состояние);
	КонецЕсли;
	
	Для Каждого Элемент Из СписокВсехОпераций() Цикл
		
		// Однопоточный режим
		Отбор.ИмяМетода = ИмяМетодаПотока(Элемент.Значение);
		Задания = ФоновыеЗадания.ПолучитьФоновыеЗадания(Отбор);
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Результат, Задания);
		
		// Многопоточный режим
		Отбор.ИмяМетода = Отбор.ИмяМетода + "ВПотоке";
		Задания = ФоновыеЗадания.ПолучитьФоновыеЗадания(Отбор);
		ОбщегоНазначенияКлиентСервер.ДополнитьМассив(Результат, Задания);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Регламентное задание.
// 
// Возвращаемое значение:
//  РегламентноеЗадание - Регламентное задание
Функция РегламентноеЗадание() Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	ОбъектМД = Метаданные.РегламентныеЗадания.кфкЗапускИнтеграции;
	Задания = РегламентныеЗадания.ПолучитьРегламентныеЗадания(Новый Структура("Метаданные", ОбъектМД));
	Если Задания.Количество() Тогда
		Задание = Задания[0];
	Иначе
		Задание = РегламентныеЗадания.СоздатьРегламентноеЗадание(ОбъектМД);
		Задание.Использование = Ложь;
		Задание.Записать();
		
	КонецЕсли;
	
	Возврат Задание;
	
КонецФункции

// Запустить потоки интеграции
Процедура ЗапуститьПотоки() Экспорт
	
	// Для запуска служебных операций
	ФактЗапуска = Новый Структура;
	ФактЗапуска.Вставить("Выгрузка", Ложь);
	ФактЗапуска.Вставить("Загрузка", Ложь);
	ФактЗапуска.Вставить("Сериализация", Ложь);
	ФактЗапуска.Вставить("Десериализация", Ложь);
	
	// ИсходящиеСообщения & ВходящиеСообщения
	Таблица = ТаблицаРаспределенияПотоков();
	ДиспетчерыЗадач = Таблица.Скопировать(, "Ссылка,Представление,ПодпотокиОбработки,ПодпотокиТранспорта");
	ДиспетчерыЗадач.Свернуть("Ссылка,Представление,ПодпотокиОбработки,ПодпотокиТранспорта");
	Для Каждого ДиспетчерЗадач Из ДиспетчерыЗадач Цикл
		
		ТипНаправления = ТипЗнч(ДиспетчерЗадач.Ссылка);
		
		НастройкиОбработки = Новый Массив; // Массив Из СправочникСсылка.кфкПродюсеры, СправочникСсылка.кфкКонсьюмеры
		НастройкиТранспорта = Новый Массив; // Массив Из СправочникСсылка.кфкПродюсеры, СправочникСсылка.кфкКонсьюмеры
		Для Каждого Строка Из Таблица.НайтиСтроки(Новый Структура("Ссылка", ДиспетчерЗадач.Ссылка)) Цикл
			
			Если Не Строка.БлокироватьОбработку Тогда
				НастройкиОбработки.Добавить(Строка.Настройка);
			КонецЕсли;
			
			Если Не Строка.БлокироватьТранспорт Тогда
				НастройкиТранспорта.Добавить(Строка.Настройка);
			КонецЕсли;
			
		КонецЦикла;
		
		ПараметрыЗадания = Новый Массив(4);
		ПараметрыЗадания[0] = Новый Структура;
		ПараметрыЗадания[1] = Новый Массив; // Массив Из СправочникСсылка.кфкПродюсеры, СправочникСсылка.кфкКонсьюмеры - Список продюсеров или консьюмеров
		ПараметрыЗадания[2] = МинимальноеКоличествоПотоков();
		ПараметрыЗадания[3] = Ложь; // Булево - Интерактивный режим (из формы элемента продюсера).
		
		Для Каждого Элемент Из СписокОперацийОбмена(ТипНаправления) Цикл
			
			Настройки = ?(Элемент.Пометка, НастройкиТранспорта, НастройкиОбработки);
			Если Настройки.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			
			Ключ = КлючЗадания(Элемент.Значение, ДиспетчерЗадач.Ссылка);
			Наименование = ПредставлениеЗадания(Элемент.Представление, ДиспетчерЗадач.Представление);
			ИмяМетода = ИмяМетодаПотока(Элемент.Значение);
			
			ПараметрыЗадания[0] = Новый Структура("Ключ, Наименование, ИмяМетода", Ключ, Наименование, ИмяМетода);
			ПараметрыЗадания[1] = Настройки;
			ПараметрыЗадания[2] = ?(Элемент.Пометка, Строка.ПодпотокиТранспорта, Строка.ПодпотокиОбработки);
			
			ЗапуститьФЗ(Ключ, ИмяМетода, Наименование, ПараметрыЗадания);
			
			// Определяем необходимость запуска служебных потоков
			Если ТипНаправления = Тип("СправочникСсылка.кфкПродюсеры") Тогда
				Если Элемент.Пометка Тогда	// Транспорта
					ФактЗапуска.Выгрузка = Истина;
				Иначе						// Обработка
					ФактЗапуска.Сериализация = Истина;
				КонецЕсли;
				
			ИначеЕсли ТипНаправления = Тип("СправочникСсылка.кфкКонсьюмеры") Тогда
				Если Элемент.Пометка Тогда	// Транспорта
					ФактЗапуска.Загрузка = Истина;
				Иначе						// Обработка
					ФактЗапуска.Десериализация = Истина;
				КонецЕсли;
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	// Служебные
	Для Каждого Элемент Из СписокСлужебныхОпераций(ФактЗапуска) Цикл
		ЗапуститьФЗ(
			КлючЗадания(Элемент.Значение),
			ИмяМетодаПотока(Элемент.Значение),
			ПредставлениеЗадания(Элемент.Представление));
	КонецЦикла;
	
КонецПроцедуры

// Запустить поток в интерактивном режиме.
// 
// Параметры:
//  Настройка - СправочникСсылка.кфкПродюсеры, СправочникСсылка.кфкКонсьюмеры - Настройка
//  ЭтоОбработка - Булево - Истина обработка, иначе транспорт
//  Идентификатор - УникальныйИдентификатор - Идентификатор формы
// 
// Возвращаемое значение:
//  Структура - параметры выполнения задания, см. ДлительныеОперации.ВыполнитьПроцедуру.
Функция ЗапуститьПотокИнтерактивно(Настройка, ЭтоОбработка, Идентификатор) Экспорт
	
	ТНастройка = ТипЗнч(Настройка);
	ШаблонОперации = ?(ЭтоОбработка, ОписаниеОперацииОбработки(ТНастройка), ОписаниеОперацииТранспорта(ТНастройка));
	
	Ключ = КлючЗадания(ШаблонОперации.Имя, НСтр("ru = 'РучнойРежим'"));
	Наименование = ПредставлениеЗадания(ШаблонОперации.Синоним, НСтр("ru = 'Ручной режим'"));
	ИмяМетода = ИмяМетодаПотока(ШаблонОперации.Имя);
	
	ПараметрыВыполнения = ДлительныеОперации.ПараметрыВыполненияФункции(Идентификатор);
	ПараметрыВыполнения.НаименованиеФоновогоЗадания = Наименование;
	ПараметрыВыполнения.КлючФоновогоЗадания = Ключ;
	ПараметрыВыполнения.ЗапуститьВФоне = Истина;
	ПараметрыВыполнения.СРасширениямиБазыДанных = Истина;
	
	Операция = Новый Структура("Ключ, Наименование, ИмяМетода", Ключ, Наименование, ИмяМетода);
	
	Результат = ДлительныеОперации.ВыполнитьПроцедуру(
		ПараметрыВыполнения,
		Операция.ИмяМетода,
		Операция, ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Настройка), МинимальноеКоличествоПотоков(), Истина);
	
	//@skip-check constructor-function-return-section
	Возврат Результат;
	
КонецФункции

#КонецОбласти

#Область ФоновыеОперации

#Область СериализацияСообщений

// Сериализация сообщений
// 
// Параметры:
//	Операция - Структура - Описание операции обмена, см. ОписаниеОперацииОбмена
//	Продюсеры - Массив Из СправочникСсылка.кфкПродюсеры - Список продюсеров
//	МаксКолПотоков - Число - Максимальное количество потоков
//	ИнтерактивныйРежим - Булево - Интерактивный режим (из формы элемента продюсера).
Процедура СериализацияСообщений(Операция, Продюсеры, МаксКолПотоков, ИнтерактивныйРежим = Ложь) Экспорт
	
	// многопоточность
	Потоки = Новый Массив; // Массив Из УникальныйИдентификатор
	// стратегия распределения
	МинРазмерПакета = МинимальныйРазмерПакета();
	МаксРазмерПакета = РазмерПорцииНабораЗаписей();
	РазмерВыборкиЗапроса = МаксРазмерПакета * МаксКолПотоков;
	// указатели
	Указатели = ПустаяТаблицаУказателейПотоков();
	ИДОперации = ИДОперации_УказательСериализацииСообщений();
	РазделОперации = ПолучитьРазделОперации(Продюсеры);
	УказательНачалаВыборки = ПолучитьПозицию(ИДОперации, РазделОперации.Значение);
	// обработка
	Очередь = кфкОбщегоНазначенияСлужебный.СоздатьНаборЗаписей(РегистрыСведений.кфкОчередьПотоков); // РегистрСведенийНаборЗаписей.кфкОчередьПотоков
	Правила = Справочники.кфкПродюсеры.ПравилаСериализации(Продюсеры);
	
	Активен = Истина;
	Пока Активен Цикл //@skip-check query-in-loop
		
		УказательПустойВыборки = УказательПустойВыборки();
		Выборка = ВыборкаСериализацииСообщений(Продюсеры, РазмерВыборкиЗапроса, УказательНачалаВыборки);
		Если Выборка.Количество() = 0 Тогда
			Если Не ИнтерактивныйРежим И ПолучитьФункциональнуюОпцию("кфкИспользоватьПотоковыйРежим") Тогда
				АктуализироватьПотоки(Потоки);
				ОбновитьСтатусУказателей(Указатели, Потоки);
				ВызватьПаузу(5000);
				
			ИначеЕсли Указатели.Количество() = 0 Тогда
				Активен = Ложь;
				
			Иначе
				ОжидатьЗавершенияПотоков(Потоки);
				ЗафиксироватьУказатели(Указатели, Потоки);
				
			КонецЕсли;
			
		Иначе
			РазмерПакета = Макс(Мин(Цел(Выборка.Количество() / МаксКолПотоков), МаксРазмерПакета), МинРазмерПакета);
			
			ДоступныеПотоки = ОжидатьСвободныеПотоки(Операция, Потоки, МаксКолПотоков, Правила);
			ЗафиксироватьУказатели(Указатели, ДоступныеПотоки);
			
			ИндексПотока = 0;
			ИдентификаторПотока = ДоступныеПотоки[ИндексПотока];
			
			Счетчик = 0;
			МеткаИзмененияМС = 0;
			Пока Выборка.Следующий() Цикл
				Счетчик = Счетчик + 1;
				МеткаИзмененияМС = Выборка.МеткаИзмененияМС;
				
				НоваяСтрока = Очередь.Добавить();
				НоваяСтрока.Ключ = Выборка.КлючЗаписи;
				НоваяСтрока.ВременнаяМетка = Выборка.ДатаРегистрацииМС;
				НоваяСтрока.ИдентификаторПотока = ИдентификаторПотока;
				
				Если Счетчик >= РазмерПакета Тогда
					Счетчик = 0;
					
					Очередь.Записать(РежимЗамещения.Добавление);
					ДобавитьУказательПотока(Указатели, ИдентификаторПотока, МеткаИзмененияМС);
					Очередь.Очистить();
					
					Если ИндексПотока < ДоступныеПотоки.ВГраница() Тогда
						ИндексПотока = ИндексПотока + 1;
						
					Иначе
						ИндексПотока = 0;
						ДоступныеПотоки = ОжидатьСвободныеПотоки(Операция, Потоки, МаксКолПотоков, Правила);
						ЗафиксироватьУказатели(Указатели, ДоступныеПотоки);
						
					КонецЕсли;
					ИдентификаторПотока = ДоступныеПотоки[ИндексПотока];
					
				КонецЕсли;
				
			КонецЦикла;
			
			Если Очередь.Количество() Тогда
				Очередь.Записать(РежимЗамещения.Добавление);
				ДобавитьУказательПотока(Указатели, ИдентификаторПотока, МеткаИзмененияМС);
				Очередь.Очистить();
			КонецЕсли;
			
		КонецЕсли;
		
		Если Активен И ПолучитьФункциональнуюОпцию("кфкБлокировкаИнтеграции") Тогда
			Активен = Ложь;
			ОжидатьЗавершенияПотоков(Потоки);
			ЗафиксироватьУказатели(Указатели, Потоки);
		КонецЕсли;
		
		ОбновитьУказательНачалаВыборки(УказательНачалаВыборки, Указатели, УказательПустойВыборки, Потоки, ИДОперации,
			РазделОперации);
		
	КонецЦикла;
	
	ЗавершитьПотоки(Потоки);
	
КонецПроцедуры

// Сериализация сообщений в потоке.
// 
// Параметры:
//  Правила - Соответствие Из Строка - см. Справочники.кфкПродюсеры.ПравилаСериализации
Процедура СериализацияСообщенийВПотоке(Правила) Экспорт
	
	ИдентификаторПотока = ТекущийПоток().УникальныйИдентификатор;
	ПустойЗапрос = Дата(3999, 12, 31);
	Очереди = ОчередиИсходящих();
	РазмерПорцииНабора = РазмерПорцииНабораЗаписей();
	
	Пока Истина Цикл
		
		Если ПолучитьФункциональнуюОпцию("кфкБлокировкаИнтеграции") Тогда
			ОчиститьОчередьПотоков(ИдентификаторПотока);
			Прервать;
		КонецЕсли;
		
		Выборка = ВыборкаСериализацияСообщенийВПотоке(ИдентификаторПотока, РазмерПорцииНабора);
		Если Выборка.Количество() = 0 Тогда
			ПустойЗапрос = Мин(ПустойЗапрос, ТекущаяУниверсальнаяДата());
			Если ПустойЗапрос > ТекущаяУниверсальнаяДата() - ТаймаутПростояПотока() Тогда
				ВызватьПаузу(5000);
			Иначе
				Прервать;
			КонецЕсли;
			
		Иначе
			ПустойЗапрос = Дата(3999, 12, 31);
			
			ОбработчикСериализацииСообщений(Выборка, Очереди, ИдентификаторПотока, Правила);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Сериализация сообщения.
// 
// Параметры:
//	Сообщение - Структура, РегистрСведенийКлючЗаписи.кфкИсходящиеСообщения - Сообщение:
//	 * КлючЗаписи - Строка - Ключ записи
//	 * ДатаРегистрацииМС - Число - Дата регистрации в миллисекундах
Процедура СериализацияСообщения(Сообщение) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	Т.КлючЗаписи КАК КлючЗаписи,
	|	Т.ДатаРегистрацииМС КАК ДатаРегистрацииМС,
	|	Т.ИсходныеДанные КАК ИсходныеДанные,
	|	Т.ЭтоУдаление КАК ЭтоУдаление,
	|	Т.Продюсер КАК Продюсер,
	|	Т.ТипОбъект КАК ТипОбъект,
	|	Т.ТипИсходныхДанных КАК ТипИсходныхДанных,
	|	Т.КлючОбъекта КАК КлючОбъекта,
	|	Т.СобытиеРегистрации КАК СобытиеРегистрации,
	|	Т.ДатаРегистрации КАК ДатаРегистрации,
	|	Т.ДатаОбработки КАК ДатаОбработки,
	|	Т.ТекстЖурнала КАК ТекстЖурнала,
	|	Т.КоличествоОбработок КАК КоличествоОбработок,
	|	Т.КоличествоВыгрузок КАК КоличествоВыгрузок
	|ИЗ
	|	РегистрСведений.кфкИсходящиеСообщения КАК Т
	|ГДЕ
	|	Т.КлючЗаписи = &КлючЗаписи
	|	И Т.ДатаРегистрацииМС = &ДатаРегистрацииМС
	|	И НЕ 0 В
	|		(ВЫБРАТЬ
	|			0
	|		ИЗ
	|			РегистрСведений.кфкОчередьПотоков КАК ОП
	|		ГДЕ
	|			ОП.Ключ = Т.КлючЗаписи)";
	Запрос.УстановитьПараметр("КлючЗаписи", Сообщение.КлючЗаписи);
	Запрос.УстановитьПараметр("ДатаРегистрацииМС", Сообщение.ДатаРегистрацииМС);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		
		//@skip-check bsl-legacy-check-string-literal
		Правила = Справочники.кфкПродюсеры.ПравилаСериализации(Выборка["Продюсер"]);
		
		Выборка.Сбросить();
		ОбработчикСериализацииСообщений(Выборка, ОчередиИсходящих(), "СЕРИАЛИЗАЦИЯ-СООБЩЕНИЯ", Правила);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ВыгрузкаСообщений

// Отправка сообщений в kafka.
// 
// Параметры:
//	Операция - Структура - Описание операции обмена, см. ОписаниеОперацииОбмена
//	Продюсеры - Массив Из СправочникСсылка.кфкПродюсеры - Список продюсеров
//	МаксКолПотоков - Число - Максимальное количество потоков
//	ИнтерактивныйРежим - Булево - Интерактивный режим (из формы элемента продюсера).
Процедура ОтправкаСообщенийВKafka(Операция, Продюсеры, МаксКолПотоков, ИнтерактивныйРежим = Ложь) Экспорт
	
	// многопоточность
	Потоки = Новый Массив; // Массив Из УникальныйИдентификатор
	// стратегия распределения
	МинРазмерПакета = МинимальныйРазмерПакета();
	МаксРазмерПакета = РазмерПорцииНабораЗаписей() * КоэффициентРазмераВыборкиЗапроса();
	РазмерВыборкиЗапроса = МаксРазмерПакета * МаксКолПотоков;
	// указатели
	Указатели = ПустаяТаблицаУказателейПотоков();
	ИДОперации = ИДОперации_УказательОтправкиИсходящихСообщений();
	РазделОперации = ПолучитьРазделОперации(Продюсеры);
	УказательНачалаВыборки = ПолучитьПозицию(ИДОперации, РазделОперации.Значение);
	// обработка
	Очередь = кфкОбщегоНазначенияСлужебный.СоздатьНаборЗаписей(РегистрыСведений.кфкОчередьПотоков); // РегистрСведенийНаборЗаписей.кфкОчередьПотоков
	ПараметрыПотока = Новый Массив(2);
	ПараметрыПотока[0] = Справочники.кфкПродюсеры.Топики(Продюсеры);
	ПараметрыПотока[1] = ИспользоватьПакетнуюПубликацию(Продюсеры);
	
	Активен = Истина;
	Пока Активен Цикл //@skip-check query-in-loop
		
		УказательПустойВыборки = УказательПустойВыборки();
		Выборка = ВыборкаОтправкиИсходящихСообщений(Продюсеры, РазмерВыборкиЗапроса, УказательНачалаВыборки);
		Если Выборка.Количество() = 0 Тогда
			Если Не ИнтерактивныйРежим И ПолучитьФункциональнуюОпцию("кфкИспользоватьПотоковыйРежим") Тогда
				АктуализироватьПотоки(Потоки);
				ОбновитьСтатусУказателей(Указатели, Потоки);
				ВызватьПаузу(5000);
				
			ИначеЕсли Указатели.Количество() = 0 Тогда
				Активен = Ложь;
				
			Иначе
				ОжидатьЗавершенияПотоков(Потоки);
				ЗафиксироватьУказатели(Указатели, Потоки);
				
			КонецЕсли;
			
		Иначе
			РазмерПакета = Макс(Мин(Цел(Выборка.Количество() / МаксКолПотоков), МаксРазмерПакета), МинРазмерПакета);
			
			ДоступныеПотоки = ОжидатьСвободныеПотоки(Операция, Потоки, МаксКолПотоков, ПараметрыПотока);
			ЗафиксироватьУказатели(Указатели, ДоступныеПотоки);
			
			ИндексПотока = 0;
			ИдентификаторПотока = ДоступныеПотоки[ИндексПотока];
			
			Счетчик = 0;
			МеткаИзмененияМС = 0;
			Пока Выборка.Следующий() Цикл
				Счетчик = Счетчик + 1;
				МеткаИзмененияМС = Выборка.МеткаИзмененияМС;
				
				НоваяСтрока = Очередь.Добавить();
				НоваяСтрока.Ключ = Выборка.КлючЗаписи;
				НоваяСтрока.ВременнаяМетка = Выборка.ДатаРегистрацииМС;
				НоваяСтрока.ИдентификаторПотока = ИдентификаторПотока;
				
				Если Счетчик >= РазмерПакета Тогда
					Счетчик = 0;
					
					Очередь.Записать(РежимЗамещения.Добавление);
					ДобавитьУказательПотока(Указатели, ИдентификаторПотока, МеткаИзмененияМС);
					Очередь.Очистить();
					
					Если ИндексПотока < ДоступныеПотоки.ВГраница() Тогда
						ИндексПотока = ИндексПотока + 1;
						
					Иначе
						ИндексПотока = 0;
						ДоступныеПотоки = ОжидатьСвободныеПотоки(Операция, Потоки, МаксКолПотоков, ПараметрыПотока);
						ЗафиксироватьУказатели(Указатели, ДоступныеПотоки);
						
					КонецЕсли;
					ИдентификаторПотока = ДоступныеПотоки[ИндексПотока];
					
				КонецЕсли;
				
			КонецЦикла;
			
			Если Очередь.Количество() Тогда
				Очередь.Записать(РежимЗамещения.Добавление);
				ДобавитьУказательПотока(Указатели, ИдентификаторПотока, МеткаИзмененияМС);
				Очередь.Очистить();
			КонецЕсли;
			
		КонецЕсли;
		
		Если Активен И ПолучитьФункциональнуюОпцию("кфкБлокировкаИнтеграции") Тогда
			Активен = Ложь;
			ОжидатьЗавершенияПотоков(Потоки);
			ЗафиксироватьУказатели(Указатели, Потоки);
		КонецЕсли;
		
		ОбновитьУказательНачалаВыборки(УказательНачалаВыборки, Указатели, УказательПустойВыборки, Потоки, ИДОперации,
			РазделОперации);
		
	КонецЦикла;
	
	ЗавершитьПотоки(Потоки);
	
КонецПроцедуры

// Отправка сообщений в kafka в потоке.
// 
// Параметры:
//	Топики - Соответствие Из Строка - см. Справочники.кфкПродюсеры.Топики
//	ПакетнаяПубликация - Булево - Использовать пакетную публикацию
Процедура ОтправкаСообщенийВKafkaВПотоке(Топики, ПакетнаяПубликация) Экспорт
	
	ИдентификаторПотока = ТекущийПоток().УникальныйИдентификатор;
	ПустойЗапрос = Дата(3999, 12, 31);
	Сессии = Новый Соответствие;
	Очереди = ОчередиИсходящих();
	РазмерПорцииНабора = РазмерПорцииНабораЗаписей();
	
	Пока Истина Цикл
		
		Если ПолучитьФункциональнуюОпцию("кфкБлокировкаИнтеграции") Тогда
			ОчиститьОчередьПотоков(ИдентификаторПотока);
			Прервать;
		КонецЕсли;
		
		Выборка = ВыборкаОтправкиИсходящихСообщенийВПотоке(ИдентификаторПотока, РазмерПорцииНабора, ПакетнаяПубликация);
		Если Выборка.Количество() = 0 Тогда
			ПустойЗапрос = Мин(ПустойЗапрос, ТекущаяУниверсальнаяДата());
			Если ПустойЗапрос > ТекущаяУниверсальнаяДата() - ТаймаутПростояПотока() Тогда
				ВызватьПаузу(5000);
			Иначе
				Прервать;
			КонецЕсли;
			
		Иначе
			ПустойЗапрос = Дата(3999, 12, 31);
			
			Если ПакетнаяПубликация Тогда
				Пока Выборка.Следующий() Цикл
					ВыборкаТ = Выборка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам); // уровень ТипОбъект
					Пока ВыборкаТ.Следующий() Цикл
						ИмяТопика = Топики.Получить(НРег(XMLСтрока(ВыборкаТ.Продюсер) + ВыборкаТ.ТипОбъект)); // Строка
						ОбработчикОтправкиПакетИсходящихСообщений(ВыборкаТ.Выбрать(), Сессии, Очереди,
							ИдентификаторПотока, ВыборкаТ.Продюсер, ИмяТопика);
					КонецЦикла;
				КонецЦикла;
				
			Иначе
				ОбработчикОтправкиИсходящихСообщений(Выборка, Сессии, Очереди, ИдентификаторПотока, Топики);
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЦикла;
	
	кфкИнтеграцияСлужебный.ЗакрытьСессииПродюсера(Сессии);
	
КонецПроцедуры

#КонецОбласти

#Область ЗагрузкаСообщений

// Загрузка сообщений из kafka.
// 
// Параметры:
//	Операция - Структура - Описание операции обмена, см. ОписаниеОперацииОбмена
//	Консьюмеры - Массив Из СправочникСсылка.кфкКонсьюмеры - Список консьюмеров
//	МаксКолПотоков - Число - Максимальное количество потоков
//	ИнтерактивныйРежим - Булево - Интерактивный режим (из формы элемента консьюмера).
Процедура ЗагрузкаСообщенийИзKafka(Операция, Консьюмеры, МаксКолПотоков, ИнтерактивныйРежим = Ложь) Экспорт
	
	// многопоточность
	Потоки = Новый Массив; // Массив Из УникальныйИдентификатор
	КЭШ = Новый Структура;
	
	// обработка
	Очередь1 = кфкОбщегоНазначенияСлужебный.СоздатьНаборЗаписей(РегистрыСведений.кфкОчередьПотоков); // РегистрСведенийНаборЗаписей.кфкОчередьПотоков
	Очередь2 = кфкОбщегоНазначенияСлужебный.СоздатьНаборЗаписей(РегистрыСведений.кфкОчередьПотоков); // РегистрСведенийНаборЗаписей.кфкОчередьПотоков
	ОчередьПотоков = ОчередьПотоковЗагрузкиСообщений();
	
	Пока Истина Цикл //@skip-check query-in-loop
		
		СостояниеОчереди = 0;
		Распределение = ТаблицаРаспределенияЧтенияКонсьюмеров(Консьюмеры, МаксКолПотоков, СостояниеОчереди, КЭШ);
		Распределение.Сортировать("НомерПотока Убыв");
		МаксНомерПотока = ?(Распределение.Количество() = 0, 0, Распределение[0].НомерПотока);
		Если МаксНомерПотока = 0 Тогда
			ВызватьИсключение НСтр("ru = 'Не удалось определить количество потоков для чтения сообщений Kafka'");
			
		ИначеЕсли СостояниеОчереди = 0
				И (ИнтерактивныйРежим Или Не ПолучитьФункциональнуюОпцию("кфкИспользоватьПотоковыйРежим")) Тогда
			Прервать;
			
		КонецЕсли;
		// Добавление новых потоков (если необходимо)
		Если Потоки.Количество() < МаксНомерПотока Тогда
			Для НомерПотока = 1 По МаксНомерПотока Цикл
				Задание = ЗапуститьПоток(Операция, НомерПотока);
				Если Потоки.Найти(Задание.УникальныйИдентификатор) = Неопределено Тогда // если новый поток
					// добавляем в список потоков
					Потоки.Вставить(НомерПотока-1, Задание.УникальныйИдентификатор);
					// добавляем команду
					Очередь1.Очистить();
					Очередь1.Отбор.Сбросить();
					Очередь1.Отбор.ИдентификаторПотока.Установить(Задание.УникальныйИдентификатор);
					НоваяСтрока = Очередь1.Добавить();
					НоваяСтрока.Ключ = КомандаЗагрузкаСообщенийАктивно();
					НоваяСтрока.ВременнаяМетка = ТекущаяУниверсальнаяДатаВМиллисекундах();
					НоваяСтрока.ИдентификаторПотока = Задание.УникальныйИдентификатор;
					Очередь1.Записать();
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		// Передача распределения в потоки и удаление лишних потоков
		ОбновитьРаспределениеКонсьюмеров(Распределение, Потоки, Очередь1, Очередь2, ОчередьПотоков);
		
		Если ПолучитьФункциональнуюОпцию("кфкБлокировкаИнтеграции") Тогда
			Прервать;
		КонецЕсли;
		
		ВызватьПаузу(5000);
		
		АктуализироватьПотоки(Потоки);
		
	КонецЦикла;
	
	ЗавершитьПотоки(Потоки, Ложь);
	
КонецПроцедуры

// Загрузка сообщений из kafka в потоке.
Процедура ЗагрузкаСообщенийИзKafkaВПотоке() Экспорт
	
	ИдентификаторПотока = ТекущийПоток().УникальныйИдентификатор;
	РазмерПорцииНабора = РазмерПорцииНабораЗаписей();
	Сессии = Новый Соответствие;
	
	Очередь = кфкОбщегоНазначенияСлужебный.СоздатьНаборЗаписей(РегистрыСведений.кфкВходящиеСообщения); // РегистрСведенийНаборЗаписей.кфкВходящиеСообщения
	
	БезРаспределения = Дата(3999, 12, 31);
	БлокироватьЗавершенияДо = ТекущаяУниверсальнаяДата() + 60; // первую минуту блокируем завершение
	
	// получаем команду о запуске
	ЕстьКоманда = ЕстьКомандаЗагрузкиСообщений(ИдентификаторПотока);
	
	//@skip-check query-in-loop
	Пока ЕстьКоманда Или БлокироватьЗавершенияДо > ТекущаяУниверсальнаяДата() Цикл
		
		Консьюмеры = КонсьюмерыЗагрузкиСообщений(ИдентификаторПотока);
		ЗакрытьСессииКонсьюмераПараллельногоПотока(Сессии, Консьюмеры);
		Если Консьюмеры.Количество() = 0 Тогда
			БезРаспределения = Мин(БезРаспределения, ТекущаяУниверсальнаяДата());
			Если БезРаспределения > ТекущаяУниверсальнаяДата() - ТаймаутПростояПотока() Тогда
				ВызватьПаузу(5000);
			Иначе
				Прервать;
			КонецЕсли;
			
		Иначе
			БезРаспределения = Дата(3999, 12, 31);
			
			Загружено = Ложь;
			ОбработчикЗагрузкиПакетСообщений(Консьюмеры, Сессии, Очередь, РазмерПорцииНабора, Загружено);
			Если Не Загружено Тогда
				ВызватьПаузу(5000);
			КонецЕсли;;
			
		КонецЕсли;
		
		ЕстьКоманда = ЕстьКомандаЗагрузкиСообщений(ИдентификаторПотока); // выполяем пока команду не удалили
		
	КонецЦикла;
	
	кфкИнтеграцияСлужебный.ЗакрытьСессииКонсьюмера(Сессии);
	
КонецПроцедуры

#КонецОбласти

#Область ДесериализацияСообщений

// Десериализация сообщений.
// 
// Параметры:
//	Операция - Структура - Описание операции обмена, см. ОписаниеОперацииОбмена
//	Консьюмеры - Массив Из СправочникСсылка.кфкКонсьюмеры - Список консьюмеров
//	МаксКолПотоков - Число - Максимальное количество потоков
//	ИнтерактивныйРежим - Булево - Интерактивный режим (из формы элемента консьюмера).
Процедура ДесериализацияСообщений(Операция, Консьюмеры, МаксКолПотоков, ИнтерактивныйРежим = Ложь) Экспорт
	
	// многопоточность
	Потоки = Новый Массив; // Массив Из УникальныйИдентификатор
	// стратегия распределения
	МинРазмерПакета = МинимальныйРазмерПакета();
	МаксРазмерПакета = РазмерПорцииНабораЗаписей();
	РазмерВыборкиЗапроса = МаксРазмерПакета * МаксКолПотоков;
	// указатели
	Указатели = ПустаяТаблицаУказателейПотоков();
	ИДОперации = ИДОперации_УказательДесериализацииСообщений();
	РазделОперации = ПолучитьРазделОперации(Консьюмеры);
	УказательНачалаВыборки = ПолучитьПозицию(ИДОперации, РазделОперации.Значение);
	// обработка
	Очередь = кфкОбщегоНазначенияСлужебный.СоздатьНаборЗаписей(РегистрыСведений.кфкОчередьПотоков); // РегистрСведенийНаборЗаписей.кфкОчередьПотоков
	Правила = Справочники.кфкКонсьюмеры.ПравилаДесериализации(Консьюмеры);
	
	Активен = Истина;
	Пока Активен Цикл //@skip-check query-in-loop
		
		УказательПустойВыборки = УказательПустойВыборки();
		Выборка = ВыборкаДесериализацииСообщений(Консьюмеры, РазмерВыборкиЗапроса, УказательНачалаВыборки);
		Если Выборка.Количество() = 0 Тогда
			Если Не ИнтерактивныйРежим И ПолучитьФункциональнуюОпцию("кфкИспользоватьПотоковыйРежим") Тогда
				АктуализироватьПотоки(Потоки);
				ОбновитьСтатусУказателей(Указатели, Потоки);
				ВызватьПаузу(5000);
				
			ИначеЕсли Указатели.Количество() = 0 Тогда
				Активен = Ложь;
				
			Иначе
				ОжидатьЗавершенияПотоков(Потоки);
				ЗафиксироватьУказатели(Указатели, Потоки);
				
			КонецЕсли;
			
		Иначе
			РазмерПакета = Макс(Мин(Цел(Выборка.Количество() / МаксКолПотоков), МаксРазмерПакета), МинРазмерПакета);
			
			ДоступныеПотоки = ОжидатьСвободныеПотоки(Операция, Потоки, МаксКолПотоков, Правила);
			ЗафиксироватьУказатели(Указатели, ДоступныеПотоки);
			
			ИндексПотока = 0;
			ИдентификаторПотока = ДоступныеПотоки[ИндексПотока];
			
			Счетчик = 0;
			МеткаИзмененияМС = 0;
			Пока Выборка.Следующий() Цикл
				Счетчик = Счетчик + 1;
				МеткаИзмененияМС = Выборка.МеткаИзмененияМС;
				
				НоваяСтрока = Очередь.Добавить();
				НоваяСтрока.Ключ = Выборка.КлючЗаписи;
				НоваяСтрока.ВременнаяМетка = Выборка.ДатаЗагрузкиМС;
				НоваяСтрока.ИдентификаторПотока = ИдентификаторПотока;
				
				Если Счетчик >= РазмерПакета Тогда
					Счетчик = 0;
					
					Очередь.Записать(РежимЗамещения.Добавление);
					ДобавитьУказательПотока(Указатели, ИдентификаторПотока, МеткаИзмененияМС);
					Очередь.Очистить();
					
					Если ИндексПотока < ДоступныеПотоки.ВГраница() Тогда
						ИндексПотока = ИндексПотока + 1;
						
					Иначе
						ИндексПотока = 0;
						ДоступныеПотоки = ОжидатьСвободныеПотоки(Операция, Потоки, МаксКолПотоков, Правила);
						ЗафиксироватьУказатели(Указатели, ДоступныеПотоки);
						
					КонецЕсли;
					ИдентификаторПотока = ДоступныеПотоки[ИндексПотока];
					
				КонецЕсли;
				
			КонецЦикла;
			
			Если Очередь.Количество() Тогда
				Очередь.Записать(РежимЗамещения.Добавление);
				ДобавитьУказательПотока(Указатели, ИдентификаторПотока, МеткаИзмененияМС);
				Очередь.Очистить();
			КонецЕсли;
			
		КонецЕсли;
		
		Если Активен И ПолучитьФункциональнуюОпцию("кфкБлокировкаИнтеграции") Тогда
			Активен = Ложь;
			ОжидатьЗавершенияПотоков(Потоки);
			ЗафиксироватьУказатели(Указатели, Потоки);
		КонецЕсли;
		
		ОбновитьУказательНачалаВыборки(УказательНачалаВыборки, Указатели, УказательПустойВыборки, Потоки, ИДОперации,
			РазделОперации);
		
	КонецЦикла;
	
	ЗавершитьПотоки(Потоки);
	
КонецПроцедуры

// Обработка десериализации сообщени в потоке.
// 
// Параметры:
//  Правила - Соответствие Из Строка - см. Справочники.кфкКонсьюмеры.ПравилаДесериализации
Процедура ДесериализацияСообщенийВПотоке(Правила) Экспорт
	
	ИдентификаторПотока = ТекущийПоток().УникальныйИдентификатор;
	ПустойЗапрос = Дата(3999, 12, 31);
	Очереди = ОчередиВходящих();
	РазмерПорцииНабора = РазмерПорцииНабораЗаписей();
	
	Пока Истина Цикл
		
		Если ПолучитьФункциональнуюОпцию("кфкБлокировкаИнтеграции") Тогда
			ОчиститьОчередьПотоков(ИдентификаторПотока);
			Прервать;
		КонецЕсли;
		
		Выборка = ВыборкаДесериализацииСообщенийВПотоке(ИдентификаторПотока, РазмерПорцииНабора);
		Если Выборка.Количество() = 0 Тогда
			ПустойЗапрос = Мин(ПустойЗапрос, ТекущаяУниверсальнаяДата());
			Если ПустойЗапрос > ТекущаяУниверсальнаяДата() - ТаймаутПростояПотока() Тогда
				ВызватьПаузу(5000);
			Иначе
				Прервать;
			КонецЕсли;
			
		Иначе
			ПустойЗапрос = Дата(3999, 12, 31);
			
			ОбработчикДесериализацииСообщений(Выборка, Очереди, ИдентификаторПотока, Правила);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Десериализация сообщения.
// 
// Параметры:
//	Сообщение - Структура, РегистрСведенийКлючЗаписи.кфкВходящиеСообщения - Сообщение:
//	 * КлючЗаписи - Строка - Ключ записи
//	 * ДатаЗагрузкиМС - Число - Дата загрузки в миллисекундах
Процедура ДесериализацияСообщения(Сообщение) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	Т.Консьюмер КАК Консьюмер,
	|	Т.Топик КАК Топик,
	|	Т.Раздел КАК Раздел,
	|	Т.Смещение КАК Смещение,
	|	Т.КлючСообщения КАК КлючСообщения,
	|	Т.КлючЗаписи КАК КлючЗаписи,
	|	Т.Заголовки КАК Заголовки,
	|	Т.ТелоСообщения КАК ТелоСообщения,
	|	Т.ДатаЗаписи КАК ДатаЗаписи,
	|	Т.ДатаЗагрузки КАК ДатаЗагрузки,
	|	Т.ДатаЗагрузкиМС КАК ДатаЗагрузкиМС,
	|	Т.ДатаОбработки КАК ДатаОбработки,
	|	Т.ТекстЖурнала КАК ТекстЖурнала,
	|	Т.КоличествоОбработок КАК КоличествоОбработок
	|ИЗ
	|	РегистрСведений.кфкВходящиеСообщения КАК Т
	|ГДЕ
	|	Т.КлючЗаписи = &КлючЗаписи
	|	И Т.ДатаЗагрузкиМС = &ДатаЗагрузкиМС
	|	И НЕ 0 В
	|		(ВЫБРАТЬ
	|			0
	|		ИЗ
	|			РегистрСведений.кфкОчередьПотоков КАК ОП
	|		ГДЕ
	|			ОП.Ключ = Т.КлючЗаписи)";
	Запрос.УстановитьПараметр("КлючЗаписи", Сообщение.КлючЗаписи);
	Запрос.УстановитьПараметр("ДатаЗагрузкиМС", Сообщение.ДатаЗагрузкиМС);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		
		//@skip-check bsl-legacy-check-string-literal
		Правила = Справочники.кфкКонсьюмеры.ПравилаДесериализации(Выборка["Консьюмер"]);
		
		Выборка.Сбросить();
		ОбработчикДесериализацииСообщений(Выборка, ОчередиВходящих(), "ДЕСЕРИАЛИЗАЦИЯ-СООБЩЕНИЯ", Правила);
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеОперации

// Удаление дублей очереди.
Процедура УдалениеДублейОчереди() Экспорт
	
	// Указатель
	ИДОперации = ИДОперации_УказательУдаленияДублейОчереди();
	УказательНачалаВыборки = ПолучитьПозицию(ИДОперации); // Число
	УказательПогрешностьСмещения = УказательПогрешностьСмещения();
	// Параметры запроса
	РазмерПорцииНабора = РазмерПорцииНабораЗаписей();
	РазмерВыборкиЗапроса = РазмерПорцииНабора * КоэффициентРазмераВыборкиЗапроса();
	
	// очередь исходящих сообщений
	Очередь = кфкОбщегоНазначенияСлужебный.СоздатьНаборЗаписей(РегистрыСведений.кфкИсходящиеСообщения); // РегистрСведенийНаборЗаписей.кфкИсходящиеСообщения
	
	Пока Истина Цикл
		
		Если ПолучитьФункциональнуюОпцию("кфкБлокировкаИнтеграции") Тогда
			Прервать;
		КонецЕсли;
		
		Выборка = ВыборкаДублейИсходящихСообщений(РазмерВыборкиЗапроса, УказательНачалаВыборки);
		Если Выборка.Количество() = 0 Тогда
			
			// Указатель удаления
			УказательНачалаВыборки = УказательПустойВыборки();
			ОбновитьПозицию(ИДОперации, УказательНачалаВыборки);
			
			// пауза или завершение операции
			Если ПолучитьФункциональнуюОпцию("кфкИспользоватьПотоковыйРежим") Тогда
				ВызватьПаузу(5000);
			Иначе
				Прервать;
			КонецЕсли;
			
		Иначе
			
			ТекущаяДата = ТекущаяДатаСеанса();
			
			// обработка выборки
			Очередь.Очистить();
			Пока Выборка.Следующий() Цикл
				
				// Запись
				НоваяСтрока = Очередь.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
				НоваяСтрока.Статус = Перечисления.кфкСтатусыСообщений.ОбработкаОтменена;
				НоваяСтрока.ДатаОбработки = ТекущаяДата;
				НоваяСтрока.ТекстЖурнала = НСтр("ru = 'Дублирует с более поздней регистрацией.'");
				НоваяСтрока.МеткаИзмененияМС = ТекущаяУниверсальнаяДатаВМиллисекундах();
				
				УказательНачалаВыборки = Выборка.МеткаИзмененияМС - УказательПогрешностьСмещения;
				
				// Запись порции в БД
				Если Очередь.Количество() = РазмерПорцииНабора Тогда // РазмерПакета
					Очередь.Записать(РежимЗамещения.Обновление);
				КонецЕсли;
				
			КонецЦикла;
			
			// Запись в БД
			Если Очередь.Количество() > 0 Тогда
				Очередь.Записать(РежимЗамещения.Обновление);
			КонецЕсли;
			
			// Указатель удаления
			ОбновитьПозицию(ИДОперации, УказательНачалаВыборки);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Процедура ВозвратВОчередь() Экспорт
	
	// Указатель
	ИДОперации = ИДОперации_ВозвратВОчередь();
	УказательНачалаВыборки = ПолучитьПозицию(ИДОперации); // Число
	УказательПогрешностьСмещения = УказательПогрешностьСмещения();
	// Параметры запроса
	МаксКоличествоВыгрузок = 3; // Максимальное количество попыток отправки сообщения.
	РазмерПорцииНабора = РазмерПорцииНабораЗаписей();
	
	// очередь исходящих сообщений
	Очередь = кфкОбщегоНазначенияСлужебный.СоздатьНаборЗаписей(РегистрыСведений.кфкИсходящиеСообщения); // РегистрСведенийНаборЗаписей.кфкИсходящиеСообщения
	
	Пока Истина Цикл
		
		Если ПолучитьФункциональнуюОпцию("кфкБлокировкаИнтеграции") Тогда
			Прервать;
		КонецЕсли;
		
		Выборка = ВыборкаВозвратаВОчередь(РазмерПорцииНабора, УказательНачалаВыборки, МаксКоличествоВыгрузок);
		Если Выборка.Количество() = 0 Тогда
			
			// Указатель удаления
			УказательНачалаВыборки = УказательПустойВыборки();
			ОбновитьПозицию(ИДОперации, УказательНачалаВыборки);
			
			// завершение операции
			Прервать;
			
		Иначе
			
			// обработка выборки
			Пока Выборка.Следующий() Цикл
				
				НоваяСтрока = Очередь.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
				НоваяСтрока.Статус = Перечисления.кфкСтатусыСообщений.Обработано;
				НоваяСтрока.МеткаИзмененияМС = ТекущаяУниверсальнаяДатаВМиллисекундах();
				
				УказательНачалаВыборки = Выборка.МеткаИзмененияМС - УказательПогрешностьСмещения;
				
			КонецЦикла;
			// Запись в БД
			Очередь.Записать(РежимЗамещения.Обновление);
			
			// Указатель удаления
			ОбновитьПозицию(ИДОперации, УказательНачалаВыборки);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Контроль интеграции.
Процедура КонтрольИнтеграции() Экспорт
	
	Если Не ПолучитьФункциональнуюОпцию("кфкИспользоватьКонтрольИнтеграции") Тогда
		Возврат;
	КонецЕсли;
	
	Параметры = РегистрыСведений.кфкПараметрыКонтроляИнтеграции.ПолучитьПараметры();
	Если Параметры.ВремяSLAИсходящих + Параметры.ВремяSLAВходящих = 0
		Или ПустаяСтрока(Параметры.ИдентификаторЧатаТГ) Или ПустаяСтрока(Параметры.ТокенБотаТГ) Тогда
		Возврат;
	КонецЕсли;
	
	Показатели = КонтроляИнтеграцииПоказатели(Параметры);
	
	Тело = Новый Массив; // Массив Из Строка

//	Исходящие сообщения
	Если Показатели.НарушенSLAИсходящих Или Показатели.ОшибкиИсходящих Тогда
		
		//@skip-check bsl-nstr-string-literal-format
		Тело.Добавить(НСтр("ru = '*✈️ Исходящие сообщения:*   '"));
		
//		Нарушен SLA
		Если Показатели.НарушенSLAИсходящих Тогда
			Шаблон = НСтр("ru = '⏱ **Нарушен SLA -** %1 сообщений не завершили обработку или выгрузку более %2 минут'");
			Тело.Добавить(СтрШаблон(Шаблон, Показатели.НарушенSLAИсходящих, Параметры.ВремяSLAИсходящих));
		КонецЕсли;
		
//		Обнаружены ошибки
		Если Показатели.ОшибкиИсходящих Тогда
			Шаблон = НСтр("ru = '❌ **Обнаружены ошибки -** %1 сообщений завершились с ошибкой'");
			Тело.Добавить(СтрШаблон(Шаблон, Показатели.ОшибкиИсходящих));
		КонецЕсли;
		
	КонецЕсли;

//	Входящие сообщения
	Если Показатели.НарушенSLAВходящих Или Показатели.ОшибкиВходящих Тогда
		
		//@skip-check bsl-nstr-string-literal-format
		Тело.Добавить(НСтр("ru = '*📩 Входящие сообщения:*   '"));
		
//		Нарушен SLA
		Если Показатели.НарушенSLAВходящих Тогда
			Шаблон = НСтр("ru = '⏱ **Нарушен SLA -** %1 сообщений не завершили обработку более %2 минут'");
			Тело.Добавить(СтрШаблон(Шаблон, Показатели.НарушенSLAВходящих, Параметры.ВремяSLAВходящих));
		КонецЕсли;
		
//		Обнаружены ошибки
		Если Показатели.ОшибкиВходящих Тогда
			Шаблон = НСтр("ru = '❌ **Обнаружены ошибки -** %1 сообщений завершились с ошибкой'");
			Тело.Добавить(СтрШаблон(Шаблон, Показатели.ОшибкиВходящих));
		КонецЕсли;
		
	КонецЕсли;
	
	Если Тело.Количество() Тогда
		ТекстСообщения = СтрСоединить(Тело, Символы.ПС);
		ОповеститьОбОшибки(Параметры, ТекстСообщения);
	КонецЕсли;

КонецПроцедуры

#Область ОчисткаРегистров

// Очистка служебных таблиц
Процедура ОчисткаСлужебныхТаблиц() Экспорт
	
	// РС.ПозицииОпераций
	Выборка = ВыборкаПозицииОпераций();
	УдалитьЗаписиРС(Выборка, РегистрыСведений.кфкПозицииОпераций, Выборка.Количество());
	
	// РС.ОчередьПотоков
	Выборка = ВыборкаИдентификаторовПотока();
	Пока Выборка.Следующий() Цикл
		
		Задание = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(Выборка.ИдентификаторПотока);
		Если Задание <> Неопределено И Задание.Состояние = СостояниеФоновогоЗадания.Активно Тогда
			Продолжить;
		КонецЕсли;
		
		ОчиститьОчередьПотоков(Выборка.ИдентификаторПотока);
		
	КонецЦикла;
	
КонецПроцедуры

// Удаление устаревших исходящих сообщений.
Процедура УдалениеУстаревшихИсходящихСообщений() Экспорт
	
	ПараметрыОчистки = ПараметрыОчисткиХранилища();
	
	РазмерПорцииНабора = РазмерПорцииНабораЗаписей();
	РазмерВыборкиЗапроса = РазмерПорцииНабора * КоэффициентРазмераВыборкиЗапроса();
	
	Пока Истина Цикл
		
		Если ПолучитьФункциональнуюОпцию("кфкБлокировкаИнтеграции") Тогда
			Прервать;
		КонецЕсли;
		
		Выборка = ВыборкаУстаревшихИсходящихСообщений(ПараметрыОчистки, РазмерВыборкиЗапроса);
		Если Выборка.Количество() = 0 Тогда
			Прервать;
		КонецЕсли;
		
		КоличествоИтераций = Выборка.Количество() / РазмерПорцииНабора;
		Для Номер = 1 По КоличествоИтераций + ?(КоличествоИтераций = Цел(КоличествоИтераций), 0, 1) Цикл
			УдалитьЗаписиРС(Выборка, РегистрыСведений.кфкИсходящиеСообщения, РазмерПорцииНабора);
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

// Удаление устаревших входящих сообщений.
Процедура УдалениеУстаревшихВходящихСообщений() Экспорт
	
	ПараметрыОчистки = ПараметрыОчисткиХранилища();
	
	РазмерПорцииНабора = РазмерПорцииНабораЗаписей();
	РазмерВыборкиЗапроса = РазмерПорцииНабора * КоэффициентРазмераВыборкиЗапроса();
	
	Пока Истина Цикл
		
		Если ПолучитьФункциональнуюОпцию("кфкБлокировкаИнтеграции") Тогда
			Прервать;
		КонецЕсли;
		
		Выборка = ВыборкаУстаревшихВходящихСообщений(ПараметрыОчистки, РазмерВыборкиЗапроса);
		Если Выборка.Количество() = 0 Тогда
			Прервать;
		КонецЕсли;
	
		КоличествоИтераций = Выборка.Количество() / РазмерПорцииНабора;
		Для Номер = 1 По КоличествоИтераций + ?(КоличествоИтераций = Цел(КоличествоИтераций), 0, 1) Цикл
			УдалитьЗаписиРС(Выборка, РегистрыСведений.кфкВходящиеСообщения, РазмерПорцииНабора);
		КонецЦикла;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ВнешнееЛогирование

// Отправка исходящих логов во внешний сервис логирования
Процедура ВыгрузкаЛоговИсходящихСообщений() Экспорт
	
	Если Не ПолучитьФункциональнуюОпцию("кфкИспользоватьВнешнееЛогирование") Тогда
		Возврат;
	КонецЕсли;
	
	// Параметры логирования
	ПараметрыЛогирования = ПараметрыЛогирования();
	Если Не ПараметрыЛогирования.Использовать Или ПустаяСтрока(ПараметрыЛогирования.АдресСервиса) Тогда
		Возврат;
	КонецЕсли;
	
	// Коэффициент влияет на итоговый размер выборки
	//	1. ВыгружатьИсходныеДанные=ДА И ВыгружатьТело=ДА => 0.5 => 25%, т.е. 5т
	//	2. ВыгружатьИсходныеДанные=ДА ИЛИ ВыгружатьТело=ДА => 1.0 => 50%, т.е. 10т
	//	3. ИНАЧЕ = 2.0 => 100%, т.е. 20т
	Коэффициент = Макс(0.5,
		?(ПараметрыЛогирования.ВыгружатьИсходныеДанныеИсходящих, 0, 1)
		+ ?(ПараметрыЛогирования.ВыгружатьТелоСообщенияИсходящих, 0, 1));
	РазмерВыборкиЗапроса = РазмерПорцииНабораЗаписей() * КоэффициентРазмераВыборкиЗапроса() * Коэффициент;
	
	// Указатель начала выборки
	ИДОперации = ИДОперации_ВыгрузкаЛоговИсходящихСообщений();
	УказательНачалаВыборки = ПолучитьПозицию(ИДОперации);
	
	// Расшифровка настройки обмена
	Представления = ПредставленияПродюсеровИКонсьюмеров();
	
	// Сессия подключения к сервису логирования
	Сессия = Неопределено;
	
	Пока Истина Цикл
		
		Если ПолучитьФункциональнуюОпцию("кфкБлокировкаИнтеграции") Тогда
			Прервать;
		КонецЕсли;
		
		Выборка = ВыборкаЛоговИсходящихСообщений(РазмерВыборкиЗапроса, УказательНачалаВыборки);
		Если Выборка.Количество() = 0 Тогда
			
			// Если длительное время нет новых событий, то сбрасываем указатель до пустой выборки
			УказательПустойВыборки = УказательПустойВыборки();
			Если УказательНачалаВыборки < УказательПустойВыборки Тогда
				ОбновитьПозицию(ИДОперации, УказательПустойВыборки);
			КонецЕсли;
			
			// Завершаем цикл операции
			Прервать;
			
		КонецЕсли;
		
		// Отправка логов
		ОбработчикВыгрузкиЛоговИсходящихСообщений(Выборка, Представления, ПараметрыЛогирования, Сессия,
			УказательНачалаВыборки);
		
		// Сдвиг указателя
		ОбновитьПозицию(ИДОперации, УказательНачалаВыборки);
		
	КонецЦикла;
	
КонецПроцедуры

// Отправка входящих логов во внешний сервис логирования
Процедура ВыгрузкаЛоговВходящихСообщений() Экспорт
	
	Если Не ПолучитьФункциональнуюОпцию("кфкИспользоватьВнешнееЛогирование") Тогда
		Возврат;
	КонецЕсли;
	
	// Параметры логирования
	ПараметрыЛогирования = ПараметрыЛогирования();
	Если Не ПараметрыЛогирования.Использовать Или ПустаяСтрока(ПараметрыЛогирования.АдресСервиса) Тогда
		Возврат;
	КонецЕсли;
	
	// Коэффициент влияет на итоговый размер выборки
	//	1. ВыгружатьТело=ДА => 1 => 50%, т.е. 10т
	//	3. ИНАЧЕ = 2.0 => 100%, т.е. - 20т
	Коэффициент = ?(ПараметрыЛогирования.ВыгружатьТелоСообщенияВходящие, 1, 2);
	РазмерВыборкиЗапроса = РазмерПорцииНабораЗаписей() * КоэффициентРазмераВыборкиЗапроса() * Коэффициент;
	
	// Указатель начала выборки
	ИДОперации = ИДОперации_ВыгрузкаЛоговВходящихСообщений();
	УказательНачалаВыборки = ПолучитьПозицию(ИДОперации);
	
	// Расшифровка настройки обмена
	Представления = ПредставленияПродюсеровИКонсьюмеров();
	
	// Сессия подключения к сервису логирования
	Сессия = Неопределено;
	
	Пока Истина Цикл
		
		Если ПолучитьФункциональнуюОпцию("кфкБлокировкаИнтеграции") Тогда
			Прервать;
		КонецЕсли;
		
		Выборка = ВыборкаЛоговВходящихСообщений(РазмерВыборкиЗапроса, УказательНачалаВыборки);
		Если Выборка.Количество() = 0 Тогда
			
			// Если длительное время нет новых событий, то сбрасываем указатель до пустой выборки
			УказательПустойВыборки = УказательПустойВыборки();
			Если УказательНачалаВыборки < УказательПустойВыборки Тогда
				ОбновитьПозицию(ИДОперации, УказательПустойВыборки);
			КонецЕсли;
			
			// Завершаем цикл операции
			Прервать;
			
		КонецЕсли;
		
		// Отправка логов
		ОбработчикВыгрузкиЛоговВходящихСообщений(Выборка, Представления, ПараметрыЛогирования, Сессия,
			УказательНачалаВыборки);
		
		// Сдвиг указателя
		ОбновитьПозицию(ИДОперации, УказательНачалаВыборки);
		
	КонецЦикла;
	
КонецПроцедуры

