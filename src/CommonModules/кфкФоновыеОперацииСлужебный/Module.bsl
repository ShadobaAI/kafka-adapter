// Таблица распределения потоков.
// 
// Возвращаемое значение:
//  ТаблицаЗначений - Таблица распределения потоков:
//	 * Ссылка - СправочникСсылка.кфкПродюсеры, СправочникСсылка.кфкКонсьюмеры - Ссылка на диспетчер задач
//	 * Представление - Строка - Представление диспетчер задач
//	 * ПодпотокиОбработки - Число - Допустимое число вложенных потоков обработки
//	 * ПодпотокиТранспорта - Число - Допустимое число вложенных транспортных потоков
//	 * Настройка - СправочникСсылка.кфкПродюсеры, СправочникСсылка.кфкКонсьюмеры - Настройка
//	 * БлокироватьОбработку - Булево - Блокировать обработку
//	 * БлокироватьТранспорт - Булево - Блокировать транспорт
Функция ТаблицаРаспределенияПотоков()
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ЕСТЬNULL(ДиспетчерыЗадач.Ссылка, ЗНАЧЕНИЕ(Справочник.кфкПродюсеры.ПустаяСсылка)) КАК Ссылка,
	|	ЕСТЬNULL(ДиспетчерыЗадач.Представление, ""Общий поток"") КАК Представление,
	|	ЕСТЬNULL(ДиспетчерыЗадач.ПодпотокиОбработки, &МинКолПотоков) КАК ПодпотокиОбработки,
	|	ЕСТЬNULL(ДиспетчерыЗадач.ПодпотокиТранспорта, &МинКолПотоков) КАК ПодпотокиТранспорта,
	|	Таблица.Ссылка КАК Настройка,
	|	Таблица.БлокироватьСериализацию КАК БлокироватьОбработку,
	|	Таблица.БлокироватьПубликацию ИЛИ Брокеры.БлокироватьПубликацию КАК БлокироватьТранспорт
	|ИЗ
	|	Справочник.кфкПродюсеры КАК Таблица
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.кфкБрокеры КАК Брокеры
	|		ПО Таблица.Брокер = Брокеры.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.кфкПродюсеры КАК ДиспетчерыЗадач
	|		ПО Таблица.Родитель = ДиспетчерыЗадач.Ссылка
	|ГДЕ
	|	Таблица.ПометкаУдаления = ЛОЖЬ
	|	И Таблица.ЭтоГруппа = ЛОЖЬ
	|	И Брокеры.ПометкаУдаления = ЛОЖЬ
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЕСТЬNULL(ДиспетчерыЗадач.Ссылка, ЗНАЧЕНИЕ(Справочник.кфкКонсьюмеры.ПустаяСсылка)),
	|	ЕСТЬNULL(ДиспетчерыЗадач.Представление, ""Общий поток""),
	|	ЕСТЬNULL(ДиспетчерыЗадач.ПодпотокиОбработки, &МинКолПотоков),
	|	ЕСТЬNULL(ДиспетчерыЗадач.ПодпотокиТранспорта, &МинКолПотоков),
	|	Таблица.Ссылка,
	|	Таблица.БлокироватьДесериализацию,
	|	Таблица.БлокироватьЧтение ИЛИ Брокеры.БлокироватьЧтение
	|ИЗ
	|	Справочник.кфкКонсьюмеры КАК Таблица
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.кфкБрокеры КАК Брокеры
	|		ПО Таблица.Брокер = Брокеры.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.кфкКонсьюмеры КАК ДиспетчерыЗадач
	|		ПО Таблица.Родитель = ДиспетчерыЗадач.Ссылка
	|ГДЕ
	|	Таблица.ПометкаУдаления = ЛОЖЬ
	|	И Таблица.ЭтоГруппа = ЛОЖЬ
	|	И Брокеры.ПометкаУдаления = ЛОЖЬ";
	Запрос.УстановитьПараметр("МинКолПотоков", МинимальноеКоличествоПотоков());
	
	Таблица = Запрос.Выполнить().Выгрузить();
	Таблица.Индексы.Добавить("Ссылка");
	
	Возврат Таблица;
	
КонецФункции

