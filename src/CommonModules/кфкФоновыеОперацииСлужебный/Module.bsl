// Метод актуализирует список потоков и очищает очередь при неактивном состоянии.
// 
// Параметры:
//  Потоки - Массив Из УникальныйИдентификатор - Потоки
Процедура АктуализироватьПотоки(Потоки)
	
	Результат = Новый Массив; // Массив Из УникальныйИдентификатор
	
	Для Каждого Поток Из Потоки Цикл
		
		Задание = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(Поток);
		Если Задание <> Неопределено И Задание.Состояние = СостояниеФоновогоЗадания.Активно Тогда
			Результат.Добавить(Задание.УникальныйИдентификатор);
			
		Иначе
			ОчиститьОчередьПотоков(Поток);
			
		КонецЕсли;
		
	КонецЦикла;
	
	Потоки = Результат;
	
КонецПроцедуры

// Метод завершает все потоки и очищает их очереди.
// 
// Параметры:
//  Потоки - Массив Из УникальныйИдентификатор - Потоки
//	ОтменитьФЗ - Булево - Отменить ФЗ
Процедура ЗавершитьПотоки(Потоки, ОтменитьФЗ = Истина)
	
	Для Каждого Поток Из Потоки Цикл
		
		Если ОтменитьФЗ Тогда
			Задание = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(Поток);
			Если Задание <> Неопределено И Задание.Состояние = СостояниеФоновогоЗадания.Активно Тогда
				Задание.Отменить();
			КонецЕсли;
		КонецЕсли;
		
		ОчиститьОчередьПотоков(Поток);
		
	КонецЦикла;
		
КонецПроцедуры

#Область ОчередьПотоков

// Очистить очередь потоков.
// 
// Параметры:
//	Идентификатор - УникальныйИдентификатор - Идентификатор потока
Процедура ОчиститьОчередьПотоков(Идентификатор)
	
	Очередь = кфкОбщегоНазначенияСлужебный.СоздатьНаборЗаписей(РегистрыСведений.кфкОчередьПотоков); // РегистрСведенийНаборЗаписей.кфкОчередьПотоков
	Очередь.Отбор.ИдентификаторПотока.Установить(Идентификатор);
	Очередь.Записать();
	
КонецПроцедуры

// Ожидать завершения всех потоков.
// 
// Параметры:
//  Потоки - Массив Из УникальныйИдентификатор - Потоки
Процедура ОжидатьЗавершенияПотоков(Потоки)
	
	Пока Истина Цикл
		
		АктуализироватьПотоки(Потоки);
		Если Потоки.Количество() = 0 Тогда
			Прервать;
		КонецЕсли;
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1 ИСТИНА ИЗ РегистрСведений.кфкОчередьПотоков
		|	ГДЕ ИдентификаторПотока В (&Идентификаторы)";
		Запрос.УстановитьПараметр("Идентификаторы", Потоки);
		Если Запрос.Выполнить().Пустой() Тогда
			Прервать;
			
		Иначе
			ВызватьПаузу(5000);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Ожидать свободный потоки
// 
// Параметры:
//  Диспетчер - Структура - Диспетчер потоков, см. ОписаниеОперацииОбмена
//  Потоки - Массив Из УникальныйИдентификатор - Потоки
//  МаксПодпотоков - Число - Допустимое число вложенных потоков
//  
//  Параметры - Неопределено, Произвольный, Массив Из Произвольный - Параметры
// 
// Возвращаемое значение:
//  Массив Из УникальныйИдентификатор - Cвободные потоки
//
Функция ОжидатьСвободныеПотоки(Диспетчер, Потоки, МаксПодпотоков, Параметры)
	
	Если Параметры = Неопределено Тогда
		ПараметрыПотока = Неопределено;
		
	ИначеЕсли ТипЗнч(Параметры) = Тип("Массив") Тогда
		ПараметрыПотока = Параметры;
		
	Иначе
		ПараметрыПотока = ОбщегоНазначенияКлиентСервер.ЗначениеВМассиве(Параметры);
		
	КонецЕсли;
	
	Если Потоки.Количество() = 0 Тогда
		Задание = ЗапуститьПоток(Диспетчер, 1, ПараметрыПотока);
		Потоки.Добавить(Задание.УникальныйИдентификатор);
		Возврат Потоки;
		
	Иначе
		Пока Истина Цикл
			
			АктуализироватьПотоки(Потоки);
			
			Запрос = Новый Запрос;
			Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ ИдентификаторПотока ИЗ РегистрСведений.кфкОчередьПотоков
			|	ГДЕ ИдентификаторПотока В (&Идентификаторы)";
			Запрос.УстановитьПараметр("Идентификаторы", Потоки);
			АктивныеПотоки = кфкОбщегоНазначенияСлужебный.ВыбратьКолонку(Запрос.Выполнить().Выбрать(), "ИдентификаторПотока");
			СвободныеПотоки = ОбщегоНазначенияКлиентСервер.РазностьМассивов(Потоки, АктивныеПотоки);
			Если СвободныеПотоки.Количество() > 0 Тогда
				Возврат СвободныеПотоки;
				
			ИначеЕсли Потоки.Количество() < МаксПодпотоков Тогда
				Для НомерПотока = 1 По МаксПодпотоков Цикл
					
					Задание = ЗапуститьПоток(Диспетчер, НомерПотока, ПараметрыПотока);
					Если Потоки.Найти(Задание.УникальныйИдентификатор) = Неопределено Тогда // если новый поток
						
						Потоки.Добавить(Задание.УникальныйИдентификатор);
						СвободныеПотоки.Добавить(Задание.УникальныйИдентификатор);
						
						Прервать; // запускаем по одному
						
					КонецЕсли;
					
				КонецЦикла;
				Если СвободныеПотоки.Количество() = 0 Тогда
					ВызватьИсключение НСтр("ru = 'Не удалось запустить потоки.'");
				КонецЕсли;
				Возврат СвободныеПотоки;
				
			Иначе
				ВызватьПаузу(5000);
			
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецФункции

#КонецОбласти

#Область Указатели

// Получить позицию.
// 
// Параметры:
//  Идентификатор - УникальныйИдентификатор - Идентификатор операции
//  Раздел - Строка - Дополнительный раздел операции
// 
// Возвращаемое значение:
//  Число - Временная метка
Функция ПолучитьПозицию(Идентификатор, Раздел = "")
	Возврат РегистрыСведений.кфкПозицииОпераций.ПолучитьПозицию(Идентификатор, Раздел);
КонецФункции

// Обновить позиции.
// 
// Параметры:
//	Идентификатор - УникальныйИдентификатор - Идентификатор операции
//	ВременнаяМетка - Число - Временная метка
//	Раздел - Неопределено, Структура - Дополнительный раздел операции:
//		* Значение - Строка - Идентификатор раздела
//		* Представление - Строка - Представление раздела
Процедура ОбновитьПозицию(Идентификатор, ВременнаяМетка, Раздел = Неопределено)
	РегистрыСведений.кфкПозицииОпераций.ОбновитьПозицию(Идентификатор, ВременнаяМетка, Раздел);
КонецПроцедуры

// Вычисляет хеш-сумму настроек.
//
// Параметры:
//	Настройки - Массив Из СправочникСсылка.кфкПродюсеры - настройки, для которых вычисляется хеш-сумма
//
// Возвращаемое значение:
//	Строка - хеш-сумма настроек в шестнадцатеричном формате
Функция ПолучитьРазделОперации(Настройки)
	
	Результат = Новый Структура("Значение,Представление", "", "");
	
	// Хеш-сумма настроек
	Список = Новый СписокЗначений; // СписокЗначений Из Строка
	Для Каждого Настройка Из Настройки Цикл
		Список.Добавить(XMLСтрока(Настройка));
	КонецЦикла;
	Список.СортироватьПоЗначению();
	Хеш = Новый ХешированиеДанных(ХешФункция.SHA256);
	Для Каждого Элемент Из Список Цикл
		Хеш.Добавить(Элемент.Значение);
	КонецЦикла;
	Результат.Значение = ПолучитьHexСтрокуИзДвоичныхДанных(Хеш.ХешСумма);
	
	// Представление настроек
	//@skip-check bsl-legacy-check-string-literal
	Реквизиты = ОбщегоНазначения.ЗначениеРеквизитаОбъектов(Настройки, "Представление");
	Представления = ОбщегоНазначения.ВыгрузитьКолонку(Реквизиты, "Значение");
	Результат.Представление = СтрСоединить(Представления, "|");
	
	Возврат Результат;
	
КонецФункции

// Создает пустую таблицу состояния потоков.
//
// Возвращаемое значение:
//	ТаблицаЗначений - пустую таблицу указателей:
//	 * ИдентификаторПотока - УникальныйИдентификатор - Идентификатор потока
//	 * СтатусПотока - Число - Статус потока
//	 * ВременнаяМетка - Число - Временная метка
//
Функция ПустаяТаблицаУказателейПотоков()
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("ИдентификаторПотока", Новый ОписаниеТипов("УникальныйИдентификатор"));
	Результат.Колонки.Добавить("СтатусПотока", ОбщегоНазначения.ОписаниеТипаЧисло(1, 0, ДопустимыйЗнак.Любой));
	Результат.Колонки.Добавить("ВременнаяМетка", ОбщегоНазначения.ОписаниеТипаЧисло(15, 0, ДопустимыйЗнак.Неотрицательный));
	
	Результат.Индексы.Добавить("ИдентификаторПотока");
	
	Возврат Результат;
	
КонецФункции

// Указатель погрешность смещения.
// 
// Возвращаемое значение:
//  Число - Указатель погрешность смещения
Функция УказательПогрешностьСмещения()
	Возврат 900000; // 15 минуту ждем появления новых данных
КонецФункции

// Указатель пустого запроса.
// 
// Возвращаемое значение:
//  Число - Указатель пустого запроса
Функция УказательПустойВыборки()
	Возврат ТекущаяУниверсальнаяДатаВМиллисекундах() - УказательПогрешностьСмещения(); // 15 минуту ждем появления новых данных
КонецФункции

// Добавить указатель потока.
// 
// Параметры:
//	Указатели - ТаблицаЗначений - Указатели, см. ПустаяТаблицаУказателейПотоков:
//	 * ИдентификаторПотока - УникальныйИдентификатор - Идентификатор потока
//	 * СтатусПотока - Число - Статус потока
//	 * ВременнаяМетка - Число - Временная метка
//	ИдентификаторПотока - УникальныйИдентификатор - Идентификатор потока
//	ВременнаяМетка - Число - Временная метка
Процедура ДобавитьУказательПотока(Указатели, ИдентификаторПотока, ВременнаяМетка)
	
	НоваяСтрока = Указатели.Добавить();
	НоваяСтрока.ИдентификаторПотока = ИдентификаторПотока;
	НоваяСтрока.ВременнаяМетка = ВременнаяМетка;
	
КонецПроцедуры

// Устанавливает статус 'завершено' указателей, см. ОбновитьУказательНачалаВыборки
// 
// Параметры:
//  Указатели - ТаблицаЗначений - указатели потоков, см. ПустаяТаблицаСостоянияПотоков:
//	 * ИдентификаторПотока - УникальныйИдентификатор - Идентификатор потока
//	 * СтатусПотока - Число - Статус потока
//	 * ВременнаяМетка - Число - Временная метка
//	ЗавершенныеПотоки - Массив Из УникальныйИдентификатор - Активные потоки
Процедура ЗафиксироватьУказатели(Указатели, ЗавершенныеПотоки)
	
	Если Указатели.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Поток Из ЗавершенныеПотоки Цикл
		Для Каждого Строка Из Указатели.НайтиСтроки(Новый Структура("ИдентификаторПотока", Поток)) Цикл
			Если Строка.СтатусПотока = 0 Тогда
				Строка.СтатусПотока = 1;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
КонецПроцедуры

// Обновить статус указателей.
// 
// Параметры:
//  УказателиПотоков - ТаблицаЗначений - указатели потоков, см. ПустаяТаблицаСостоянияПотоков:
//	 * ИдентификаторПотока - УникальныйИдентификатор - Идентификатор потока
//	 * СтатусПотока - Число - Статус потока
//	 * ВременнаяМетка - Число - Временная метка
//	Потоки - Массив Из УникальныйИдентификатор - Потоки
Процедура ОбновитьСтатусУказателей(УказателиПотоков, Потоки)
	
	Если УказателиПотоков.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ ИдентификаторПотока ИЗ РегистрСведений.кфкОчередьПотоков
	|	ГДЕ ИдентификаторПотока В (&Идентификаторы)";
	Запрос.УстановитьПараметр("Идентификаторы", Потоки);
	АктивныеПотоки = кфкОбщегоНазначенияСлужебный.ВыбратьКолонку(Запрос.Выполнить().Выбрать(), "ИдентификаторПотока");
	ЗавершенныеПотоки = ОбщегоНазначенияКлиентСервер.РазностьМассивов(Потоки, АктивныеПотоки);
	
	ЗафиксироватьУказатели(УказателиПотоков, ЗавершенныеПотоки);

КонецПроцедуры

// Обновляет указатели начала выборки.
//
// Параметры:
//	УказательНачалаВыборки - Число - Указатель начала выборки данных
//	УказателиПотоков - ТаблицаЗначений - указатели потоков, см. ПустаяТаблицаСостоянияПотоков:
//	 * ИдентификаторПотока - УникальныйИдентификатор - Идентификатор потока
//	 * СтатусПотока - Число - Статус потока
//	 * ВременнаяМетка - Число - Временная метка
//	УказательПустойВыборки - Число - Указатель пустой выборки
//	Потоки - Массив Из УникальныйИдентификатор - Активныеотоки
//	ИДОперации - УникальныйИдентификатор - ИД операции
//	РазделОперации - Неопределено, Структура - Дополнительный раздел операции:
//		* Значение - Строка - Идентификатор раздела
//		* Представление - Строка - Представление раздела
// 
Процедура ОбновитьУказательНачалаВыборки(УказательНачалаВыборки, УказателиПотоков, УказательПустойВыборки, Потоки,
		ИДОперации, РазделОперации)
	
	Если УказателиПотоков.Количество() = 0 Тогда
		УказательНачалаВыборки = Макс(УказательНачалаВыборки, УказательПустойВыборки);
		ОбновитьПозицию(ИДОперации, УказательНачалаВыборки, РазделОперации);
		
	Иначе
		КУдалению = Новый Массив; // Массив Из СтрокаТаблицыЗначений
		УказателиПотоков.Сортировать("ВременнаяМетка");
		
		МинСтатус = 1;
		НовыйУказатель = Ложь;
		
		Для Каждого Строка Из УказателиПотоков Цикл
			
			Если Строка.СтатусПотока = 0 И Потоки.Найти(Строка.ИдентификаторПотока) = Неопределено Тогда
				Строка.СтатусПотока = -1;
				КУдалению.Добавить(Строка); // сразу удаляем
			КонецЕсли;
			
			МинСтатус = Мин(МинСтатус, Строка.СтатусПотока);
			Если МинСтатус = 1 Тогда
				НовыйУказатель = Истина;
				УказательНачалаВыборки = Строка.ВременнаяМетка;
				КУдалению.Добавить(Строка); // пакет обработан и учтен, можно удалить
			КонецЕсли;
			
		КонецЦикла;
		
		Для Каждого Строка Из КУдалению Цикл
			УказателиПотоков.Удалить(Строка);
		КонецЦикла;
		
		Если НовыйУказатель Тогда
			УказательНачалаВыборки = УказательНачалаВыборки - УказательПогрешностьСмещения();
			ОбновитьПозицию(ИДОперации, УказательНачалаВыборки, РазделОперации);
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СериализацияСообщений

// Выборка сериализации сообщений. см. СериализацияСообщений
//
// Параметры:
//  Продюсеры - Массив Из СправочникСсылка.кфкПродюсеры - Продюсеры
//  Количество - Число - Количество записей
//  МеткаИзмененияМС - Число - Указатель начала выборки данных
// 
// Возвращаемое значение:
//  ВыборкаИзРезультатаЗапроса - Выборка исходящих сообщений:
//	* КлючЗаписи - Строка - Владелец сообщения
//	* ДатаРегистрацииМС - Число - Дата регистрации (мс)
//	* МеткаИзмененияМС - Число - Последнее изменение (мс)
Функция ВыборкаСериализацииСообщений(Продюсеры, Количество, МеткаИзмененияМС)
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаОбработкаИсходящихСообщений(Количество);
	Запрос.УстановитьПараметр("Продюсеры", Продюсеры);
	Запрос.УстановитьПараметр("Статус", Перечисления.кфкСтатусыСообщений.Новое);
	Запрос.УстановитьПараметр("МеткаИзмененияМС", МеткаИзмененияМС);
	
	Возврат Запрос.Выполнить().Выбрать();
	
КонецФункции

// Выборка сериализация сообщений. см. СериализацияСообщений
//
// Параметры:
//  ИдентификаторПотока - УникальныйИдентификатор - Идентификатор потока
//  Количество - Число - Количество записей
// 
// Возвращаемое значение:
//  ВыборкаИзРезультатаЗапроса - Выборка исходящих сообщений:
//  * КлючЗаписи - Строка - Владелец сообщения
//  * ДатаРегистрацииМС - Число - Дата регистрации (мс)
//  * ИсходныеДанные - ХранилищеЗначения - Исходные данные
//	* ЭтоУдаление - Булево - Это удаление
//	* Продюсер - СправочникСсылка.кфкПродюсеры - Продюсер
//	* ТипОбъект - Строка - Тип объекта
//	* ТипИсходныхДанных - Строка - Тип исходных данных
//	* КлючОбъекта - Строка - Ключ записи
//	* СобытиеРегистрации - ПеречислениеСсылка.кфкСобытияРегистрации - Событие регистрации
//	* ДатаРегистрации - Дата - Дата регистрации
//	* ДатаОбработки - Дата - Дата обработки
//	* ТекстЖурнала - Строка - Текст журнала
//	* КоличествоОбработок - Число - Количество обработок
//	* КоличествоВыгрузок - Число - Количество выгрузок
Функция ВыборкаСериализацияСообщенийВПотоке(ИдентификаторПотока, Количество)
	
	ТекстЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1000
	|	Т.КлючЗаписи КАК КлючЗаписи,
	|	Т.ДатаРегистрацииМС КАК ДатаРегистрацииМС,
	|	Т.ИсходныеДанные КАК ИсходныеДанные,
	|	Т.ЭтоУдаление КАК ЭтоУдаление,
	|	Т.Продюсер КАК Продюсер,
	|	Т.ТипОбъект КАК ТипОбъект,
	|	Т.ТипИсходныхДанных КАК ТипИсходныхДанных,
	|	Т.КлючОбъекта КАК КлючОбъекта,
	|	Т.СобытиеРегистрации КАК СобытиеРегистрации,
	|	Т.ДатаРегистрации КАК ДатаРегистрации,
	|	Т.ДатаОбработки КАК ДатаОбработки,
	|	Т.ТекстЖурнала КАК ТекстЖурнала,
	|	Т.КоличествоОбработок КАК КоличествоОбработок,
	|	Т.КоличествоВыгрузок КАК КоличествоВыгрузок
	|ИЗ
	|	РегистрСведений.кфкИсходящиеСообщения КАК Т
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.кфкОчередьПотоков КАК ОП
	|		ПО Т.КлючЗаписи = ОП.Ключ
	|		И Т.ДатаРегистрацииМС = ОП.ВременнаяМетка
	|		И ОП.ИдентификаторПотока = &ИдентификаторПотока
	|
	|УПОРЯДОЧИТЬ ПО
	|	Т.МеткаИзмененияМС";
	
	Запрос = Новый Запрос;
	Запрос.Текст = СтрЗаменить(ТекстЗапроса, "1000", XMLСтрока(Количество));
	Запрос.УстановитьПараметр("ИдентификаторПотока", ИдентификаторПотока);
	
	Возврат Запрос.Выполнить().Выбрать();
	
КонецФункции

Процедура ОбработчикСериализацииСообщений(Выборка, Очереди, ИдентификаторПотока, Правила)
	
	Очередь = НоваяОчередь(Очереди);
	ОчередьПотока = НоваяОчередьПотока(Очереди);
	
	Пока Выборка.Следующий() Цикл
		
		// Инициализация переменных сообщения
		Ключ = "";
		Заголовки = Неопределено;
		Тело = Неопределено;
		// Инициализация переменных журнала
		ТекстЖурнала = "";
		ДлительностьОбработки = 0;
		Статус = Перечисления.кфкСтатусыСообщений.ОшибкаОбработки;
		
		// Применение правил сериализации
		Правило = Правила.Получить(НРег(XMLСтрока(Выборка.Продюсер) + Выборка.ТипОбъект)); // см. НовоеОписаниеПравилОбмена
		Если Правило = Неопределено Тогда
			Статус = Перечисления.кфкСтатусыСообщений.ОшибкаОбработки;
			ТекстЖурнала = НСтр("ru = 'Не задан тип сериализации!'");
			
		Иначе
			Попытка
				
				// Инициализация переменных обработки
				Отказ = Ложь;
				Данные = Неопределено; // Неопределено, СправочникОбъектИмяСправочника, ДокументОбъектИмяДокумента
				Сообщение = Неопределено; // Неопределено, Структура - см. кфкИнтеграция.ПараметрыСообщения
				
				СвойстваСообщений = СвойстваСериализацииСообщений(Выборка);
				ИсходныеДанные = кфкОбщегоНазначенияСлужебный.ЗначениеИзХранилища(Выборка.ИсходныеДанные);
				ДопСвойства = Неопределено;
				Если ТипЗнч(ИсходныеДанные) = Тип("Структура") И ИсходныеДанные.Количество() = 2
					И ИсходныеДанные.Свойство("Данные", Данные) И ИсходныеДанные.Свойство("ДополнительныеСвойства", ДопСвойства) Тогда
					Если ТипЗнч(ДопСвойства) = Тип("Структура") И ДопСвойства.Количество() > 0 Тогда
						ОбщегоНазначенияКлиентСервер.ДополнитьСтруктуру(Данные.ДополнительныеСвойства, ДопСвойства, Истина);
					КонецЕсли;
					
				Иначе
					Данные = ИсходныеДанные;
				КонецЕсли;
				
				// Выполнение обработчика
				Если Правило.Тип = Перечисления.кфкТипыОбработчиков.ПроизвольныйОбработчик Тогда
					Сообщение = ВыполнитьПроизвольныйОбработчикСериализации(Правило, Данные, СвойстваСообщений,
						ДлительностьОбработки, ТекстЖурнала, Отказ);
					
				ИначеЕсли Правило.Тип = Перечисления.кфкТипыОбработчиков.КонвертацияДанных Тогда
					Сообщение = ВыполнитьКДОбработчикСериализации(Правило, Данные, СвойстваСообщений,
						ДлительностьОбработки, ТекстЖурнала, Отказ);
					
				Иначе
					Статус = Перечисления.кфкСтатусыСообщений.ОшибкаОбработки;
					ТекстЖурнала = НСтр("ru = 'Не задан тип сериализации!'");
					
				КонецЕсли;
				
				// Результат обработки
				Если Отказ = Истина Тогда // Отказ
					Статус = Перечисления.кфкСтатусыСообщений.ОбработкаОтменена;
					
				ИначеЕсли Сообщение = Неопределено Тогда // Ошибка
					Статус = Перечисления.кфкСтатусыСообщений.ОшибкаОбработки;
					
				Иначе // ОК
					// Статус
					Статус = Перечисления.кфкСтатусыСообщений.Обработано;
					// Заголовки
					Заголовки = кфкОбщегоНазначенияСлужебный.ЗначениеВХранилище(Сообщение.Заголовки);
					// Тело
					Данные = кфкИнтеграцияСлужебный.ТелоСообщения(Сообщение, ТекстЖурнала); // Неопределено, Строка, ДвоичныеДанные
					Если Данные = Неопределено Тогда
						Статус = Перечисления.кфкСтатусыСообщений.ОшибкаОбработки;
					Иначе
						Тело = кфкОбщегоНазначенияСлужебный.ЗначениеВХранилище(Данные);
					КонецЕсли;
					// КлючСообщения
					Ключ = Сообщение.Ключ;
					
				КонецЕсли;
				
			Исключение
				
				Сообщение = Неопределено;
				ТекстЖурнала = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
				Отказ = Ложь;
				
			КонецПопытки;
			
		КонецЕсли;
		
		// Запись
		НоваяСтрока = Очередь.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		НоваяСтрока.Статус = Статус;
		НоваяСтрока.КлючСообщения = Ключ;
		НоваяСтрока.Заголовки = Заголовки;
		НоваяСтрока.ТелоСообщения = Тело;
		НоваяСтрока.ДатаОбработки = ТекущаяДатаСеанса();
		НоваяСтрока.ДлОбработкиМС = ДлительностьОбработки;
		НоваяСтрока.КоличествоОбработок = НоваяСтрока.КоличествоОбработок + 1;
//		НоваяСтрока.ДатаВыгрузки = Неопределено;
		НоваяСтрока.ТекстЖурнала = ДополнитьТекстЖурнала(Выборка.ТекстЖурнала, ТекстЖурнала);
		НоваяСтрока.МеткаИзмененияМС = ТекущаяУниверсальнаяДатаВМиллисекундах();
		
		НоваяСтрока = ОчередьПотока.Добавить();
		НоваяСтрока.Ключ = Выборка.КлючЗаписи;
		НоваяСтрока.ВременнаяМетка = Выборка.ДатаРегистрацииМС;
		НоваяСтрока.ИдентификаторПотока = ИдентификаторПотока;
		
	КонецЦикла;
	
	// Если разница между первой и последней меткой изменений больше 2 секунд, то обновляем все метки изменений
	Если Очередь[Очередь.Количество()-1].МеткаИзмененияМС - Очередь[0].МеткаИзмененияМС > 2000 Тогда
		ТекущаяДатаМС = ТекущаяУниверсальнаяДатаВМиллисекундах();
		Для Каждого Строка Из Очередь Цикл
			Строка.МеткаИзмененияМС = ТекущаяДатаМС;
		КонецЦикла;
	КонецЕсли;
	
//	Запись в БД
	Очередь.Записать(РежимЗамещения.Обновление);
	ОчередьПотока.Записать(РежимЗамещения.Удаление);
	
КонецПроцедуры

// Свойства сериализации сообщений. см. СериализацияСообщений
// 
// Параметры:
//  Выборка - ВыборкаИзРезультатаЗапроса - Выборка исходящих сообщений. см. ВыборкаСериализацииСообщений.
// 
// Возвращаемое значение:
//  Структура - Свойства сериализации сообщений:
// * Продюсер - СправочникСсылка.кфкПродюсеры - Продюсер
// * ТипОбъект - Строка - Тип объект
// * ТипИсходныхДанных - Строка - Тип исходных данных
// * СобытиеРегистрации - ПеречислениеСсылка.кфкСобытияРегистрации - Событие регистрации
// * КлючРегистрации - Строка - Ключ регистрации
// * ДатаРегистрации - Дата - Дата регистрации
// * ДатаРегистрацииМС - Число - Дата регистрации в миллисекундах
// * ПоследняяОбработка - Дата - Последняя обработка
// * ЭтоУдаление - Булево - Это удаление
// * СсылкаНаОбъект - Неопределено, ЛюбаяСсылка - Ссылка на объект регистрации
Функция СвойстваСериализацииСообщений(Выборка)
	
	Результат = Новый Структура;
	Результат.Вставить("Продюсер", Выборка.Продюсер);
	Результат.Вставить("ТипОбъект", Выборка.ТипОбъект);
	Результат.Вставить("ТипИсходныхДанных", Выборка.ТипИсходныхДанных);
	Результат.Вставить("СобытиеРегистрации", Выборка.СобытиеРегистрации);
	Результат.Вставить("КлючРегистрации", Выборка.КлючЗаписи);
	Результат.Вставить("ДатаРегистрации", Выборка.ДатаРегистрации);
	Результат.Вставить("ДатаРегистрацииМС", Выборка.ДатаРегистрацииМС);
	Результат.Вставить("ПоследняяОбработка", Выборка.ДатаОбработки);
	Результат.Вставить("ЭтоУдаление", Выборка.ЭтоУдаление);
	
	ТипОбъект = СтрЗаменитьПоРегулярномуВыражению(Выборка.ТипИсходныхДанных, "(Object|Ref|RecordSet)\.", ".", Истина);
	ОбъектМД = ОбщегоНазначения.ОбъектМетаданныхПоПолномуИмени(ТипОбъект);
	Если СтроковыеФункцииКлиентСервер.ЭтоУникальныйИдентификатор(Выборка.КлючОбъекта)
			И Не ОбщегоНазначения.ЭтоРегистр(ОбъектМД) Тогда
		
		Менеджер = ОбщегоНазначения.МенеджерОбъектаПоПолномуИмени(ОбъектМД.ПолноеИмя());
		СсылкаНаОбъект = Менеджер.ПолучитьСсылку(Новый УникальныйИдентификатор(Выборка.КлючОбъекта));
		Результат.Вставить("СсылкаНаОбъект", СсылкаНаОбъект);
		
	Иначе
		Результат.Вставить("СсылкаНаОбъект", Неопределено);
		
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ВыполнитьПроизвольныйОбработчикСериализации(Правило, Данные, СвойстваСообщений, ДлительностьОбработки,
		ТекстЖурнала, Отказ)
	
	Если ПустаяСтрока(Правило.ИмяМетода) Тогда
		ТекстЖурнала = НСтр("ru = 'Не задан метод сериализации!'");
		Возврат Неопределено;
	КонецЕсли;
	
	ПараметрыСериализации = Новый Массив(4); // Массив Из Неопределено, СправочникСсылка, Структура, Строка, Булево
	ПараметрыСериализации[0] = Данные;
	ПараметрыСериализации[1] = СвойстваСообщений;
	ПараметрыСериализации[2] = "";
	ПараметрыСериализации[3] = Ложь;

	НачалоОбработки = ТекущаяУниверсальнаяДатаВМиллисекундах();
	// TODO: ОбщегоНазначения.ВыполнитьМетодОбъекта с БСП 3.1.11
	Сообщение = ОбщегоНазначения.ВызватьФункциюКонфигурации(Правило.ИмяМетода, ПараметрыСериализации); // см. кфкИнтеграция.ПараметрыСообщения
	ДлительностьОбработки = ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоОбработки;

	ТекстЖурнала = ПараметрыСериализации[2];
	Отказ = ПараметрыСериализации[3];
	
	Возврат Сообщение;
	
КонецФункции

Функция ВыполнитьКДОбработчикСериализации(Правило, Данные, СвойстваСообщений, ДлительностьОбработки, ТекстЖурнала, Отказ)
	
	Перем Регистратор; // ЛюбаяСсылка
	
	КомпонентыОбмена = Правило.КомпонентыОбмена; // Неопределено, Структура - см. кфкОбменДаннымиXDTOСервер.ИнициализироватьКомпонентыОбмена
	Если Правило.КомпонентыОбмена = Неопределено Тогда
		
		Если ПустаяСтрока(Правило.Формат) Или ПустаяСтрока(Правило.ИмяМодуля) Или ПустаяСтрока(Правило.ИмяПОД) Тогда
			ТекстЖурнала = НСтр("ru = 'Ошибка инициализации компонентов обмена. Не заполнены обязательные поля.'");
			Возврат Неопределено;
		КонецЕсли;
		
		КомпонентыОбмена = кфкОбменДаннымиXDTOСервер.ИнициализироватьКомпонентыОбмена("Отправка"); // Структура
		КомпонентыОбмена.XMLСхема = Правило.Формат;
		КомпонентыОбмена.МенеджерОбмена = ОбщегоНазначения.ОбщийМодуль(Правило.ИмяМодуля);
		кфкОбменДаннымиXDTOСервер.ИнициализироватьТаблицыПравилОбмена(КомпонентыОбмена);
		
		Правило.КомпонентыОбмена = КомпонентыОбмена;
		
	КонецЕсли;
	
	КомпонентыОбмена.КлючСообщения = "";
	КомпонентыОбмена.СвойстваСообщения = СвойстваСообщений;
	КомпонентыОбмена.ЗаголовкиСообщения.Очистить();
	
	ТелоСообщения = Новый Массив; // Структура, Массив Из Структура
	
	НачалоОбработки = ТекущаяУниверсальнаяДатаВМиллисекундах(); // Начало замера сериализации
	
	ИмяБазовогоТипа = СтрРазделить(СвойстваСообщений.ТипИсходныхДанных, ".")[0];
	Если (ИмяБазовогоТипа = "InformationRegisterRecordSet" // регистр сведений 
			Или ИмяБазовогоТипа = "AccumulationRegisterRecordSet" // регистр накопления
			Или ИмяБазовогоТипа = "AccountingRegisterRecordSet" // регистр бухгалтерии
			Или ИмяБазовогоТипа = "CalculationRegisterRecordSet") // регистр расчета
		И ТипЗнч(Данные) = Тип("Структура") И Данные.Свойство("Регистратор", Регистратор)
			И Данные.Свойство("ДополнительныеСвойства") Тогда 
		
		// Получаем все записи регистра по регистратору
		Запрос = Новый Запрос(СтрШаблон("ВЫБРАТЬ * ИЗ %1 ГДЕ Регистратор = &Регистратор", СвойстваСообщений.ТипОбъект));
		Запрос.УстановитьПараметр("Регистратор", Регистратор);
		Выборка = Запрос.Выполнить().Выбрать();
		
		// Колонки регистра
		ПоляЗаписи = СтрСоединить(ОбщегоНазначения.ВыгрузитьКолонку(Выборка.Владелец().Колонки, "Имя"), ",");
		
		// Перебираем записи регистра
		Пока Выборка.Следующий() Цикл
			
			// Формируем запись регистра
			Запись = Новый Структура(ПоляЗаписи);
			ЗаполнитьЗначенияСвойств(Запись, Выборка);
			
			// Конвертируем запись в формат обмена 
			Результат = кфкОбменДаннымиXDTOСервер.ПроизвестиВыгрузкуДанных(КомпонентыОбмена, Запись, Правило.ИмяПОД);
			Если КомпонентыОбмена.ФлагПропустить Тогда
				Продолжить;
				
			ИначеЕсли КомпонентыОбмена.ФлагОшибки Тогда
				Прервать;
				
			КонецЕсли;
			
			// Добавляем запись в тело сообщения
			ТелоСообщения.Добавить(Результат);
			
		КонецЦикла;
		
	Иначе // Ссылочный объект/независимый регистр/произвольное сообщение
		ТелоСообщения = кфкОбменДаннымиXDTOСервер.ПроизвестиВыгрузкуДанных(КомпонентыОбмена, Данные, Правило.ИмяПОД); // Структура
		
	КонецЕсли;
	
	ДлительностьОбработки = ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоОбработки; // Фиксируруем замер сериализации
	
	// Обработка результата
	Отказ = КомпонентыОбмена.ФлагПропустить;
	ТекстЖурнала = СтрСоединить(КомпонентыОбмена.ПротоколКонвертации, "
		|- - - - - - - - - - - - - - - - - - - - - - - - -
		|");
	Если КомпонентыОбмена.ФлагОшибки Или КомпонентыОбмена.ФлагПропустить Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	Сообщение = кфкИнтеграция.ПараметрыСообщения();
	Сообщение.Данные = ТелоСообщения;
	Сообщение.Ключ = КомпонентыОбмена.КлючСообщения;
	Сообщение.Заголовки = КомпонентыОбмена.ЗаголовкиСообщения;
	
	Возврат Сообщение;
	
КонецФункции

#КонецОбласти

#Область ВыгрузкаСообщений

Функция ИспользоватьПакетнуюПубликацию(Продюсеры)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ МИНИМУМ(ЕСТЬNULL(Т2.ИспользоватьПакетнуюПубликацию, ЛОЖЬ))
	|ИЗ
	|	Справочник.кфкПродюсеры КАК Т1
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.кфкПродюсеры КАК Т2
	|		ПО Т1.Родитель = Т2.Ссылка
	|ГДЕ
	|	Т1.Ссылка В (&Продюсеры)";
	Запрос.УстановитьПараметр("Продюсеры", Продюсеры);
	Выборка = Запрос.Выполнить().Выбрать();
	
	Возврат ?(Выборка.Следующий(), Выборка[0], Ложь);
	
КонецФункции

// Выборка отправки данных исходящих сообщений. см. ОтправкаСообщенийВKafka
// 
// Параметры:
//  Продюсеры - Массив Из СправочникСсылка.кфкПродюсеры - Продюсеры
//  Количество - Число - Количество записей
//  МеткаИзмененияМС - Число - Указатель начала выборки данных
//
// Возвращаемое значение:
//  ВыборкаИзРезультатаЗапроса - Выборка исходящих сообщений:
//	* КлючЗаписи - Строка - Владелец сообщения
//	* ДатаРегистрацииМС - Число - Дата регистрации (мс)
//	* МеткаИзмененияМС - Число - Последнее изменение (мс)
Функция ВыборкаОтправкиИсходящихСообщений(Продюсеры, Количество, МеткаИзмененияМС)
	
	Запрос = Новый Запрос;
	Запрос.Текст = ТекстЗапросаОбработкаИсходящихСообщений(Количество);
	Запрос.УстановитьПараметр("Продюсеры", Продюсеры);
	Запрос.УстановитьПараметр("Статус", Перечисления.кфкСтатусыСообщений.Обработано);
	Запрос.УстановитьПараметр("МеткаИзмененияМС", МеткаИзмененияМС);
	
	Возврат Запрос.Выполнить().Выбрать();
	
КонецФункции

// Выборка отправки данных исходящих сообщений. см. ОтправкаСообщенийВKafka
// 
// Параметры:
//	ИдентификаторПотока - УникальныйИдентификатор - Идентификатор потока
//	Количество - Число - Количество записей
//	ПакетнаяПубликация - Булево - Использовать пакетную публикацию
//
// Возвращаемое значение:
//  ВыборкаИзРезультатаЗапроса - Выборка исходящих сообщений:
//  * КлючЗаписи - Строка - Владелец сообщения
//  * ДатаРегистрацииМС - Число - Дата регистрации (мс)
//  * ИсходныеДанные - ХранилищеЗначения - Исходные данные
//	* ЭтоУдаление - Булево - Это удаление
//	* КлючСообщения - Строка - Ключ сообщения
//	* Заголовки - ХранилищеЗначения - Исходные данные
//	* ТелоСообщения - ХранилищеЗначения - Исходные данные
//	* Продюсер - СправочникСсылка.кфкПродюсеры - Продюсер
//	* ТипОбъект - Строка - Тип объекта
//	* ТипИсходныхДанных - Строка - Тип исходных данных
//	* КлючОбъекта - Строка - Ключ записи
//	* СобытиеРегистрации - ПеречислениеСсылка.кфкСобытияРегистрации - Событие регистрации
//	* ДатаРегистрации - Дата - Дата регистрация
//	* ДатаОбработки - Дата - Дата обработки
//	* ДлОбработкиМС - Число - Длительность обработки в миллисекундах
//	* ТекстЖурнала - Строка - Текст журнала
//	* КоличествоОбработок - Число - Количество обработок
//	* КоличествоВыгрузок - Число - Количество выгрузок
Функция ВыборкаОтправкиИсходящихСообщенийВПотоке(ИдентификаторПотока, Количество, ПакетнаяПубликация)
	
	ТекстЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1000
	|	Т.КлючЗаписи КАК КлючЗаписи,
	|	Т.ДатаРегистрацииМС КАК ДатаРегистрацииМС,
	|	Т.ИсходныеДанные КАК ИсходныеДанные,
	|	Т.ЭтоУдаление КАК ЭтоУдаление,
	|	Т.КлючСообщения КАК КлючСообщения,
	|	Т.Заголовки КАК Заголовки,
	|	Т.ТелоСообщения КАК ТелоСообщения,
	|	Т.Продюсер КАК Продюсер,
	|	Т.ТипОбъект КАК ТипОбъект,
	|	Т.ТипИсходныхДанных КАК ТипИсходныхДанных,
	|	Т.КлючОбъекта КАК КлючОбъекта,
	|	Т.СобытиеРегистрации КАК СобытиеРегистрации,
	|	Т.ДатаРегистрации КАК ДатаРегистрации,
	|	Т.ДатаОбработки КАК ДатаОбработки,
	|	Т.ДлОбработкиМС КАК ДлОбработкиМС,
	|	Т.ТекстЖурнала КАК ТекстЖурнала,
	|	Т.КоличествоОбработок КАК КоличествоОбработок,
	|	Т.КоличествоВыгрузок КАК КоличествоВыгрузок
	|ИЗ
	|	РегистрСведений.кфкИсходящиеСообщения КАК Т
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.кфкОчередьПотоков КАК ОП
	|		ПО Т.КлючЗаписи = ОП.Ключ
	|		И Т.ДатаРегистрацииМС = ОП.ВременнаяМетка
	|		И ОП.ИдентификаторПотока = &ИдентификаторПотока
	|
	|УПОРЯДОЧИТЬ ПО
	|	Т.МеткаИзмененияМС";
	
	Если ПакетнаяПубликация Тогда
		ТекстЗапроса = ТекстЗапроса + "
		|ИТОГИ
		|ПО
		|	Продюсер,
		|	ТипОбъект";
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = СтрЗаменить(ТекстЗапроса, "1000", XMLСтрока(Количество));
	Запрос.УстановитьПараметр("ИдентификаторПотока", ИдентификаторПотока);
	
	ОбходЗапроса = ?(ПакетнаяПубликация, ОбходРезультатаЗапроса.ПоГруппировкам, ОбходРезультатаЗапроса.Прямой);
	Возврат Запрос.Выполнить().Выбрать(ОбходЗапроса);
	
КонецФункции

Процедура ОбработчикОтправкиИсходящихСообщений(Выборка, Сессии, Очереди, ИдентификаторПотока, Топики)
	
	Очередь = НоваяОчередь(Очереди);
	ОчередьПотока = НоваяОчередьПотока(Очереди);
	
	Пока Выборка.Следующий() Цикл
		
		ТекстЖурнала = "";
		ИмяТопика = Топики.Получить(НРег(XMLСтрока(Выборка.Продюсер) + Выборка.ТипОбъект)); // Строка
		Если ПустаяСтрока(ИмяТопика) Тогда
			Статус = Перечисления.кфкСтатусыСообщений.ОшибкаВыгрузки;
			ТекстЖурнала = НСтр("ru = 'Отсутствует имя топика!'");
			
		Иначе
			Сообщение = кфкИнтеграция.ПараметрыСообщения();
			//@skip-check statement-type-change
			Сообщение.Данные = кфкОбщегоНазначенияСлужебный.ЗначениеИзХранилища(Выборка.ТелоСообщения);
			//@skip-check statement-type-change
			Сообщение.Заголовки = кфкОбщегоНазначенияСлужебный.ЗначениеИзХранилища(Выборка.Заголовки);
			Сообщение.Ключ = ?(ПустаяСтрока(Выборка.КлючСообщения), Выборка.КлючОбъекта, Выборка.КлючСообщения);
			
			Результат = кфкИнтеграцияСлужебный.Отправить(Выборка.Продюсер, ИмяТопика, Сообщение, -1, Сессии); // см. кфкИнтеграция.РезультатИнтеграции
			Если Результат.Успешно Тогда
				Статус = Перечисления.кфкСтатусыСообщений.Выгружено;
				
			Иначе
				Статус = Перечисления.кфкСтатусыСообщений.ОшибкаВыгрузки;
				ТекстЖурнала = Результат.ТекстОшибки; 
				
			КонецЕсли;
			
		КонецЕсли;
		
		// Запись
		НоваяСтрока = Очередь.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		НоваяСтрока.Статус = Статус;
		НоваяСтрока.ДатаВыгрузки = ТекущаяДатаСеанса();
		НоваяСтрока.ТекстЖурнала = ДополнитьТекстЖурнала(Выборка.ТекстЖурнала, ТекстЖурнала);
		НоваяСтрока.КоличествоВыгрузок = НоваяСтрока.КоличествоВыгрузок + 1;
		НоваяСтрока.МеткаИзмененияМС = ТекущаяУниверсальнаяДатаВМиллисекундах();
		
		НоваяСтрока = ОчередьПотока.Добавить();
		НоваяСтрока.Ключ = Выборка.КлючЗаписи;
		НоваяСтрока.ВременнаяМетка = Выборка.ДатаРегистрацииМС;
		НоваяСтрока.ИдентификаторПотока = ИдентификаторПотока;
		
	КонецЦикла;
	
//	Запись в БД
	Очередь.Записать(РежимЗамещения.Обновление);
	ОчередьПотока.Записать(РежимЗамещения.Удаление);
	
КонецПроцедуры

// Обработчик отправки пакет исходящих сообщений.
// 	см. ОтправитьПакетСообщений - метод не может гарантировать доставку всех сообщений, а использование транзакций не оправдано (ВК 1.8.1)
// 
// Параметры:
//	Выборка - см. ВыборкаОтправкиИсходящихСообщенийВПотоке
//	Сессии - Соответствие Из КлючИЗначение - Сессии
//	Очереди - Структура - Очереди
//	ИдентификаторПотока - УникальныйИдентификатор - Идентификатор потока
//	Продюсер - СправочникСсылка.кфкПродюсеры - Продюсер
//	ИмяТопика - Строка - Имя топика
//@skip-check module-unused-method
Процедура ОбработчикОтправкиПакетИсходящихСообщений(Выборка, Сессии, Очереди, ИдентификаторПотока, Продюсер, ИмяТопика)
	
	// Проверка наличия имени топика
	Если ПустаяСтрока(ИмяТопика) Тогда
		ОбработчикОтправкиПакетИсходящихСообщенийЗаписатьОшибку(Выборка, Очереди, ИдентификаторПотока,
			НСтр("ru = 'Отсутствует имя топика!'"));
		Возврат;
	КонецЕсли;
	
	// Инициализация набора записей
	Очередь = НоваяОчередь(Очереди);
	ОчередьПотока = НоваяОчередьПотока(Очереди);
	
	// Инициализация значений очереди БД
	ТекущаяДата = ТекущаяДатаСеанса();
	ТекущаяДатаМС = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	// Инициализация значений очереди Kafka
	Сообщения = Новый Массив; // Массив Из Структура
	
	// Формируем пакет сообщений
	Пока Выборка.Следующий() Цикл
		
		// Запись
		НоваяСтрока = Очередь.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		НоваяСтрока.Статус = Перечисления.кфкСтатусыСообщений.Выгружено;
		НоваяСтрока.ДатаВыгрузки = ТекущаяДата;
		НоваяСтрока.КоличествоВыгрузок = НоваяСтрока.КоличествоВыгрузок + 1;
		НоваяСтрока.МеткаИзмененияМС = ТекущаяДатаМС;
		НоваяСтрока = ОчередьПотока.Добавить();
		НоваяСтрока.Ключ = Выборка.КлючЗаписи;
		НоваяСтрока.ВременнаяМетка = Выборка.ДатаРегистрацииМС;
		НоваяСтрока.ИдентификаторПотока = ИдентификаторПотока;
		
		// Добавление сообщения в оперативную очередь
		Сообщение = Новый Структура;
		Сообщение.Вставить("key", ?(ПустаяСтрока(Выборка.КлючСообщения), Выборка.КлючОбъекта, Выборка.КлючСообщения));
		Сообщение.Вставить("partition", -1);
		Сообщение.Вставить("message", кфкОбщегоНазначенияСлужебный.ЗначениеИзХранилища(Выборка.ТелоСообщения));
		Сообщение.Вставить("headers", кфкИнтеграцияСлужебный.ЗаголовкиПакетногоСообщения(
			кфкОбщегоНазначенияСлужебный.ЗначениеИзХранилища(Выборка.Заголовки)));
		Сообщения.Добавить(Сообщение);
		
	КонецЦикла;
	
	// Отправка в Kafka и запись в БД
	НачатьТранзакцию();
	Попытка
		
		// Запись в БД
		Очередь.Записать(РежимЗамещения.Обновление);
		ОчередьПотока.Записать(РежимЗамещения.Удаление);
		
		// Отправка в Kafka
		Результат = кфкИнтеграцияСлужебный.ОтправитьПакетСообщений(Продюсер, ИмяТопика, Сообщения, Сессии); // см. кфкИнтеграция.РезультатИнтеграции
		Если Результат.Успешно Тогда
			ЗафиксироватьТранзакцию();
			
		Иначе
			ОтменитьТранзакцию();
			ОбработчикОтправкиПакетИсходящихСообщенийЗаписатьОшибку(Выборка, Очереди, ИдентификаторПотока, Результат.ТекстОшибки);
			
		КонецЕсли;
		
	Исключение
		ОтменитьТранзакцию();
		ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ОбработчикОтправкиПакетИсходящихСообщенийЗаписатьОшибку(Выборка, Очереди, ИдентификаторПотока, ТекстОшибки);
		
	КонецПопытки;
	
КонецПроцедуры

Процедура ОбработчикОтправкиПакетИсходящихСообщенийЗаписатьОшибку(Выборка, Очереди, ИдентификаторПотока, ТекстЖурнала)
	
	// Инициализация набора записей
	Очередь = НоваяОчередь(Очереди);
	ОчередьПотока = НоваяОчередьПотока(Очереди);
	
	// Инициализация значений очереди БД
	ТекущаяДата = ТекущаяДатаСеанса();
	ТекущаяДатаМС = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	Выборка.Сбросить();
	Пока Выборка.Следующий() Цикл
		
		// Запись
		НоваяСтрока = Очередь.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		НоваяСтрока.Статус = Перечисления.кфкСтатусыСообщений.ОшибкаВыгрузки;
		НоваяСтрока.ДатаВыгрузки = ТекущаяДата;
		НоваяСтрока.ТекстЖурнала = ДополнитьТекстЖурнала(Выборка.ТекстЖурнала, ТекстЖурнала);
		НоваяСтрока.КоличествоВыгрузок = НоваяСтрока.КоличествоВыгрузок + 1;
		НоваяСтрока.МеткаИзмененияМС = ТекущаяДатаМС;
		
		НоваяСтрока = ОчередьПотока.Добавить();
		НоваяСтрока.Ключ = Выборка.КлючЗаписи;
		НоваяСтрока.ВременнаяМетка = Выборка.ДатаРегистрацииМС;
		НоваяСтрока.ИдентификаторПотока = ИдентификаторПотока;
		
	КонецЦикла;
	
	// Запись в БД
	Очередь.Записать(РежимЗамещения.Обновление);
	ОчередьПотока.Записать(РежимЗамещения.Удаление);
	
КонецПроцедуры

#КонецОбласти

#Область ЗагрузкаСообщений

Функция КомандаЗагрузкаСообщенийАктивно()
	Возврат "ЗАГРУЗКА-СООБЩЕНИЙ-АКТИВНО";
КонецФункции

Функция ЕстьКомандаЗагрузкиСообщений(ИдентификаторПотока)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РегистрСведений.кфкОчередьПотоков.Ключ ГДЕ Ключ = &Ключ И ИдентификаторПотока = &ИдентификаторПотока";
	Запрос.УстановитьПараметр("Ключ", КомандаЗагрузкаСообщенийАктивно());
	Запрос.УстановитьПараметр("ИдентификаторПотока", ИдентификаторПотока);
	
	Возврат Не Запрос.Выполнить().Пустой();
	
КонецФункции

// Возвращает таблицу распределения чтения консьюмеров
// 
// Параметры:
//	Консьюмеры - Массив Из СправочникСсылка.кфкКонсьюмеры - Консьюмеры
//  МаксКолПотоков - Число - Максимальное количество потоков
//	СостояниеОчереди - Число - Текущий размер очереди
//	КЭШ - Неопределено, Структура - Кэш
// 
// Возвращаемое значение:
//	ТаблицаЗначений - Таблица распределения чтения консьюмеров:
//	 * Консьюмер - СправочникСсылка.кфкКонсьюмеры - Консьюмер
//	 * НомерПотока - Число - Номер потока
Функция ТаблицаРаспределенияЧтенияКонсьюмеров(Консьюмеры, МаксКолПотоков, СостояниеОчереди, КЭШ)
	
	Если Не КЭШ.Свойство("Коннектор") Тогда
		КЭШ.Вставить("ТочкиПолучения", Справочники.кфкКонсьюмеры.ТочкиПолученияСообщений(Консьюмеры));
		КЭШ.Вставить("Коннектор", Обработки.кфкИнтеграция.Создать());
		КЭШ.Вставить("ПартицииКонсьюмеров", Новый Соответствие);
		
		ИсторияОчереди = Новый ТаблицаЗначений;
		ИсторияОчереди.Колонки.Добавить("Консьюмер", Новый ОписаниеТипов("СправочникСсылка.кфкКонсьюмеры"));
		ИсторияОчереди.Колонки.Добавить("РазмерОчереди", Новый ОписаниеТипов("Число"));
		ИсторияОчереди.Колонки.Добавить("ВремяЗамера", Новый ОписаниеТипов("Дата"));
		ИсторияОчереди.Индексы.Добавить("Консьюмер");
		КЭШ.Вставить("ИсторияОчереди", ИсторияОчереди);
		
	КонецЕсли;
	ТочкиПолучения = КЭШ.ТочкиПолучения; // см. Справочники.кфкКонсьюмеры.ТочкиПолученияСообщений
	Коннектор = КЭШ.Коннектор;
	ИсторияОчереди = КЭШ.ИсторияОчереди;
	ПартицииКонсьюмеров = КЭШ.ПартицииКонсьюмеров;
	
	СостояниеОчереди = 0;
	
	// Сбор статистики - отставание консьюмеров
	Для Каждого КлючЗначение Из ТочкиПолучения Цикл
		Точка = КлючЗначение.Значение;
		
		НоваяСтрока = ИсторияОчереди.Добавить();
		НоваяСтрока.Консьюмер = КлючЗначение.Ключ;
		НоваяСтрока.ВремяЗамера = ТекущаяУниверсальнаяДата();
		
		КоличествоПартиций = 0;
		
		Для Каждого ИмяТопика Из Точка.Топики Цикл
			Отставание = Коннектор.ПолучитьОтставаниеКонсьюмера(Точка.АдресБрокера, ИмяТопика, Точка.Идентификатор); // Структура
			Если Отставание <> Неопределено Тогда
				НоваяСтрока.РазмерОчереди = НоваяСтрока.РазмерОчереди + Число(Отставание.total_lag);
				Значение = Неопределено; // Структура
				КоличествоПартиций = КоличествоПартиций + ?(Отставание.Свойство("partitions", Значение),
					Значение.Количество(), 0);
			КонецЕсли;
		КонецЦикла;
		
		ПартицииКонсьюмеров.Вставить(КлючЗначение.Ключ, Макс(1, КоличествоПартиций));
		
		СостояниеОчереди = СостояниеОчереди + НоваяСтрока.РазмерОчереди;
		
	КонецЦикла;
	
	// Удаление устаревших записей статистики
	ИнтервалРасчета = 300; // 5 мин
	НачалоПериодаРасчета = ТекущаяУниверсальнаяДата() - ИнтервалРасчета;
	ИсторияОчереди.Сортировать("ВремяЗамера Возр");
	Пока ИсторияОчереди.Количество() > 0 И ИсторияОчереди[0].ВремяЗамера < НачалоПериодаРасчета Цикл
		ИсторияОчереди.Удалить(0);
	КонецЦикла;
	
	// Агрегация статистики
	ИсторияОчереди.Сортировать("РазмерОчереди Убыв");
	Статистика = Новый ТаблицаЗначений;
	Статистика.Колонки.Добавить("Консьюмер", Новый ОписаниеТипов("СправочникСсылка.кфкКонсьюмеры"));
	Статистика.Колонки.Добавить("РазмерОчереди", Новый ОписаниеТипов("Число"));
	Статистика.Колонки.Добавить("Партиций", Новый ОписаниеТипов("Число"));
	Статистика.Колонки.Добавить("СредРазмер", Новый ОписаниеТипов("Число"));
	Для Каждого КлючЗначение Из ПартицииКонсьюмеров Цикл
		
		НоваяСтрока = Статистика.Добавить();
		НоваяСтрока.Консьюмер = КлючЗначение.Ключ;
		НоваяСтрока.Партиций = КлючЗначение.Значение;
		
		// Агрегация
		Строки = ИсторияОчереди.НайтиСтроки(Новый Структура("Консьюмер", КлючЗначение.Ключ));
		НоваяСтрока.РазмерОчереди = ?(Строки.Количество() = 0, 0, Строки[0].РазмерОчереди); // Максимальное значение
		
		// Считаем "тяжесть" каждого консьюмера
		НоваяСтрока.СредРазмер = НоваяСтрока.РазмерОчереди / КлючЗначение.Значение;
		
	КонецЦикла;
	
	// Средний размер очереди
	ОбщийКоэффициентРазмера = 0.7; // Степень распределения, 0.5 - агрессивная группировка (больше топиков в одном потоке), 0.8-0.9 - консервативная (чаще разделяем)
	МаксРазмерПакета = Макс(Статистика.Итог("СредРазмер") / МаксКолПотоков
		* ОбщийКоэффициентРазмера, РазмерПорцииНабораЗаписей() / 10);
	
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Консьюмер", Новый ОписаниеТипов("СправочникСсылка.кфкКонсьюмеры"));
	Результат.Колонки.Добавить("НомерПотока", Новый ОписаниеТипов("Число"));
	Результат.Колонки.Добавить("СредРазмер", Новый ОписаниеТипов("Число"));
	
	МаксНомерПотока = 0;
	
	// Распределяем консьюмеры по потокам
	Статистика.Сортировать("СредРазмер Убыв"); // от большего к меньшему
	Для Каждого Строка Из Статистика Цикл
		
		КоличествоПотоков = ?(Строка.СредРазмер < МаксРазмерПакета, 1,
			Мин(Окр(Строка.СредРазмер / МаксРазмерПакета, 0, РежимОкругления.Окр15как20), Строка.Партиций));
		СредРазмер = Строка.СредРазмер / КоличествоПотоков;
		Для Номер = 1 По КоличествоПотоков Цикл
			
			Результат.Сортировать("СредРазмер Возр, НомерПотока Возр");
			НомерПотока = ?(Результат.Количество() > 0 И Результат[0].СредРазмер + СредРазмер < МаксРазмерПакета
					Или МаксНомерПотока = МаксКолПотоков,
				Результат[0].НомерПотока, МаксНомерПотока + 1);
			МаксНомерПотока = Макс(МаксНомерПотока, НомерПотока);
			
			НоваяСтрока = Результат.Добавить();
			НоваяСтрока.Консьюмер = Строка.Консьюмер;
			НоваяСтрока.НомерПотока = НомерПотока;
			НоваяСтрока.СредРазмер = СредРазмер;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Результат.Колонки.Удалить("СредРазмер");
	Результат.Индексы.Добавить("НомерПотока");
	
	Возврат Результат;
	
КонецФункции

Процедура ОбновитьРаспределениеКонсьюмеров(Распределение, Потоки, Очередь1, Очередь2, ОчередьПотоков)
	
	// Сбросим состояние наборов записей
	Очередь1.Очистить();
	Очередь2.Очистить();
	Очередь1.Отбор.Сбросить();
	Очередь2.Отбор.Сбросить();
					
	// Удаляем неиспользуемые потоки
	Ключи = ОбщегоНазначения.ВыгрузитьКолонку(ОчередьПотоков, "Ключ");
	Для Каждого Ключ Из ОбщегоНазначенияКлиентСервер.РазностьМассивов(Ключи, Потоки) Цикл
		ОчередьПотоков.Удалить(Ключ);
	КонецЦикла;
	
	Для Индекс = 0 По Потоки.ВГраница() Цикл
		
		ИдентификаторПотока = Потоки[Индекс];
		
		// Текущее состояние РС.ОчередьПотоков
		Консьюмеры = ОчередьПотоков.Получить(ИдентификаторПотока); // Массив Из СправочникСсылка.кфкКонсьюмеры
		Если Консьюмеры = Неопределено Тогда
			Консьюмеры = Новый Массив;
			ОчередьПотоков.Вставить(ИдентификаторПотока, Консьюмеры);
		КонецЕсли;
		
		КУдалению = ОбщегоНазначения.СкопироватьРекурсивно(Консьюмеры, Ложь);
		
		// Добавляем новые консьюмеры
		Для Каждого Строка Из Распределение.НайтиСтроки(Новый Структура("НомерПотока", Индекс+1)) Цикл
			
			Если Консьюмеры.Найти(Строка.Консьюмер) = Неопределено Тогда
				
				НоваяСтрока = Очередь1.Добавить();
				НоваяСтрока.Ключ = XMLСтрока(Строка.Консьюмер);
				НоваяСтрока.ВременнаяМетка = 0;
				НоваяСтрока.ИдентификаторПотока = ИдентификаторПотока;
				
				Консьюмеры.Добавить(Строка.Консьюмер);
				
			КонецЕсли;
			
			ОбщегоНазначенияКлиентСервер.УдалитьЗначениеИзМассива(КУдалению, Строка.Консьюмер);
			
		КонецЦикла;
		
		// Удаляем старые консьюмеры
		Для Каждого Консьюмер Из КУдалению Цикл
			
			НоваяСтрока = Очередь2.Добавить();
			НоваяСтрока.Ключ = XMLСтрока(Консьюмер);
			НоваяСтрока.ВременнаяМетка = 0;
			НоваяСтрока.ИдентификаторПотока = ИдентификаторПотока;
			
			ОбщегоНазначенияКлиентСервер.УдалитьЗначениеИзМассива(Консьюмеры, Консьюмер);
			
		КонецЦикла;
		
	КонецЦикла;
	
	// Записываем изменения
	Если Очередь1.Количество() > 0 Тогда
		Очередь1.Записать(РежимЗамещения.Добавление);
	КонецЕсли;
	Если Очередь2.Количество() > 0 Тогда
		Очередь2.Записать(РежимЗамещения.Удаление);
	КонецЕсли;
	
КонецПроцедуры

Функция ОчередьПотоковЗагрузкиСообщений()
	
	Результат = Новый Соответствие;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
		|	Т2.Ключ КАК Ключ,
		|	Т2.ИдентификаторПотока КАК ИдентификаторПотока
		|ИЗ
		|	РегистрСведений.кфкОчередьПотоков КАК Т1
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.кфкОчередьПотоков КАК Т2
		|		ПО Т1.ИдентификаторПотока = Т2.ИдентификаторПотока
		|		И Т1.Ключ <> Т2.Ключ
		|		И Т1.Ключ = &Ключ
		|ИТОГИ
		|ПО
		|	ИдентификаторПотока";
	Запрос.УстановитьПараметр("Ключ", КомандаЗагрузкаСообщенийАктивно());
	ВыборкаПотока = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаПотока.Следующий() Цикл
		
		Список = Новый Массив; // Массив Из СправочникСсылка.кфкКонсьюмеры
		Выборка = ВыборкаПотока.Выбрать();
		Пока Выборка.Следующий() Цикл
			Список.Добавить(Справочники.кфкКонсьюмеры.ПолучитьСсылку(Новый УникальныйИдентификатор(Выборка[0])));
		КонецЦикла;
		
		Результат.Вставить(ВыборкаПотока[1], Список);
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Возвращает консьюмеры для загрузки сообщений.
// 
// Параметры:
//	ИдентификаторПотока - УникальныйИдентификатор - Идентификатор потока
// 
// Возвращаемое значение:
//	Массив Из СправочникСсылка.кфкКонсьюмеры - Консьюмеры для загрузки сообщений
Функция КонсьюмерыЗагрузкиСообщений(ИдентификаторПотока)
	
	Результат = Новый Массив; // Массив Из СправочникСсылка.кфкКонсьюмеры
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РегистрСведений.кфкОчередьПотоков.Ключ ГДЕ ИдентификаторПотока = &ИдентификаторПотока";
	Запрос.УстановитьПараметр("ИдентификаторПотока", ИдентификаторПотока);
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл
		Если Выборка[0] <> КомандаЗагрузкаСообщенийАктивно() Тогда
			Результат.Добавить(Справочники.кфкКонсьюмеры.ПолучитьСсылку(Новый УникальныйИдентификатор(Выборка[0])));
		КонецЕсли;
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// Закрыть сессии консьюмера параллельного потока.
// 
// Параметры:
//	Сессии - Соответствие Из КлючИЗначение - Сессии:
//	 * Ключ - СправочникСсылка.кфкКонсьюмеры - Консьюмер
//	 * Значение - ОбработкаОбъект.кфкИнтеграция - Сессия
//	Консьюмеры - Массив Из СправочникСсылка.кфкКонсьюмеры - Консьюмеры
Процедура ЗакрытьСессииКонсьюмераПараллельногоПотока(Сессии, Консьюмеры)
	
	КУдалению = Новый Соответствие;
	Для Каждого Сессия Из Сессии Цикл
		
		Если Консьюмеры.Найти(Сессия.Ключ) = Неопределено Тогда
			КУдалению.Вставить(Сессия.Ключ, Сессия.Значение);
			Сессии.Удалить(Сессия.Ключ);
		КонецЕсли;
		
	КонецЦикла;
	
	кфкИнтеграцияСлужебный.ЗакрытьСессииКонсьюмера(КУдалению);
	
КонецПроцедуры

// Устарела. Обработчик загрузки сообщений.
// 
// Параметры:
//	Консьюмеры - Массив Из СправочникСсылка.кфкКонсьюмеры - Консьюмеры
//	Сессии - Соответствие Из КлючИЗначение - Сессии
//	Очередь - РегистрСведенийНаборЗаписей.кфкВходящиеСообщения - Очередь
//	РазмерПакета - Число - Размер пакета
//	Загружено - Булево - Загружено
//@skip-check module-unused-method
Процедура ОбработчикЗагрузкиСообщений(Консьюмеры, Сессии, Очередь, РазмерПакета, Загружено)
	
	Загружено = Ложь;
	
	Для Каждого Консьюмер Из Консьюмеры Цикл
		
		Очередь.Очистить();
		
		Сообщение = Неопределено;
		
		Для НомерСообщений = 1 По РазмерПакета Цикл
			
			Результат = кфкИнтеграцияСлужебный.Прочитать(Консьюмер, Ложь, Сессии); // см. кфкИнтеграция.РезультатИнтеграции
			Если Результат.Успешно = Ложь Тогда
				ОповеститьОбОшибкиЧтения(Консьюмер, Результат.ТекстОшибки);
				кфкИнтеграцияСлужебный.ЗакрытьСессииКонсьюмера(Сессии);
				ВызватьИсключение Результат.ТекстОшибки;
				
			ИначеЕсли Результат.Сообщение = Неопределено Тогда
				Прервать;
				
			Иначе
				ТекущаяДата = ТекущаяДатаСеанса();
				ТекущаяДатаМС = ТекущаяУниверсальнаяДатаВМиллисекундах();
				
				Сообщение = Результат.Сообщение;
				
				Хеш = Новый ХешированиеДанных(ХешФункция.SHA256);
				Хеш.Добавить(XMLСтрока(Консьюмер));
				Хеш.Добавить(НРег(Сообщение.Топик));
				Хеш.Добавить(НРег(Сообщение.Ключ));
				
				НоваяСтрока = Очередь.Добавить();
				ЗаполнитьЗначенияСвойств(НоваяСтрока, Сообщение, "Топик,Раздел,Смещение");
				НоваяСтрока.КлючЗаписи = ПолучитьHexСтрокуИзДвоичныхДанных(Хеш.ХешСумма);
				НоваяСтрока.ДатаЗагрузкиМС = ТекущаяДатаМС;
				НоваяСтрока.Статус = Перечисления.кфкСтатусыСообщений.Новое; 
				НоваяСтрока.Заголовки = кфкОбщегоНазначенияСлужебный.ЗначениеВХранилище(Сообщение.Заголовки);
				НоваяСтрока.ТелоСообщения = кфкОбщегоНазначенияСлужебный.ЗначениеВХранилище(Сообщение.Тело);
				НоваяСтрока.Консьюмер = Консьюмер;
				НоваяСтрока.КлючСообщения = Сообщение.Ключ;
				НоваяСтрока.ДатаЗаписи = МестноеВремя(Дата(1970, 1, 1, 0, 0, 0) + Сообщение.ВременнаяМетка);
				НоваяСтрока.ДатаЗагрузки = ТекущаяДата;
				НоваяСтрока.МеткаИзмененияМС = ТекущаяДатаМС;
				
			КонецЕсли;
			
		КонецЦикла;
		
		// сохраняем результат чтения
		Если Очередь.Количество() > 0 Тогда
			
			НачатьТранзакцию();
			Попытка
				
				Очередь.Записать(РежимЗамещения.Добавление);
				
				// Зафиксировать смещение в Кафке
				Если Не Сообщение = Неопределено Тогда
					Результат = кфкИнтеграцияСлужебный.ЗафиксироватьСмещение(Консьюмер, Сессии, Сообщение); // Сообщение - последнее полученное сообщение
					Если Не Результат.Успешно Тогда
						ВызватьИсключение Результат.ТекстОшибки;
					КонецЕсли;
				КонецЕсли;
				
				ЗафиксироватьТранзакцию();
				
			Исключение
				
				ОтменитьТранзакцию();
				кфкИнтеграцияСлужебный.ЗакрытьСессииКонсьюмера(Сессии);
				
				ТекстОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
				ОповеститьОбОшибкиЧтения(Консьюмер, ТекстОшибки);
				ВызватьИсключение ТекстОшибки;
				
			КонецПопытки;
			
			Загружено = Истина;
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

// Обработчик загрузки пакет сообщений.
// 
// Параметры:
//	Консьюмеры - Массив Из СправочникСсылка.кфкКонсьюмеры - Консьюмеры
//	Сессии - Соответствие Из КлючИЗначение - Сессии
//	Очередь - РегистрСведенийНаборЗаписей.кфкВходящиеСообщения - Очередь
//	РазмерПакета - Число - Размер пакета
//	Загружено - Булево - Загружено
Процедура ОбработчикЗагрузкиПакетСообщений(Консьюмеры, Сессии, Очередь, РазмерПакета, Загружено)
	
	Загружено = Ложь;
	
	Для Каждого Консьюмер Из Консьюмеры Цикл
			
		Результат = кфкИнтеграцияСлужебный.ПрочитатьПакетСообщений(Консьюмер, Истина, РазмерПакета, Сессии); // см. кфкИнтеграция.РезультатИнтеграции
		Если Результат.Успешно = Ложь Тогда
			ОповеститьОбОшибкиЧтения(Консьюмер, Результат.ТекстОшибки);
			кфкИнтеграцияСлужебный.ЗакрытьСессииКонсьюмера(Сессии);
			ВызватьИсключение Результат.ТекстОшибки;
			
		ИначеЕсли Результат.Сообщения.Количество() > 0 Тогда
			
			// Инициализация
			Очередь.Очистить();
			ТекущаяДата = ТекущаяДатаСеанса();
			ТекущаяДатаМС = ТекущаяУниверсальнаяДатаВМиллисекундах();
			НомерСообщения = 0;
			
			// Перебор сообщений
			Для Каждого Сообщение Из Результат.Сообщения Цикл
				НомерСообщения = НомерСообщения + 1;
				
				// ключ сообщения
				Ключ = "";
				Если Не Сообщение.Свойство("key", Ключ) Тогда
					СтрокаXML = ОбщегоНазначения.ЗначениеВСтрокуXML(Сообщение.message);
					ХешОбъекта = Новый ХешированиеДанных(ХешФункция.SHA256);
					ХешОбъекта.Добавить(СтрокаXML);
					Ключ = ПолучитьHexСтрокуИзДвоичныхДанных(ХешОбъекта.ХешСумма);
				КонецЕсли;
				
				Заголовки = Новый Соответствие;
				Если Сообщение.Свойство("headers") Тогда
					//@skip-check property-return-type
					Для Каждого header Из Сообщение.headers Цикл
						Заголовки.Вставить(header.key, header.value);
					КонецЦикла;
				КонецЕсли;
				
				Хеш = Новый ХешированиеДанных(ХешФункция.SHA256);
				Хеш.Добавить(XMLСтрока(Консьюмер));
				Хеш.Добавить(НРег(Сообщение.topic));
				Хеш.Добавить(НРег(Ключ));
				
				НоваяСтрока = Очередь.Добавить();
				НоваяСтрока.КлючЗаписи = ПолучитьHexСтрокуИзДвоичныхДанных(Хеш.ХешСумма);
				НоваяСтрока.ДатаЗагрузкиМС = ТекущаяДатаМС + НомерСообщения / 10000;
				
				НоваяСтрока.Статус = Перечисления.кфкСтатусыСообщений.Новое; 
				НоваяСтрока.Заголовки = кфкОбщегоНазначенияСлужебный.ЗначениеВХранилище(Заголовки);
				НоваяСтрока.ТелоСообщения = кфкОбщегоНазначенияСлужебный.ЗначениеВХранилище(Сообщение.message);
				
				НоваяСтрока.Консьюмер = Консьюмер;
				НоваяСтрока.Топик = Сообщение.topic;
				НоваяСтрока.Раздел = Сообщение.partition;
				НоваяСтрока.Смещение = Сообщение.offset;
				НоваяСтрока.КлючСообщения = Ключ;
//				НоваяСтрока.ДатаЗаписиМС = 62135596800000 + Сообщение.timestamp;
				НоваяСтрока.ДатаЗаписи = МестноеВремя(Дата(1970, 1, 1, 0, 0, 0) + Сообщение.timestamp / 1000);
				НоваяСтрока.ДатаЗагрузки = ТекущаяДата;
				НоваяСтрока.МеткаИзмененияМС = ТекущаяДатаМС;
				
			КонецЦикла;
			
			// Фиксируем сообщения
			Очередь.Записать(РежимЗамещения.Добавление);
			
		КонецЕсли;
			
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти

#Область ДесериализацияСообщений

// Выборка десериализации сообщений. см. ДесериализацияСообщений
// 
// Параметры:
//  Консьюмеры - Массив из СправочникСсылка.кфкКонсьюмеры - Консьюмеры
//  Количество - Число - Количество записей
//  МеткаИзмененияМС - Число - Указатель начала выборки данных
// 
// Возвращаемое значение:
//  ВыборкаИзРезультатаЗапроса - Выборка исходящих сообщений:
//	* КлючЗаписи - Строка - Ключ записи
//	* ДатаЗагрузкиМС - Число - Дата загрузки из брокер (мс)
//	* МеткаИзмененияМС - Число - Последнее изменение (мс)
Функция ВыборкаДесериализацииСообщений(Консьюмеры, Количество, МеткаИзмененияМС)
	
	ТекстЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1000
	|	Т.КлючЗаписи КАК КлючЗаписи,
	|	Т.ДатаЗагрузкиМС КАК ДатаЗагрузкиМС,
	|	Т.МеткаИзмененияМС КАК МеткаИзмененияМС
	|ИЗ
	|	РегистрСведений.кфкВходящиеСообщения КАК Т
	|ГДЕ
	|	Т.Консьюмер В (&Консьюмеры)
	|	И Т.МеткаИзмененияМС >= &МеткаИзмененияМС
	|	И НЕ 0 В
	|		(ВЫБРАТЬ
	|			0
	|		ИЗ
	|			РегистрСведений.кфкОчередьПотоков КАК ОП
	|		ГДЕ
	|			ОП.Ключ = Т.КлючЗаписи)
	|	И Т.Статус = ЗНАЧЕНИЕ(Перечисление.кфкСтатусыСообщений.Новое)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Т.МеткаИзмененияМС";
	
	Запрос = Новый Запрос;
	Запрос.Текст = СтрЗаменить(ТекстЗапроса, "1000", XMLСтрока(Количество));
	Запрос.УстановитьПараметр("Консьюмеры", Консьюмеры);
	Запрос.УстановитьПараметр("МеткаИзмененияМС", МеткаИзмененияМС);
	
	Возврат Запрос.Выполнить().Выбрать();
	
КонецФункции

// Выборка десериализации сообщений. см. ДесериализацияСообщений
// 
// Параметры:
//  ИдентификаторПотока - УникальныйИдентификатор - Идентификатор потока
//  Количество - Число - Количество записей
// 
// Возвращаемое значение:
//  ВыборкаИзРезультатаЗапроса - Выборка исходящих сообщений:
//	* Консьюмер - СправочникСсылка.кфкКонсьюмеры - Консьюмер
//	* Топик - Строка - Топик
//	* Раздел - Строка - Раздел
//	* Смещение - Строка - Смещение
//	* КлючСообщения - Строка - Ключ
//	* КлючЗаписи - Строка - Владелец сообщения
//	* Заголовки - ХранилищеЗначения - Заголовки
//	* ТелоСообщения - ХранилищеЗначения - Тело
//	* ДатаЗаписи - Дата - Дата записи в брокер
//	* ДатаЗагрузки - Дата - Дата загрузки
//	* ДатаЗагрузкиМС - Число - Дата загрузки из брокер (мс)
//	* ДатаОбработки - Дата - Дата загрузки
//	* ТекстЖурнала - Строка - Текст журнала
//	* КоличествоОбработок - Число - Количество обработок
Функция ВыборкаДесериализацииСообщенийВПотоке(ИдентификаторПотока, Количество)
	
	ТекстЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1000
	|	Т.Консьюмер КАК Консьюмер,
	|	Т.Топик КАК Топик,
	|	Т.Раздел КАК Раздел,
	|	Т.Смещение КАК Смещение,
	|	Т.КлючСообщения КАК КлючСообщения,
	|	Т.КлючЗаписи КАК КлючЗаписи,
	|	Т.Заголовки КАК Заголовки,
	|	Т.ТелоСообщения КАК ТелоСообщения,
	|	Т.ДатаЗаписи КАК ДатаЗаписи,
	|	Т.ДатаЗагрузки КАК ДатаЗагрузки,
	|	Т.ДатаЗагрузкиМС КАК ДатаЗагрузкиМС,
	|	Т.ДатаОбработки КАК ДатаОбработки,
	|	Т.ТекстЖурнала КАК ТекстЖурнала,
	|	Т.КоличествоОбработок КАК КоличествоОбработок
	|ИЗ
	|	РегистрСведений.кфкВходящиеСообщения КАК Т
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.кфкОчередьПотоков КАК ОП
	|		ПО Т.КлючЗаписи = ОП.Ключ
	|		И Т.ДатаЗагрузкиМС = ОП.ВременнаяМетка
	|		И ОП.ИдентификаторПотока = &ИдентификаторПотока";
	
	Запрос = Новый Запрос;
	Запрос.Текст = СтрЗаменить(ТекстЗапроса, "1000", XMLСтрока(Количество));
	Запрос.УстановитьПараметр("ИдентификаторПотока", ИдентификаторПотока);
	
	Возврат Запрос.Выполнить().Выбрать();
	
КонецФункции

Процедура ОбработчикДесериализацииСообщений(Выборка, Очереди, ИдентификаторПотока, Правила)
	
	Очередь = НоваяОчередь(Очереди);
	ОчередьПотока = НоваяОчередьПотока(Очереди);
	
	Пока Выборка.Следующий() Цикл
		
		// Инициализация переменных журнала
		ТекстЖурнала = "";
		ДлительностьОбработки = 0;
		Статус = Перечисления.кфкСтатусыСообщений.ОшибкаОбработки;
		
		// Применение правил сериализации
		Правило = Правила.Получить(НРег(XMLСтрока(Выборка.Консьюмер) + Выборка.Топик)); // см. НовоеОписаниеПравилОбмена
		Если Правило = Неопределено Тогда
			Статус = Перечисления.кфкСтатусыСообщений.ОшибкаОбработки;
			ТекстЖурнала = НСтр("ru = 'Не задан тип десериализации!'");
			
		Иначе
			Попытка
				// Инициализация переменных обработки
				Отказ = Ложь;
				Успешно = Ложь;
				ТелоСообщения = кфкОбщегоНазначенияСлужебный.ЗначениеИзХранилища(Выборка.ТелоСообщения);
				СвойстваСообщений = СвойстваВходящихСообщений(Выборка);
				
				// Выполнение обработчика
				Если Правило.Тип = Перечисления.кфкТипыОбработчиков.ПроизвольныйОбработчик Тогда
					Успешно = ВыполнитьПроизвольныйОбработчикДесериализации(Правило, ТелоСообщения, СвойстваСообщений,
						ДлительностьОбработки, ТекстЖурнала, Отказ);
					
				ИначеЕсли Правило.Тип = Перечисления.кфкТипыОбработчиков.КонвертацияДанных Тогда
					Успешно = ВыполнитьКДОбработчикДесериализации(Правило, ТелоСообщения, СвойстваСообщений,
						ДлительностьОбработки, ТекстЖурнала, Отказ);
					
				Иначе
					Статус = Перечисления.кфкСтатусыСообщений.ОшибкаОбработки;
					ТекстЖурнала = НСтр("ru = 'Не задан тип десериализации!'");
					
				КонецЕсли;
				
				// Результат обработки
				Если Не Успешно Тогда // Ошибка
					Статус = Перечисления.кфкСтатусыСообщений.ОшибкаОбработки;
					
				ИначеЕсли Отказ = Истина Тогда // Отказ
					Статус = Перечисления.кфкСтатусыСообщений.ОбработкаОтменена;
					
				Иначе // ОК
					Статус = Перечисления.кфкСтатусыСообщений.Обработано;
					
				КонецЕсли;
				
			Исключение
				ТекстЖурнала = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
				Статус = Перечисления.кфкСтатусыСообщений.ОшибкаОбработки;
				
			КонецПопытки;
		КонецЕсли;
		
		// Запись
		НоваяСтрока = Очередь.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
		НоваяСтрока.Статус = Статус;
		НоваяСтрока.ДатаОбработки = ТекущаяДатаСеанса();
		НоваяСтрока.ДлОбработкиМС = ДлительностьОбработки;
		НоваяСтрока.КоличествоОбработок = НоваяСтрока.КоличествоОбработок + 1;
		НоваяСтрока.ТекстЖурнала = ДополнитьТекстЖурнала(Выборка.ТекстЖурнала, ТекстЖурнала);
		НоваяСтрока.МеткаИзмененияМС = ТекущаяУниверсальнаяДатаВМиллисекундах();
		
		НоваяСтрока = ОчередьПотока.Добавить();
		НоваяСтрока.Ключ = Выборка.КлючЗаписи;
		НоваяСтрока.ВременнаяМетка = Выборка.ДатаЗагрузкиМС;
		НоваяСтрока.ИдентификаторПотока = ИдентификаторПотока;
		
	КонецЦикла;
	
	// Если разница между первой и последней меткой изменений больше 2 секунд, то обновляем все метки изменений
	Если Очередь[Очередь.Количество()-1].МеткаИзмененияМС - Очередь[0].МеткаИзмененияМС > 2000 Тогда
		ТекущаяДатаМС = ТекущаяУниверсальнаяДатаВМиллисекундах();
		Для Каждого Строка Из Очередь Цикл
			Строка.МеткаИзмененияМС = ТекущаяДатаМС;
		КонецЦикла;
	КонецЕсли;
	
//	Запись в БД
	Очередь.Записать(РежимЗамещения.Обновление);
	ОчередьПотока.Записать(РежимЗамещения.Удаление);
	
КонецПроцедуры

// Свойства сообщения подготовки данных. см. ДесериализацияСообщений
// 
// Параметры:
//  Выборка - ВыборкаИзРезультатаЗапроса - Выборка исходящих сообщений. см. ВыборкаДесериализацииСообщений.
// 
// Возвращаемое значение:
//  Структура - Свойства сообщения подготовки данных:
//	* Консьюмер - СправочникСсылка.кфкКонсьюмеры - Консьюмер
//	* Топик - Строка - Топик
//	* Ключ - Строка - Ключ
//	* Раздел - Строка - Раздел
//	* Смещение - Строка - Смещение
//	* Заголовки - Соответствие Из Строка - Заголовки
//	* ДатаЗагрузки - Дата - Дата загрузки
//	* ДатаОбработки - Дата - Дата обработки
Функция СвойстваВходящихСообщений(Выборка)
			
	Результат = Новый Структура;
	Результат.Вставить("Консьюмер", Выборка.Консьюмер);
	Результат.Вставить("Топик", Выборка.Топик);
	Результат.Вставить("Ключ", Выборка.КлючСообщения);
	Результат.Вставить("Раздел", Выборка.Раздел);
	Результат.Вставить("Смещение", Выборка.Смещение);
	Результат.Вставить("Заголовки", кфкОбщегоНазначенияСлужебный.ЗначениеИзХранилища(Выборка.Заголовки));
	Результат.Вставить("ДатаЗаписи", Выборка.ДатаЗаписи);
	Результат.Вставить("ДатаЗагрузки", Выборка.ДатаЗагрузки);
	Результат.Вставить("ДатаОбработки", Выборка.ДатаОбработки);
	
	//@skip-check constructor-function-return-section
	Возврат Результат;
	
КонецФункции

Функция ВыполнитьПроизвольныйОбработчикДесериализации(Правило, ТелоСообщения, СвойстваСообщений, ДлительностьОбработки, ТекстЖурнала, Отказ)
	
	Если ПустаяСтрока(Правило.ИмяМетода) Тогда
		ТекстЖурнала = НСтр("ru = 'Не задан метод десериализации!'");
		Возврат Ложь;
	КонецЕсли;
	
	ПараметрыСериализации = Новый Массив(4); // Массив Из Неопределено, СправочникСсылка, Структура, Строка, Булево
	ПараметрыСериализации[0] = ТелоСообщения;
	ПараметрыСериализации[1] = СвойстваСообщений;
	ПараметрыСериализации[2] = "";
	ПараметрыСериализации[3] = Ложь;
	
	НачалоОбработки = ТекущаяУниверсальнаяДатаВМиллисекундах();
	ОбщегоНазначения.ВыполнитьМетодКонфигурации(Правило.ИмяМетода, ПараметрыСериализации);
	ДлительностьОбработки = ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоОбработки;
	
	ТекстЖурнала = ПараметрыСериализации[2];
	Отказ = ПараметрыСериализации[3];
	
	Возврат Истина;
	
КонецФункции

Функция ВыполнитьКДОбработчикДесериализации(Правило, ТелоСообщения, СвойстваСообщений, ДлительностьОбработки, ТекстЖурнала, Отказ)
	
	КомпонентыОбмена = Правило.КомпонентыОбмена; // Неопределено, Структура - см. кфкОбменДаннымиXDTOСервер.ИнициализироватьКомпонентыОбмена
	Если Правило.КомпонентыОбмена = Неопределено Тогда
		
		Если ПустаяСтрока(Правило.Формат) Или ПустаяСтрока(Правило.ИмяМодуля) Или ПустаяСтрока(Правило.ИмяПОД) Тогда
			ТекстЖурнала = НСтр("ru = 'Ошибка инициализации компонентов обмена. Не заполнены обязательные поля.'");
			Возврат Неопределено;
		КонецЕсли;
		
		КомпонентыОбмена = кфкОбменДаннымиXDTOСервер.ИнициализироватьКомпонентыОбмена("Получение");
		КомпонентыОбмена.XMLСхема = Правило.Формат;
		КомпонентыОбмена.МенеджерОбмена = ОбщегоНазначения.ОбщийМодуль(Правило.ИмяМодуля);
		кфкОбменДаннымиXDTOСервер.ИнициализироватьТаблицыПравилОбмена(КомпонентыОбмена);
		
		Правило.КомпонентыОбмена = КомпонентыОбмена;
		
	КонецЕсли;
	
	КомпонентыОбмена.КлючСообщения = СвойстваСообщений.Ключ;
	КомпонентыОбмена.СвойстваСообщения = СвойстваСообщений;
	КомпонентыОбмена.ЗаголовкиСообщения = СвойстваСообщений.Заголовки;
	
	НачалоОбработки = ТекущаяУниверсальнаяДатаВМиллисекундах();
	кфкОбменДаннымиXDTOСервер.ПроизвестиЧтениеДанных(КомпонентыОбмена, ТелоСообщения, Правило.ИмяПОД);
	ДлительностьОбработки = ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоОбработки;
	
	Отказ = КомпонентыОбмена.ФлагПропустить;
	ТекстЖурнала = СтрСоединить(КомпонентыОбмена.ПротоколКонвертации, "
		|- - - - - - - - - - - - - - - - - - - - - - - - -
		|");
	
	Возврат КомпонентыОбмена.ФлагОшибки;
	
КонецФункции

#КонецОбласти

#Область УдалениеДублейОчереди

// Выборка дублей исходящих сообщений.
// 
// Параметры:
//  Количество - Число - Количество записей
//  МеткаИзмененияМС - Число - Указатель начала выборки данных
// 
// Возвращаемое значение:
//  ВыборкаИзРезультатаЗапроса - Выборка дублей исходящих сообщений:
//	* КлючЗаписи - Строка - Владелец сообщения
//	* ДатаРегистрацииМС - Число - Дата регистрации (мс)
//	* Продюсер - СправочникСсылка.кфкПродюсеры - Продюсер
//	* МеткаИзмененияМС - Число - Метка изменения (мс)
//
Функция ВыборкаДублейИсходящихСообщений(Количество, МеткаИзмененияМС)
	
	ТекстЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1000
	|	Т1.КлючЗаписи КАК КлючЗаписи,
	|	Т1.ДатаРегистрацииМС КАК ДатаРегистрацииМС,
	|	Т1.Продюсер КАК Продюсер,
	|	Т1.МеткаИзмененияМС КАК МеткаИзмененияМС
	|ИЗ
	|	РегистрСведений.кфкИсходящиеСообщения КАК Т1
	|ГДЕ
	|	Т1.МеткаИзмененияМС >= &МеткаИзмененияМС
	|	И НЕ Т1.ДатаРегистрацииМС В
	|		(ВЫБРАТЬ
	|			МАКСИМУМ(Т2.ДатаРегистрацииМС) КАК ДатаРегистрацииМС
	|		ИЗ
	|			РегистрСведений.кфкИсходящиеСообщения КАК Т2
	|		ГДЕ
	|			Т2.КлючЗаписи = Т1.КлючЗаписи)
	|	И НЕ 0 В
	|		(ВЫБРАТЬ
	|			0
	|		ИЗ
	|			РегистрСведений.кфкОчередьПотоков КАК ОП
	|		ГДЕ
	|			ОП.Ключ = Т1.КлючЗаписи)
	|	И Т1.Статус В (ЗНАЧЕНИЕ(Перечисление.кфкСтатусыСообщений.Новое),
	|		ЗНАЧЕНИЕ(Перечисление.кфкСтатусыСообщений.ОшибкаОбработки), ЗНАЧЕНИЕ(Перечисление.кфкСтатусыСообщений.Обработано),
	|		ЗНАЧЕНИЕ(Перечисление.кфкСтатусыСообщений.ОшибкаВыгрузки))
	|
	|УПОРЯДОЧИТЬ ПО
	|	МеткаИзмененияМС";
	
	Запрос = Новый Запрос;
	Запрос.Текст = СтрЗаменить(ТекстЗапроса, "1000", XMLСтрока(Количество));
	Запрос.УстановитьПараметр("МеткаИзмененияМС", МеткаИзмененияМС);
	
	Возврат Запрос.Выполнить().Выбрать();
	
КонецФункции

#КонецОбласти

#Область ВозвратВОчередь

// Возвращает выборку возврата в очередь
// 
// Параметры:
//	Количество - Число - Количество записей
//	МеткаИзмененияМС - Число, Произвольный - Метка изменения МС
//	МаксКоличествоВыгрузок - Число - Макс количество выгрузок
// 
// Возвращаемое значение:
//	ВыборкаИзРезультатаЗапроса - Выборка возврата в очередь:
//		* КлючЗаписи - Строка - Ключ записи
//		* ДатаРегистрацииМС - Число - Дата регистрации МС
//		* ИсходныеДанные - ХранилищеЗначения - Исходные данные
//		* ЭтоУдаление - Булево - Это удаление
//		* КлючСообщения - Строка - Ключ сообщения
//		* Заголовки - ХранилищеЗначения - Заголовки
//		* ТелоСообщения - ХранилищеЗначения - Тело сообщения
//		* Продюсер - Строка - Продюсер
//		* ТипОбъект - Строка - Тип объект
//		* ТипИсходныхДанных - Строка - Тип исходных данных
//		* КлючОбъекта - Строка - Ключ объекта
//		* СобытиеРегистрации - ПеречислениеСсылка.кфкСобытияРегистрации - Событие регистрации
//		* ДатаРегистрации - Дата - Дата регистрации
//		* ДатаОбработки - Дата - Дата обработки
//		* ДатаВыгрузки - Дата - Дата выгрузки
//		* ДлОбработкиМС - Число - Длительность обработки МС
//		* ТекстЖурнала - Строка - Текст журнала
//		* КоличествоОбработок - Число - Количество обработок
//		* КоличествоВыгрузок - Число - Количество выгрузок
//		* МеткаИзмененияМС - Число - Метка изменения МС
Функция ВыборкаВозвратаВОчередь(Количество, МеткаИзмененияМС, МаксКоличествоВыгрузок)
	
	ТекстЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1000
	|	Т.КлючЗаписи КАК КлючЗаписи,
	|	Т.ДатаРегистрацииМС КАК ДатаРегистрацииМС,
	|	Т.ИсходныеДанные КАК ИсходныеДанные,
	|	Т.ЭтоУдаление КАК ЭтоУдаление,
	|	Т.КлючСообщения КАК КлючСообщения,
	|	Т.Заголовки КАК Заголовки,
	|	Т.ТелоСообщения КАК ТелоСообщения,
	|	Т.Продюсер КАК Продюсер,
	|	Т.ТипОбъект КАК ТипОбъект,
	|	Т.ТипИсходныхДанных КАК ТипИсходныхДанных,
	|	Т.КлючОбъекта КАК КлючОбъекта,
	|	Т.СобытиеРегистрации КАК СобытиеРегистрации,
	|	Т.ДатаРегистрации КАК ДатаРегистрации,
	|	Т.ДатаОбработки КАК ДатаОбработки,
	|	Т.ДатаВыгрузки КАК ДатаВыгрузки,
	|	Т.ДлОбработкиМС КАК ДлОбработкиМС,
	|	Т.ТекстЖурнала КАК ТекстЖурнала,
	|	Т.КоличествоОбработок КАК КоличествоОбработок,
	|	Т.КоличествоВыгрузок КАК КоличествоВыгрузок,
	|	Т.МеткаИзмененияМС КАК МеткаИзмененияМС
	|ИЗ
	|	РегистрСведений.кфкИсходящиеСообщения КАК Т
	|ГДЕ
	|	Т.МеткаИзмененияМС > &МеткаИзмененияМС
	|	И Т.Статус = ЗНАЧЕНИЕ(Перечисление.кфкСтатусыСообщений.ОшибкаВыгрузки)
	|	И Т.КоличествоВыгрузок < &КоличествоВыгрузок
	|
	|УПОРЯДОЧИТЬ ПО
	|	МеткаИзмененияМС";
	
	Запрос = Новый Запрос;
	Запрос.Текст = СтрЗаменить(ТекстЗапроса, "1000", XMLСтрока(Количество));
	Запрос.УстановитьПараметр("МеткаИзмененияМС", МеткаИзмененияМС);
	Запрос.УстановитьПараметр("КоличествоВыгрузок", МаксКоличествоВыгрузок);
	
	Возврат Запрос.Выполнить().Выбрать();
	
КонецФункции

#КонецОбласти

#Область ОчисткаХранилищаОчереди

// Удаляет записи регистра сведений на основе переданной выборки.
//
// Параметры:
//	Выборка - ВыборкаИзРезультатаЗапроса - Выборка записей регистра сведений для удаления
//	Менеджер - РегистрСведенийМенеджерИмяРегистраСведений - Менеджер регистра сведений, записи которого необходимо удалить
//	РазмерПакета - Число - Количество записей в пакете
Процедура УдалитьЗаписиРС(Выборка, Менеджер, РазмерПакета)
	
	Если Выборка.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	Набор = кфкОбщегоНазначенияСлужебный.СоздатьНаборЗаписей(Менеджер);
	Пока Выборка.Следующий() Цикл
		
		ЗаполнитьЗначенияСвойств(Набор.Добавить(), Выборка);
		
		Если Набор.Количество() = РазмерПакета Тогда
			Прервать;
		КонецЕсли;
		
	КонецЦикла;
	Набор.Записать(РежимЗамещения.Удаление);
	
КонецПроцедуры

#Область УдалениеУстаревшихСообщений

// Возвращает параметры очистки хранилища очереди сообщений
// 
// Возвращаемое значение:
//	Структура - Параметры очистки хранилища:
//	 * СрокХраненияНезавершенных - Число - Срок хранения незавершенных сообщений в днях
//	 * СрокХраненияОшибкиОбработкиИсходящих - Число - Срок хранения ошибок отправки исходящих сообщений в днях
//	 * СрокХраненияОтмененныхИсходящих - Число - Срок хранения отмененных исходящих сообщений в днях
//	 * СрокХраненияОшибкиОтправки - Число - Срок хранения ошибок отправки исходящих сообщений в днях
//	 * СрокХраненияОтправленных - Число - Срок хранения отправленных сообщений в днях
//	 * СрокХраненияОшибкиОбработкиВходящих - Число - Срок хранения ошибок обработки входящих сообщений в днях
//	 * СрокХраненияОтмененныхВходящих - Число - Срок хранения отмененных входящих сообщений в днях
//	 * СрокХраненияОбработанных - Число - Срок хранения обработанных сообщений в днях
//	 * УчитыватьУказательЛогирования - Булево - Признак необходимости учитывать указатель логирования
Функция ПараметрыОчисткиХранилища()
	
	Результат = РегистрыСведений.кфкПараметрыОчисткиХранилища.ПолучитьПараметры();
	Результат.Вставить("УчитыватьУказательЛогирования", ПараметрыЛогирования().Использовать);
	
	Возврат Результат;
	
КонецФункции

// Выборка устаревших исходящих сообщений. см. ОчисткаХранилищаОчереди
// 
// Параметры:
//	ПараметрыОчистки - см. ПараметрыОчисткиХранилища
//	Количество - Число - Количество записей
// 
// Возвращаемое значение:
//	ВыборкаИзРезультатаЗапроса - Выборка записей исходящих сообщений:
//		* КлючЗаписи - Строка - Владелец сообщения
//		* ДатаРегистрацииМС - Число - Дата регистрации (мс)
Функция ВыборкаУстаревшихИсходящихСообщений(ПараметрыОчистки, Количество)
	
	УказателиУдаления = УказателиУдаленияИсходящих(ПараметрыОчистки);
	Если УказателиУдаления.Количество() = 0 Тогда
		Возврат Новый Массив; // Заглушка
	КонецЕсли;
	
	Запрос = Новый Запрос;
	
	ТекстЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1000
	|	Т.КлючЗаписи КАК КлючЗаписи,
	|	Т.ДатаРегистрацииМС КАК ДатаРегистрацииМС
	|ИЗ
	|	РегистрСведений.кфкИсходящиеСообщения КАК Т
	|
	|ГДЕ
	|	&УсловияУдаления";
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "1000", XMLСтрока(Количество));
	
	УсловияУдаления = Новый Массив; // Массив Из Строка
	Для Каждого Указатель Из УказателиУдаления Цикл
		
		КлючУказателя = XMLСтрока(Указатель.Ключ);
		ИмяПараметраУказателя = "Указатель" + КлючУказателя;
		ИмяПараметраСтатуса = "Статус" + КлючУказателя;
		
		УсловияУдаления.Добавить(СтрШаблон("Т.МеткаИзмененияМС < &%1 И Т.Статус В (&%2)",
			ИмяПараметраУказателя, ИмяПараметраСтатуса));
		
		Запрос.УстановитьПараметр(ИмяПараметраУказателя, Указатель.Ключ);
		Запрос.УстановитьПараметр(ИмяПараметраСтатуса, Указатель.Значение);
		
	КонецЦикла;
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УсловияУдаления", СтрСоединить(УсловияУдаления, " ИЛИ "));
	
	Запрос.Текст = ТекстЗапроса;
	
	Возврат Запрос.Выполнить().Выбрать();

КонецФункции

// Выборка устаревших входящих сообщений. см. ОчисткаХранилищаОчереди
// 
// Параметры:
//	ПараметрыОчистки - см. ПараметрыОчисткиХранилища
//	Количество - Число - Количество записей
// 
// Возвращаемое значение:
//  ВыборкаИзРезультатаЗапроса - Выборка записей входящих сообщений:
//	* Консьюмер - СправочникСсылка.кфкКонсьюмеры - Консьюмер
//	* Топик - Строка - Топик
//	* Раздел - Строка - Раздел
//	* КлючСообщения - Строка - Ключ сообщения
//	* ДатаЗагрузкиМС - Число - Дата загрузки в МС
Функция ВыборкаУстаревшихВходящихСообщений(ПараметрыОчистки, Количество)
	
	УказателиУдаления = УказателиУдаленияВходящих(ПараметрыОчистки);
	Если УказателиУдаления.Количество() = 0 Тогда
		Возврат Новый Массив; // Заглушка
	КонецЕсли;
	
	Запрос = Новый Запрос;
	
	ТекстЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1000
	|	Т.КлючЗаписи КАК КлючЗаписи,
	|	Т.ДатаЗагрузкиМС КАК ДатаЗагрузкиМС
	|ИЗ
	|	РегистрСведений.кфкВходящиеСообщения КАК Т
	|
	|ГДЕ
	|	&УсловияУдаления";
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "1000", XMLСтрока(Количество));
	
	УсловияУдаления = Новый Массив; // Массив Из Строка
	Для Каждого Указатель Из УказателиУдаления Цикл
		
		КлючУказателя = XMLСтрока(Указатель.Ключ);
		ИмяПараметраУказателя = "Указатель" + КлючУказателя;
		ИмяПараметраСтатуса = "Статус" + КлючУказателя;
		
		УсловияУдаления.Добавить(СтрШаблон("Т.МеткаИзмененияМС < &%1 И Т.Статус В (&%2)",
			ИмяПараметраУказателя, ИмяПараметраСтатуса));
		
		Запрос.УстановитьПараметр(ИмяПараметраУказателя, Указатель.Ключ);
		Запрос.УстановитьПараметр(ИмяПараметраСтатуса, Указатель.Значение);
		
	КонецЦикла;
	ТекстЗапроса = СтрЗаменить(ТекстЗапроса, "&УсловияУдаления", СтрСоединить(УсловияУдаления, " ИЛИ "));
	
	Запрос.Текст = ТекстЗапроса;
	
	Возврат Запрос.Выполнить().Выбрать();
	
КонецФункции

// Возвращает указатели удаления исходящих сообщений.
// 
// Параметры:
//	ПараметрыОчистки - см. ПараметрыОчисткиХранилища
// 
// Возвращаемое значение:
//	Соответствие Из КлючИЗначение - Указатели удаления:
//		* Ключ - Число - Указатель удаления по статусу
//		* Значение - Массив Из ПеречислениеСсылка.кфкСтатусыСообщений - Статусы сообщений
Функция УказателиУдаленияИсходящих(ПараметрыОчистки)
	
	// УдалениеДублейОчереди
	УказательУдаленияДублей = ПолучитьПозицию(ИДОперации_УказательУдаленияДублейОчереди()); // Число
	// УдалениеУстаревшихИсходящихСообщений
	УказательВыгрузкиЛогов = ?(ПараметрыОчистки.УчитыватьУказательЛогирования,
		ПолучитьПозицию(ИДОперации_ВыгрузкаЛоговИсходящихСообщений()), Неопределено); // Число, Неопределено
	
	Результат = Новый Соответствие;
	
	ТекущаяУниверсальнаяДатаМС = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	// СрокХраненияНезавершенных
	СрокХранения = РассчитатьУказательУдаления(ТекущаяУниверсальнаяДатаМС, ПараметрыОчистки.СрокХраненияНезавершенных,
		УказательВыгрузкиЛогов);
	Если СрокХранения <> Неопределено Тогда
		СрокХранения = Мин(УказательУдаленияДублей, СрокХранения);
		ДобавитьУказательУдаления(Результат, Перечисления.кфкСтатусыСообщений.ПустаяСсылка(), СрокХранения);
		ДобавитьУказательУдаления(Результат, Перечисления.кфкСтатусыСообщений.Новое, СрокХранения);
		ДобавитьУказательУдаления(Результат, Перечисления.кфкСтатусыСообщений.Обработано, СрокХранения);
	КонецЕсли;
	
	// СрокХраненияОшибкиОбработкиИсходящих
	ДобавитьУказательУдаления(Результат, Перечисления.кфкСтатусыСообщений.ОшибкаОбработки,
		РассчитатьУказательУдаления(ТекущаяУниверсальнаяДатаМС, ПараметрыОчистки.СрокХраненияОшибкиОбработкиИсходящих,
			УказательВыгрузкиЛогов));
	
	// СрокХраненияОтмененныхИсходящих
	ДобавитьУказательУдаления(Результат, Перечисления.кфкСтатусыСообщений.ОбработкаОтменена,
		РассчитатьУказательУдаления(ТекущаяУниверсальнаяДатаМС, ПараметрыОчистки.СрокХраненияОтмененныхИсходящих,
			УказательВыгрузкиЛогов));
	
	// СрокХраненияОшибкиОтправки
	ДобавитьУказательУдаления(Результат, Перечисления.кфкСтатусыСообщений.ОшибкаВыгрузки,
		РассчитатьУказательУдаления(ТекущаяУниверсальнаяДатаМС, ПараметрыОчистки.СрокХраненияОшибкиОтправки,
			УказательВыгрузкиЛогов));
	
	// СрокХраненияОтправленных
	ДобавитьУказательУдаления(Результат, Перечисления.кфкСтатусыСообщений.Выгружено,
		РассчитатьУказательУдаления(ТекущаяУниверсальнаяДатаМС, ПараметрыОчистки.СрокХраненияОтправленных,
			УказательВыгрузкиЛогов));
	
	Возврат Результат;
	
КонецФункции

// Возвращает указатели удаления входящих сообщений.
// 
// Параметры:
//	ПараметрыОчистки - см. ПараметрыОчисткиХранилища
// 
// Возвращаемое значение:
//	Соответствие Из КлючИЗначение - Указатели удаления:
//		* Ключ - Число - Указатель удаления по статусу
//		* Значение - Массив Из ПеречислениеСсылка.кфкСтатусыСообщений - Статусы сообщений
Функция УказателиУдаленияВходящих(ПараметрыОчистки)
	
	// УдалениеДублейОчереди
	УказательУдаленияДублей = ПолучитьПозицию(ИДОперации_УказательУдаленияДублейОчереди()); // Число
	// УдалениеУстаревшихИсходящихСообщений
	УказательВыгрузкиЛогов = ?(ПараметрыОчистки.УчитыватьУказательЛогирования,
		ПолучитьПозицию(ИДОперации_ВыгрузкаЛоговИсходящихСообщений()), Неопределено); // Число, Неопределено
	
	Результат = Новый Соответствие;
	
	ТекущаяУниверсальнаяДатаМС = ТекущаяУниверсальнаяДатаВМиллисекундах();
	
	// СрокХраненияНезавершенных
	СрокХранения = РассчитатьУказательУдаления(ТекущаяУниверсальнаяДатаМС, ПараметрыОчистки.СрокХраненияНезавершенных,
		УказательВыгрузкиЛогов);
	Если СрокХранения <> Неопределено Тогда
		СрокХранения = Мин(УказательУдаленияДублей, СрокХранения);
		ДобавитьУказательУдаления(Результат, Перечисления.кфкСтатусыСообщений.ПустаяСсылка(), СрокХранения);
		ДобавитьУказательУдаления(Результат, Перечисления.кфкСтатусыСообщений.Новое, СрокХранения);
	КонецЕсли;
	
	// СрокХраненияОшибкиОбработкиВходящих
	ДобавитьУказательУдаления(Результат, Перечисления.кфкСтатусыСообщений.ОшибкаОбработки,
		РассчитатьУказательУдаления(ТекущаяУниверсальнаяДатаМС, ПараметрыОчистки.СрокХраненияОшибкиОбработкиВходящих,
			УказательВыгрузкиЛогов));
	
	// СрокХраненияОтмененныхВходящих
	ДобавитьУказательУдаления(Результат, Перечисления.кфкСтатусыСообщений.ОбработкаОтменена,
		РассчитатьУказательУдаления(ТекущаяУниверсальнаяДатаМС, ПараметрыОчистки.СрокХраненияОтмененныхВходящих,
			УказательВыгрузкиЛогов));
	
	// СрокХраненияОбработанных
	ДобавитьУказательУдаления(Результат, Перечисления.кфкСтатусыСообщений.Обработано,
		РассчитатьУказательУдаления(ТекущаяУниверсальнаяДатаМС, ПараметрыОчистки.СрокХраненияОбработанных,
			УказательВыгрузкиЛогов));
	
	Возврат Результат;
	
КонецФункции

// Рассчитать указатель удаления.
// 
// Параметры:
//	ТекущаяУниверсальнаяДатаМС - Число - Текущая универсальная дата в миллисекундах
//	СрокХранения - Число - Срок хранения в днях
//	ВыгрузкаЛогов - Неопределено, Число - Указатель выгрузки логов
// 
// Возвращаемое значение:
//	Число, Неопределено - Указатель удаления
Функция РассчитатьУказательУдаления(ТекущаяУниверсальнаяДатаМС, СрокХранения, ВыгрузкаЛогов)
	
	Если СрокХранения = -1 Тогда // удаление не требуется
		Возврат Неопределено;
		
	ИначеЕсли СрокХранения = -2 Тогда // удаление после выгрузки логов
		Возврат ВыгрузкаЛогов; // Неопределено, Число
		
	ИначеЕсли СрокХранения >= 0 Тогда // удаление через заданный срок
		Возврат ?(ВыгрузкаЛогов = Неопределено,
			ТекущаяУниверсальнаяДатаМС - СрокХранения * 86400000,				// без ожидания выгрузки логов
			Мин(ВыгрузкаЛогов, РассчитатьУказательУдаления(ТекущаяУниверсальнаяДатаМС, СрокХранения, Неопределено)));	// с учетом выгрузки логов
		
	Иначе
		ВызватьИсключение НСтр("ru = 'Некорректный срок хранения'");
		
	КонецЕсли;
	
КонецФункции

// Дополняет указатели удаления
// 
// Параметры:
//	Указатели - Соответствие Из КлючИЗначение - Указатели удаления
//	СтатусСообщения - ПеречислениеСсылка.кфкСтатусыСообщений - Статус сообщения
//	СрокХранения - см. РассчитатьУказательУдаления
Процедура ДобавитьУказательУдаления(Указатели, СтатусСообщения, СрокХранения)
	
	Если СрокХранения = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Статусы = Указатели.Получить(СрокХранения); // Массив Из ПеречислениеСсылка.кфкСтатусыСообщений
	Если Статусы = Неопределено Тогда
		Статусы = Новый Массив;
		Указатели.Вставить(СрокХранения, Статусы);
	КонецЕсли;
	
	Статусы.Добавить(СтатусСообщения);
	
КонецПроцедуры

#КонецОбласти

#Область ОчисткаСлужебныхТаблиц

// Выборка позиции операций.
// 
// Возвращаемое значение:
//	ВыборкаИзРезультатаЗапроса - Выборка позиции операций:
//	 * Идентификатор - УникальныйИдентификатор - Идентификатор операции
//	 * Раздел - Строка - Дополнительный раздел операции
Функция ВыборкаПозицииОпераций()
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	Т.Идентификатор КАК Идентификатор,
	|	Т.Раздел КАК Раздел
	|ИЗ
	|	РегистрСведений.кфкПозицииОпераций КАК Т
	|ГДЕ
	|	Т.ВременнаяМетка < &ВременнаяМетка";
	Запрос.УстановитьПараметр("ВременнаяМетка", ТекущаяУниверсальнаяДатаВМиллисекундах() - 2592000000); // 30 дней
	
	Возврат Запрос.Выполнить().Выбрать();
	
КонецФункции

// Выборка идентификаторов потока.
// 
// Возвращаемое значение:
//  ВыборкаИзРезультатаЗапроса - Выборка идентификаторов потока:
//	 * ИдентификаторПотока - УникальныйИдентификатор - Идентификатор потока
Функция ВыборкаИдентификаторовПотока()
	
	Запрос = Новый Запрос("ВЫБРАТЬ РАЗЛИЧНЫЕ ИдентификаторПотока ИЗ РегистрСведений.кфкОчередьПотоков");
	
	Возврат Запрос.Выполнить().Выбрать();
	
КонецФункции

