// Запустить фоновое задание
// 
// Параметры:
//  Ключ - Строка - Ключ
//  ИмяМетода - Строка - Имя метода
//  Наименование - Строка - Наименование
//  Параметры - Неопределено, Массив Из Произвольный - Параметры
// 
// Возвращаемое значение:
//  ФоновоеЗадание - Запущенное задание
Функция ЗапуститьФЗ(Ключ, ИмяМетода, Наименование, Параметры = Неопределено)
	
	Отбор = Новый Структура;
	Отбор.Вставить("Ключ", Ключ);
	Отбор.Вставить("Состояние", СостояниеФоновогоЗадания.Активно);
	Задания = ФоновыеЗадания.ПолучитьФоновыеЗадания(Отбор);
	Если Задания.Количество() = 0 Тогда
		Задание = ФоновыеЗадания.Выполнить(
			ИмяМетода,
			Параметры,
			Ключ,
			Наименование);
		
		Если Задание.Состояние = СостояниеФоновогоЗадания.ЗавершеноАварийно Тогда
			ВызватьИсключение ОбработкаОшибок.ПодробноеПредставлениеОшибки(Задание.ИнформацияОбОшибке);
		КонецЕсли;
		
		Возврат Задание;
		
//		ВызватьПаузу(5000); // контроль выполнения - ждем 5 сек, затем проверяем статус ФЗ
//		Задание = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(Задание.УникальныйИдентификатор);
//		Если Задание.Состояние = СостояниеФоновогоЗадания.ЗавершеноАварийно Тогда
//			ВызватьИсключение ОбработкаОшибок.ПодробноеПредставлениеОшибки(Задание.ИнформацияОбОшибке);
//		КонецЕсли;
		
	Иначе
		Возврат Задания[0];
		
	КонецЕсли;
	
КонецФункции

