// Возвращает список операций продюсера.
// 
// Возвращаемое значение:
//  СписокЗначений Из Строка - Операции


// Возвращает список всех операций.
// 
// Возвращаемое значение:
//  СписокЗначений Из Строка - Операции
Функция СписокВсехОпераций()
	
	Результат = Новый СписокЗначений; // СписокЗначений Из Строка
	
	ОбщегоНазначенияКлиентСервер.ДополнитьСписок(Результат, СписокОперацийОбмена(Тип("СправочникСсылка.кфкПродюсеры")));
	ОбщегоНазначенияКлиентСервер.ДополнитьСписок(Результат, СписокОперацийОбмена(Тип("СправочникСсылка.кфкКонсьюмеры")));
	
	ОбщегоНазначенияКлиентСервер.ДополнитьСписок(Результат, СписокСлужебныхОпераций());
	
	Возврат Результат;
	
КонецФункции

// Возвращает список операций консьюмера.
// 
// Параметры:
//	ФактЗапуска - Неопределено, Структура - Факт запуска:
//		* Выгрузка - Булево - Выгрузка
//		* Загрузка - Булево - Загрузка
//		* Сериализация - Булево - Сериализация
//		* Десериализация - Булево - Десериализация
// ИгнорироватьФункциональныеОпции - Булево - Игнорировать функциональные опции
// 
// Возвращаемое значение:
//	СписокЗначений Из ЭлементСпискаЗначений - Операции:
//		* Значение - Строка - Имя операции
//		* Представление - Строка - Представление операции
Функция СписокСлужебныхОпераций(ФактЗапуска = Неопределено, ИгнорироватьФункциональныеОпции = Ложь)
	
	Результат = Новый СписокЗначений; // СписокЗначений Из Строка
	
	// Параметры запуска служебных операций
	ЕстьСериализация = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ФактЗапуска, "Сериализация", Истина);
	ЕстьДесериализация = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ФактЗапуска, "Десериализация", Истина);
	ЕстьВыгрузка = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ФактЗапуска, "Выгрузка", Истина);
	ЕстьЗагрузка = ОбщегоНазначенияКлиентСервер.СвойствоСтруктуры(ФактЗапуска, "Загрузка", Истина);
	ИспользоватьВнешнееЛогирование = ПолучитьФункциональнуюОпцию("кфкИспользоватьВнешнееЛогирование");
	
	// 1.1 - Служебные операции для исходящих сообщений
	Если ЕстьСериализация Или ЕстьВыгрузка Тогда
		Результат.Добавить("УдалениеДублейОчереди", НСтр("ru = 'Удаление дублей очереди'"));
	КонецЕсли;
	Если ЕстьВыгрузка Тогда
		Результат.Добавить("ВозвратВОчередь", НСтр("ru = 'Возврат в очередь'"));
	КонецЕсли;
	
	// 1.2 - Служебные операции для входящих сообщений
	// тут будут служебные операции для входящих сообщений
	
	// 2 - Очистка хранилища
	Если ЕстьСериализация Или ЕстьВыгрузка Тогда // 2.1 - Очистка РС ИсходящиеСообщения
		Результат.Добавить("УдалениеУстаревшихИсходящихСообщений",
			НСтр("ru = 'Удаление устаревших исходящих сообщений'"));
	КонецЕсли;
	Если ЕстьДесериализация Или ЕстьЗагрузка Тогда // 2.2 - Очистка РС ВходящиеСообщения
		Результат.Добавить("УдалениеУстаревшихВходящихСообщений",
			НСтр("ru = 'Удаление устаревших входящих сообщений'"));
	КонецЕсли;
	Результат.Добавить("ОчисткаСлужебныхТаблиц", НСтр("ru = 'Очистка служебных таблиц'")); // 2.3 - Вспомогательные таблицы
	
	// 3 - Выгрузка логов во внешнее хранилище
	Если ИгнорироватьФункциональныеОпции Или ИспользоватьВнешнееЛогирование Тогда
		
		Если ЕстьСериализация Или ЕстьВыгрузка Тогда // 3.1 - Логи из РС ИсходящиеСообщения
			Результат.Добавить("ВыгрузкаЛоговИсходящихСообщений", НСтр("ru = 'Выгрузка логов исходящих сообщений'"));
		КонецЕсли;
		
		Если ЕстьДесериализация Или ЕстьЗагрузка Тогда // 3.2 - Логи из РС ВходящиеСообщения
			Результат.Добавить("ВыгрузкаЛоговВходящихСообщений", НСтр("ru = 'Выгрузка логов входящих сообщений'"));
		КонецЕсли;
		
	КонецЕсли;
	
	// 4 - Алерты
	Если ИгнорироватьФункциональныеОпции Или ПолучитьФункциональнуюОпцию("кфкИспользоватьКонтрольИнтеграции") Тогда
		Результат.Добавить("КонтрольИнтеграции", НСтр("ru = 'Контроль интеграции'"));
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Возвращает список операций продюсера или консьюмера.
// 
// Параметры:
//  ТипИнтеграции - Тип - Тип интеграции: СправочникСсылка.кфкПродюсеры или СправочникСсылка.кфкКонсьюмеры
//  ТипОперация - Неопределено, Булево - Истина - только обработка, Ложь - только транспорт, иначе - все
// 
// Возвращаемое значение:
//	СписокЗначений Из Строка - Список операций:
//	 * Знчаение - Строка - Имя операции
//	 * Представление - Строка - Синоним операции
//	 * ЭтоТранспорт - Булево - Это транспорт
Функция СписокОперацийОбмена(ТипИнтеграции, ТипОперация = Неопределено)
	
	Результат = Новый СписокЗначений; // СписокЗначений Из Строка
	
	Если ТипИнтеграции = Тип("СправочникСсылка.кфкПродюсеры") Тогда
		// Сериализация
		Операция = ОписаниеОперацииОбработки(ТипИнтеграции);
		Результат.Добавить(Операция.Имя, Операция.Синоним, Операция.ЭтоТранспорт);
		// Выгрузка
		Операция = ОписаниеОперацииТранспорта(ТипИнтеграции);
		Результат.Добавить(Операция.Имя, Операция.Синоним, Операция.ЭтоТранспорт);
		
	ИначеЕсли ТипИнтеграции = Тип("СправочникСсылка.кфкКонсьюмеры") Тогда
		// Десериализация
		Операция = ОписаниеОперацииОбработки(ТипИнтеграции);
		Результат.Добавить(Операция.Имя, Операция.Синоним, Операция.ЭтоТранспорт);
		// Загрузка
		Операция = ОписаниеОперацииТранспорта(ТипИнтеграции);
		Результат.Добавить(Операция.Имя, Операция.Синоним, Операция.ЭтоТранспорт);
		 
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

// Описание операции обработки.
// 
// Параметры:
//  ТипИнтеграции - Тип - Тип интеграции: СправочникСсылка.кфкПродюсеры или СправочникСсылка.кфкКонсьюмеры
// 
// Возвращаемое значение:
//  Неопределено, Структура - Описание операции обработки:
// * Имя - Строка - Имя операции
// * Синоним - Строка - Синоним операции
// * ЭтоТранспорт - Булево - Это транспорт
Функция ОписаниеОперацииОбработки(ТипИнтеграции)
	
	Результат = Новый Структура;
	Результат.Вставить("Имя", "");
	Результат.Вставить("Синоним", "");
	Результат.Вставить("ЭтоТранспорт", Ложь);
		
	Если ТипИнтеграции = Тип("СправочникСсылка.кфкПродюсеры") Тогда
		Результат.Имя = "СериализацияСообщений";
		Результат.Синоним = НСтр("ru = 'Сериализация сообщений'");
		
	ИначеЕсли ТипИнтеграции = Тип("СправочникСсылка.кфкКонсьюмеры") Тогда
		Результат.Имя = "ДесериализацияСообщений";
