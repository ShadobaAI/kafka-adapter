#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура УстановитьВидимостьДоступность() Экспорт
	
	// ОБЩИЙ ДОСТУП
	Элементы.ВключитьПодсистему.Видимость = Не ИспользоватьИнтеграцию;
	Элементы.ВыключитьПодсистему.Видимость = ИспользоватьИнтеграцию;
	Элементы.КомандыПерейти.Доступность = ИспользоватьИнтеграцию;
	Элементы.ГруппаПанельОсновное.Доступность = ИспользоватьИнтеграцию;
	
	// НАВИГАЦИЯ
	Картинка = ?(БлокировкаИнтеграции, БиблиотекаКартинок.кфкЗаблокироватьПотоки16, БиблиотекаКартинок.кфкРазблокироватьПотоки16х16);
	Элементы.ПерейтиФоновыеЗадания.Картинка = Картинка;
	Элементы.ПерейтиФоновыеЗаданияИзОсновной.Картинка = Картинка;
	
	Картинка = ?(ИспользоватьРегламентноеЗадание, БиблиотекаКартинок.кфкЗапуск16, БиблиотекаКартинок.кфкПауза16);
	Элементы.ПерейтиРегламентноеЗадание.Картинка = Картинка;
	Элементы.ПерейтиРегламентноеЗаданиеИзОсновной.Картинка = Картинка;
	
КонецПроцедуры

#Область Навигация

&НаКлиенте
Процедура ПерейтиНаСтраницуПриОткрытии()
	
	Если Не ПустаяСтрока(Параметры.ИмяСтраницы) Тогда
		ОткрытьСтраницу(Параметры.ИмяСтраницы);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьСтраницу(ИмяСтраницы)
	
	ОткрытьФорму("Обработка.кфкПанельАдминистрирования.Форма." + ИмяСтраницы, , ЭтотОбъект, , Окно);
	
КонецПроцедуры

#КонецОбласти

#Область УправлениеПодсистемой

&НаСервереБезКонтекста
Процедура ВключитьПодсистемуНаСервере()
	
	Константы.кфкИспользоватьИнтеграцию.Установить(Истина);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ВыключитьПодсистемуНаСервере()
	
	Константы.кфкИспользоватьИнтеграцию.Установить(Ложь);
	Константы.кфкБлокировкаИнтеграции.Установить(Истина);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти
