#Область УправлениеПодсистемой

&НаКлиенте
Процедура ВключитьПодсистему(Команда)
	
	ИспользоватьИнтеграцию = Истина;
	ВключитьПодсистемуНаСервере();
	
	УстановитьВидимостьДоступность();
	
	ОбновитьИнтерфейс();
	
КонецПроцедуры

&НаКлиенте
Асинх Процедура ВыключитьПодсистему(Команда)
	
	ЗаголовокВопроса = НСтр("ru = 'Полная остановка обмена с Kafka и регистрации данных'");
	ТекстВопроса = НСтр("ru = 'Вы отключаете обработку сообщений Kafka и регистрацию данных в системе.
		|Это может привести к рассинхронизации данных при последующей интеграции.
		|Продолжить выполнение?'");
	Кнопки = Новый СписокЗначений; // СписокЗначений Из КодВозвратаДиалога
	Кнопки.Добавить(КодВозвратаДиалога.Да, НСтр("ru = 'Продолжить'"));
	Кнопки.Добавить(КодВозвратаДиалога.Нет, НСтр("ru = 'Отмена'"));
	Ответ = Ждать ВопросАсинх(ТекстВопроса, Кнопки, 60, КодВозвратаДиалога.Нет, ЗаголовокВопроса, КодВозвратаДиалога.Нет); // КодВозвратаДиалога
	Если Ответ = КодВозвратаДиалога.Нет Тогда
		Возврат;
	КонецЕсли;
	
	ИспользоватьИнтеграцию = Ложь;
	БлокировкаИнтеграции = Истина;
	ВыключитьПодсистемуНаСервере();
	
	УстановитьВидимостьДоступность();
	
	ОбновитьИнтерфейс();
	
КонецПроцедуры

#КонецОбласти

