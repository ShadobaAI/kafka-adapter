#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	кфкИспользоватьИнтеграцию.Значение КАК ИспользоватьИнтеграцию,
		|	кфкБлокировкаИнтеграции.Значение КАК БлокировкаИнтеграции
		|ИЗ
		|	Константа.кфкИспользоватьИнтеграцию КАК кфкИспользоватьИнтеграцию,
		|	Константа.кфкБлокировкаИнтеграции КАК кфкБлокировкаИнтеграции";
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, Выборка);
	
	ИспользоватьРегламентноеЗадание = кфкФоновыеОперацииСлужебный.РегламентноеЗадание().Использование;
	
	ВерсияПодсистемы = кфкОбщегоНазначенияСлужебный.ВерсияПодсистемы();
	ВерсияКомпоненты = кфкИнтеграцияСлужебныйПовтИсп.ВерсияКомпоненты();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	УстановитьВидимостьДоступность();
	
	Если Не ПустаяСтрока(Параметры.ИмяСтраницы) Тогда
		ПодключитьОбработчикОжидания("ПерейтиНаСтраницуПриОткрытии", 0.1, Истина);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

