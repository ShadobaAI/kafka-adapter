#Область ПараметрыКонтроляИнтеграции

&НаКлиенте
Процедура ИспользоватьКонтрольИнтеграции(Команда)
	
	ИспользоватьКонтрольИнтеграции = Не ИспользоватьКонтрольИнтеграции;
	УстановитьИспользоватьКонтрольИнтеграции(ИспользоватьКонтрольИнтеграции);
	
	УстановитьВидимостьДоступность();
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура УстановитьВидимостьДоступность()
	
	// НАВИГАЦИЯ
	Элементы.ПерейтиФоновыеЗадания.Картинка = ВладелецФормы.Элементы.ПерейтиФоновыеЗадания.Картинка;
	Элементы.ПерейтиРегламентноеЗадание.Картинка = ВладелецФормы.Элементы.ПерейтиРегламентноеЗадание.Картинка;
	
	// КОНТРОЛЬ ИНТЕГРАЦИИ
	Элементы.ГруппаКонтрольИнтеграции.Доступность = ЕстьИсторияХранилища();
	Элементы.ИспользоватьКонтрольИнтеграции.Пометка = ИспользоватьКонтрольИнтеграции;
	Элементы.ГруппаПараметрыКонтроляИнтеграции.Доступность = ИспользоватьКонтрольИнтеграции;
	
КонецПроцедуры

#Область Навигация

&НаКлиенте
Процедура ОткрытьСтраницу(ИмяСтраницы)
	
	ОткрытьФорму("Обработка.кфкПанельАдминистрирования.Форма." + ИмяСтраницы, , ВладелецФормы, , ВладелецФормы.Окно);
	
КонецПроцедуры

#КонецОбласти

#Область Очереди

&НаКлиенте
Функция ЕстьИсторияХранилища()
	
	Возврат ПараметрыОчисткиХранилища.СрокХраненияОбработанных > 0
//		И ПараметрыОчисткиХранилища.СрокХраненияОтмененныхВходящих > 0
//		И ПараметрыОчисткиХранилища.СрокХраненияОтмененныхИсходящих > 0
		И ПараметрыОчисткиХранилища.СрокХраненияОтправленных > 0
		И ПараметрыОчисткиХранилища.СрокХраненияОшибкиОбработкиВходящих > 0
		И ПараметрыОчисткиХранилища.СрокХраненияОшибкиОбработкиИсходящих > 0
		И ПараметрыОчисткиХранилища.СрокХраненияОшибкиОтправки > 0;
			
КонецФункции

&НаКлиенте
Процедура ОбновитьПараметрыОчисткиХранилища()
	
	ПараметрыОчистки = Новый Структура;
	ПараметрыОчистки.Вставить("СрокХраненияНезавершенных", -1);
	// ИсходящиеСообщения
	ПараметрыОчистки.Вставить("СрокХраненияОшибкиОбработкиИсходящих", -1);
	ПараметрыОчистки.Вставить("СрокХраненияОтмененныхИсходящих", -1);
	ПараметрыОчистки.Вставить("СрокХраненияОшибкиОтправки", -1);
	ПараметрыОчистки.Вставить("СрокХраненияОтправленных", -1);
	// ВходящиеСообщения
	ПараметрыОчистки.Вставить("СрокХраненияОшибкиОбработкиВходящих", -1);
	ПараметрыОчистки.Вставить("СрокХраненияОтмененныхВходящих", -1);
	ПараметрыОчистки.Вставить("СрокХраненияОбработанных", -1);
	
	ЗаполнитьЗначенияСвойств(ПараметрыОчистки, ПараметрыОчисткиХранилища);
	
	ОбновитьПараметрыОчисткиХранилищаНаСервере(ПараметрыОчистки);
	
	Если Не ЕстьИсторияХранилища() И ИспользоватьКонтрольИнтеграции Тогда
		
		ИспользоватьКонтрольИнтеграции = Ложь;
		УстановитьИспользоватьКонтрольИнтеграции(Ложь);
		
	КонецЕсли;
	
	УстановитьВидимостьДоступность();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьПараметрыКонтроляИнтеграции()
	
	ПараметрыКонтроля = Новый Структура;
	// Правила
	ПараметрыКонтроля.Вставить("ВремяSLAИсходящих", 10);
	ПараметрыКонтроля.Вставить("ВремяSLAВходящих", 10);
	// Настройки ТГ
	ПараметрыКонтроля.Вставить("ИдентификаторЧатаТГ", "");
	ПараметрыКонтроля.Вставить("ТокенБотаТГ", "");
	
	ЗаполнитьЗначенияСвойств(ПараметрыКонтроля, ПараметрыКонтроляИнтеграции);
	
	ОбновитьПараметрыКонтроляИнтеграцииНаСервере(ПараметрыКонтроля);
	
	УстановитьВидимостьДоступность();
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьИспользоватьКонтрольИнтеграции(Знчаение)
	
	Константы.кфкИспользоватьКонтрольИнтеграции.Установить(Знчаение);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ОбновитьПараметрыОчисткиХранилищаНаСервере(НовыеПараметры)
	
	ПараметрыОчистки = РегистрыСведений.кфкПараметрыОчисткиХранилища.ПолучитьПараметры();
	ЗаполнитьЗначенияСвойств(ПараметрыОчистки, НовыеПараметры);
	РегистрыСведений.кфкПараметрыОчисткиХранилища.ОбновитьПараметры(ПараметрыОчистки);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ОбновитьПараметрыКонтроляИнтеграцииНаСервере(НовыеПараметры)
	
	РегистрыСведений.кфкПараметрыКонтроляИнтеграции.ОбновитьПараметры(НовыеПараметры);
	
КонецПроцедуры

&НаСервере
Процедура ПрочитатьПараметрыОчисткиХранилища()
	
	ПараметрыОчистки = РегистрыСведений.кфкПараметрыОчисткиХранилища.ПолучитьПараметры();
	ЗаполнитьЗначенияСвойств(ПараметрыОчисткиХранилища, ПараметрыОчистки);
	
	СрокХраненияНезавершенных = ПараметрыОчисткиХранилища.СрокХраненияНезавершенных;
	
КонецПроцедуры

&НаСервере
Процедура ПрочитатьПараметрыКонтроляИнтеграции()
	
	ПараметрыКонтроля = РегистрыСведений.кфкПараметрыКонтроляИнтеграции.ПолучитьПараметры();
	ЗаполнитьЗначенияСвойств(ПараметрыКонтроляИнтеграции, ПараметрыКонтроля);
	
КонецПроцедуры

#КонецОбласти

#КонецОбласти
