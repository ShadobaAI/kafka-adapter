#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ
		|	кфкИспользоватьКонтрольИнтеграции.Значение КАК ИспользоватьКонтрольИнтеграции
		|ИЗ
		|	Константа.кфкИспользоватьКонтрольИнтеграции КАК кфкИспользоватьКонтрольИнтеграции";
	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	ЗаполнитьЗначенияСвойств(ЭтотОбъект, Выборка);
	
	ПрочитатьПараметрыОчисткиХранилища();
	ПрочитатьПараметрыКонтроляИнтеграции();
	
	Элементы.ГруппаПанельОчереди.Доступность = кфкОбщегоНазначенияСлужебный.ЭтоПолноправныйПользователь();
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	УстановитьВидимостьДоступность();
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовШапкиФормы

#Область ПараметрыОчисткиХранилища

&НаКлиенте
Процедура ПараметрыОчисткиХранилищаСрокХраненияНезавершенныхПриИзменении(Элемент)
	
	Если ПараметрыОчисткиХранилища.СрокХраненияНезавершенных = 0 Тогда
		ПараметрыОчисткиХранилища.СрокХраненияНезавершенных = ?(СрокХраненияНезавершенных > 0, -1, 1);
	КонецЕсли;
	
	ОбновитьПараметрыОчисткиХранилища();
	
	СрокХраненияНезавершенных = ПараметрыОчисткиХранилища.СрокХраненияНезавершенных;
	
КонецПроцедуры

