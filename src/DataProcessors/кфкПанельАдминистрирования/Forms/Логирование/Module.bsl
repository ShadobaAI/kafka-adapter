#Область Логирование

// Завершить выбор каталога логирования.
// 
// Параметры:
//  ПутьККаталогу - Строка, Массив Из Строка - Путь к каталогу
//  ДополнительныеПараметры - Структура - Дополнительные параметры
&НаКлиенте
Процедура ЗавершитьВыборКаталогаЛогирования(ПутьККаталогу, ДополнительныеПараметры) Экспорт
	
	Если ПутьККаталогу = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Если ТипЗнч(ПутьККаталогу) = Тип("Массив") И ПутьККаталогу.Количество() Тогда
		КаталогЛогирования = ПутьККаталогу[0];
		
	ИначеЕсли ТипЗнч(ПутьККаталогу) = Тип("Строка") И Не ПустаяСтрока(ПутьККаталогу) Тогда
		КаталогЛогирования = ПутьККаталогу;
		
	КонецЕсли;
	
	Если СодержитКириллицуВСтроке(КаталогЛогирования) Тогда
		ОбщегоНазначенияКлиент.СообщитьПользователю(НСтр("ru = 'Каталог логирования не может содержать кириллицу!'"), ,
			, "КаталогЛогирования");
		
	Иначе
		УстановитьКаталогЛогирования(КаталогЛогирования);
		
	КонецЕсли;
	
КонецПроцедуры

// Содержит кириллицу в строке.
// 
// Параметры:
//  СтрокаПроверки - Строка - Строка проверки
// 
// Возвращаемое значение:
//  Булево - Содержит кириллицу в строке
&НаКлиенте
Функция СодержитКириллицуВСтроке(СтрокаПроверки)
	
	Если ТипЗнч(СтрокаПроверки) <> Тип("Строка") Или ПустаяСтрока(СтрокаПроверки) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	Для Индекс = 1 По СтрДлина(СтрокаПроверки) Цикл
		КодСимвола = КодСимвола(Сред(СтрокаПроверки, Индекс, 1));
		Если 1040 <= КодСимвола И КодСимвола <= 1105 Или КодСимвола = 1025 Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	
	Возврат Ложь;
	
КонецФункции

&НаКлиенте
Процедура ОбновитьПараметрыЛогирования()
	
	ПараметрыЛога = Новый Структура;
	ПараметрыЛога.Вставить("Использовать", Ложь);
	// Настройки внешнего логирования
	ПараметрыЛога.Вставить("АдресСервиса", "");
	ПараметрыЛога.Вставить("Префикс", "");
	// ИсходящиеСообщения
	ПараметрыЛога.Вставить("ВыгружатьИсходныеДанныеИсходящих", Ложь);
	ПараметрыЛога.Вставить("ВыгружатьЗаголовкиСообщенияИсходящих", Ложь);
	ПараметрыЛога.Вставить("ВыгружатьТелоСообщенияИсходящих", Ложь);
	// ВходящиеСообщения
	ПараметрыЛога.Вставить("ВыгружатьЗаголовкиСообщенияВходящих", Ложь);
	ПараметрыЛога.Вставить("ВыгружатьТелоСообщенияВходящие", Ложь);
	
	ЗаполнитьЗначенияСвойств(ПараметрыЛога, ПараметрыЛогирования);
	
	ОбновитьПараметрыЛогированияНаСервере(ПараметрыЛога);
	
	УстановитьВидимостьДоступность();
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьКаталогЛогирования(Значение)
	
	Константы.кфкКаталогЛогированияКомпоненты.Установить(Значение);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьФорматИмениФайловЛогирования(Значение)
	
	Константы.кфкФорматИмениФайловЛогированияКомпоненты.Установить(Значение);
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ОбновитьПараметрыЛогированияНаСервере(НовыеПараметры)
	
	ПараметрыЛога = РегистрыСведений.кфкПараметрыЛогирования.ПолучитьПараметры();
	ЗаполнитьЗначенияСвойств(ПараметрыЛога, НовыеПараметры);
	РегистрыСведений.кфкПараметрыЛогирования.ОбновитьПараметры(НовыеПараметры);
	
КонецПроцедуры

&НаСервере
Процедура ПрочитатьПараметрыЛогирования()
	
	ПараметрыЛога = РегистрыСведений.кфкПараметрыЛогирования.ПолучитьПараметры();
	ЗаполнитьЗначенияСвойств(ПараметрыЛогирования, ПараметрыЛога);
	
КонецПроцедуры

