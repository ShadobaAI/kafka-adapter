{
  "$schema": "https://1c-syntax.github.io/bsl-language-server/configuration/schema.json",
  "language": "ru",
  "configurationRoot": "src",
  "diagnostics": {
    "computeTrigger": "onSave",
    "skipSupport": "never",
    "parameters": {
      "AssignAliasFieldsInQuery": false,
      "UsingServiceTag": false,
      "Typo": {
        "minWordLength": 3,
        "userWordsToIgnore": "асинх,кфк,подпотоки,партишионер,партишионера,автообновления,консьюмер,консьюмеры,консьюмеров,консьюмера,сериализации,сериализацию,десериализации,десериализацию",
        "caseInsensitive": true
      }
    }
  }
}